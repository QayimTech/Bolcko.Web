@{
    ViewData["Title"] = "في انتظار الموافقة";
}
<div class="max-w-lg mx-auto p-6 text-center" dir="rtl">
    <div class="bg-amber-50 border border-amber-200 rounded-2xl p-12 shadow-sm">
        <p class="text-6xl mb-4">⏳</p>
        <h1 class="text-2xl font-bold text-amber-800 mb-3">طلبك قيد المراجعة</h1>
        <p class="text-amber-700 mb-6">شكراً لتسجيلك كمندوب! يقوم فريق بولكو بمراجعة طلبك. سيتم إشعارك عبر التطبيق فور اتخاذ القرار.</p>
        <form asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="px-6 py-2 bg-amber-600 text-white rounded-lg hover:bg-amber-700 text-sm font-medium">
                تسجيل الخروج
            </button>
        </form>
    </div>
</div>
