@using Bolcko.Domain.Entities.Delivery
@using Bolcko.Domain.Enums
@model DeliveryJob
@{
    Layout = null; // صفحة موبايل خفيفة بدون الـ Layout العام لكي لا تطالبه بتسجيل دخول
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تحديث الشحنة #@Model.Id - بلوكو للتوصيل</title>
    <!-- Tailwind CSS directly from CDN for lightweight and clean design -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        body {
            font-family: 'Cairo', sans-serif;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md bg-white rounded-3xl border border-slate-200 shadow-xl overflow-hidden">
        <!-- Brand Header -->
        <div class="bg-slate-900 text-white p-6 text-center">
            <h1 class="font-black text-lg tracking-wider text-[#E8A020]">BLOCKO DELIVERY</h1>
            <p class="text-xs text-slate-400 mt-1">تحديث تسليم شحنة #@Model.Id</p>
        </div>

        <!-- Feedback Messages -->
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="p-6 text-center">
                <span class="material-symbols-outlined text-emerald-500 text-6xl block mb-4">check_circle</span>
                <h2 class="font-black text-emerald-800 text-lg mb-2">@ViewBag.SuccessMessage</h2>
                <p class="text-xs text-slate-500">تم حفظ البيانات وتحديث لوحة تحكم المتجر بنجاح.</p>
            </div>
        }
        else
        {
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="m-6 p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl text-xs font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">error</span>
                    @ViewBag.ErrorMessage
                </div>
            }

            <div class="p-6">
                <!-- Customer info card -->
                <div class="bg-slate-50 rounded-2xl border border-slate-200 p-4 mb-6 space-y-3">
                    <h3 class="font-black text-slate-800 text-xs flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm text-[#E8A020]">person</span>
                        معلومات الزبون
                    </h3>
                    <div class="text-xs space-y-1">
                        <p class="font-bold text-slate-900">الاسم: @(Model.Order?.User?.FirstName) @(Model.Order?.User?.LastName)</p>
                        <p class="text-slate-500">العنوان: @(Model.Order?.ShippingAddress?.AddressLine1), @(Model.Order?.ShippingAddress?.City)</p>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Order?.User?.PhoneNumber))
                    {
                        <a href="tel:@(Model.Order.User.PhoneNumber)" class="w-full py-2.5 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-bold rounded-xl text-xs flex items-center justify-center gap-2 transition-all">
                            <span class="material-symbols-outlined text-sm">phone</span>
                            اتصال هاتفي بالزبون
                        </a>
                    }
                </div>

                <!-- Financial values -->
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-amber-50/50 border border-amber-200 rounded-2xl p-4 text-center">
                        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block mb-1">المبلغ المطلوب COD</span>
                        <span class="text-lg font-black text-amber-600">@((Model.Order?.TotalAmount ?? 0).ToString("N2")) د.أ</span>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 text-center">
                        <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block mb-1">أجر التوصيل</span>
                        <span class="text-lg font-black text-slate-800">@(Model.DeliveryFee.ToString("N2")) د.أ</span>
                    </div>
                </div>

                <!-- Update Form -->
                <form asp-action="SubmitDriverUpdate" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="token" value="@Model.DeliveryToken" />

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-2">المبلغ المحصل فعلياً (د.أ) *</label>
                        <input name="collectedAmount" type="number" step="0.01" min="0" value="@(Model.Order?.TotalAmount ?? 0)" required
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                        <p class="text-[10px] text-slate-400 mt-1">أدخل (0) في حال كان الطلب مرتجعاً بالكامل.</p>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-2">سبب المرتجع / ملاحظات (اختياري)</label>
                        <textarea name="returnReason" rows="2" placeholder="اكتب سبب الارتجاع هنا..."
                                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all"></textarea>
                    </div>

                    <button type="submit" class="w-full py-3 bg-[#E8A020] hover:bg-[#d6901c] text-white text-xs font-black rounded-xl shadow-md transition-all active:scale-95 mt-4">
                        تحديث وحفظ التسليم
                    </button>
                </form>
            </div>
        }
    </div>
</body>
</html>
