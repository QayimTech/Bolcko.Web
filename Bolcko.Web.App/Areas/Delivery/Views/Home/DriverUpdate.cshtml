@using Bolcko.Domain.Entities.Delivery
@using Bolcko.Domain.Enums
@model DeliveryJob
@{
    Layout = null;
    var totalCodAmount = Model.Order?.TotalAmount ?? 0m;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تحديث الشحنة #@Model.Id - بلوكو للتوصيل</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        body { font-family: 'Cairo', sans-serif; }
    </style>
</head>
<body class="bg-slate-100 text-slate-800 flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md bg-white rounded-3xl border border-slate-200 shadow-2xl overflow-hidden">
        <!-- Brand Header -->
        <div class="bg-slate-900 text-white p-6 text-center relative">
            <div class="w-12 h-12 bg-[#E8A020]/20 rounded-2xl flex items-center justify-center mx-auto mb-2 text-[#E8A020]">
                <span class="material-symbols-outlined text-2xl">local_shipping</span>
            </div>
            <h1 class="font-black text-lg tracking-wider text-[#E8A020]">BLOCKO EXPRESS</h1>
            <p class="text-xs text-slate-400 mt-0.5">تحديث تسليم شحنة #@Model.Id (طلب @(Model.Order?.OrderNumber ?? ""))</p>
        </div>

        <!-- Feedback Messages -->
        @if (ViewBag.SuccessMessage != null)
        {
            <div class="p-8 text-center space-y-4">
                <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto shadow-inner">
                    <span class="material-symbols-outlined text-5xl">check_circle</span>
                </div>
                <h2 class="font-black text-emerald-800 text-xl">@ViewBag.SuccessMessage</h2>
                <p class="text-xs text-slate-500 leading-relaxed">تمت مزامنة حالة الطلب مع حساب الزبون ولوحة تحكم المتجر بنجاح.</p>
                <div class="pt-4 border-t border-slate-100 text-[11px] text-slate-400 font-bold">شكراً لجهودكم في التوصيل 💚</div>
            </div>
        }
        else
        {
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="m-6 p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-2xl text-xs font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">error</span>
                    @ViewBag.ErrorMessage
                </div>
            }

            <div class="p-6 space-y-6">
                <!-- Customer info card -->
                <div class="bg-slate-50 rounded-2xl border border-slate-200 p-4 space-y-3">
                    <div class="flex justify-between items-center border-b border-slate-200 pb-2">
                        <h3 class="font-black text-slate-800 text-xs flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm text-[#E8A020]">person</span>
                            بيانات المستلم
                        </h3>
                        <span class="text-[10px] bg-slate-200 text-slate-700 px-2 py-0.5 rounded-full font-bold">شحنة #@Model.Id</span>
                    </div>
                    <div class="text-xs space-y-1">
                        <p class="font-bold text-slate-900 text-sm">@(Model.Order?.User?.FirstName) @(Model.Order?.User?.LastName)</p>
                        <p class="text-slate-500">📍 @(Model.Order?.ShippingAddress?.AddressLine1), @(Model.Order?.ShippingAddress?.City)</p>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Order?.User?.PhoneNumber))
                    {
                        <a href="tel:@(Model.Order.User.PhoneNumber)" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-black rounded-xl text-xs flex items-center justify-center gap-2 shadow-md transition-all active:scale-95">
                            <span class="material-symbols-outlined text-base">call</span>
                            اتصال هاتفي مباشر بالزبون (@Model.Order.User.PhoneNumber)
                        </a>
                    }
                </div>

                <!-- Financial Badges -->
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-amber-50/70 border border-amber-200 rounded-2xl p-3 text-center">
                        <span class="text-[10px] text-amber-800 font-bold uppercase block mb-1">المبلغ المطلوب (COD)</span>
                        <span class="text-xl font-black text-amber-600">@totalCodAmount.ToString("N2") <span class="text-xs font-bold">د.أ</span></span>
                        <span class="text-[9px] text-amber-700 font-bold block mt-1">شامل التوصيل بالكامل</span>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-3 text-center">
                        <span class="text-[10px] text-slate-500 font-bold uppercase block mb-1">أجرة التوصيل المستحقة</span>
                        <span class="text-xl font-black text-slate-800">@(Model.DeliveryFee.ToString("N2")) <span class="text-xs font-bold">د.أ</span></span>
                        <span class="text-[9px] text-slate-400 block mt-1">حصة المندوب/الشركة</span>
                    </div>
                </div>

                <!-- Action Preset Selector -->
                <div>
                    <label class="block text-xs font-black text-slate-700 mb-2">حدد حالة التوصيل بنقرة واحدة:</label>
                    <div class="grid grid-cols-3 gap-2">
                        <button type="button" onclick="selectPreset('delivered')" id="btn-delivered"
                                class="preset-btn py-2.5 px-2 bg-emerald-50 border-2 border-emerald-500 text-emerald-700 font-black rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all">
                            <span class="material-symbols-outlined text-lg">check_circle</span>
                            تسليم كامل
                        </button>
                        <button type="button" onclick="selectPreset('returned')" id="btn-returned"
                                class="preset-btn py-2.5 px-2 bg-slate-50 border border-slate-200 text-slate-600 font-bold rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all">
                            <span class="material-symbols-outlined text-lg">cancel</span>
                            مرتجع كامل
                        </button>
                        <button type="button" onclick="selectPreset('partial')" id="btn-partial"
                                class="preset-btn py-2.5 px-2 bg-slate-50 border border-slate-200 text-slate-600 font-bold rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all">
                            <span class="material-symbols-outlined text-lg">published_with_changes</span>
                            تسليم جزئي
                        </button>
                    </div>
                </div>

                <!-- Main Form -->
                <form asp-action="SubmitDriverUpdate" method="post" class="space-y-4 pt-2 border-t border-slate-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="token" value="@Model.DeliveryToken" />

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1.5">المبلغ المحصل فعلياً (د.أ) *</label>
                        <input name="collectedAmount" id="collectedInput" type="number" step="0.01" min="0" value="@totalCodAmount.ToString("F2")" required
                               class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1.5">سبب المرتجع / ملاحظات (اختياري)</label>
                        <select id="reasonPreset" onchange="applyReasonPreset(this.value)" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs text-slate-700 outline-none mb-2 hidden">
                            <option value="">-- اختر سبب الارتجاع الشائع --</option>
                            <option value="الزبون لم يرد على الاتصال الهاتفي">الزبون لم يرد على الاتصال الهاتفي</option>
                            <option value="الزبون رفض الاستلام">الزبون رفض الاستلام</option>
                            <option value="العنوان مكتوب بشكل غير صحيح">العنوان غير صحيح / خارج التغطية</option>
                            <option value="الزبون طلب إرجاع الشحنة">الزبون طلب إلغاء وإرجاع الشحنة</option>
                        </select>
                        <textarea name="returnReason" id="reasonInput" rows="2" placeholder="ملاحظات التسليم أو سبب المرتجع..."
                                  class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all"></textarea>
                    </div>

                    <button type="submit" class="w-full py-3.5 bg-[#E8A020] hover:bg-[#d6901c] text-white text-xs font-black rounded-xl shadow-lg transition-all active:scale-95">
                        حفظ وتأكيد التحديث
                    </button>
                </form>
            </div>
        }
    </div>

    <script>
        const totalCod = @totalCodAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);

        function selectPreset(type) {
            document.querySelectorAll('.preset-btn').forEach(b => {
                b.className = "preset-btn py-2.5 px-2 bg-slate-50 border border-slate-200 text-slate-600 font-bold rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all";
            });

            const btn = document.getElementById('btn-' + type);
            const input = document.getElementById('collectedInput');
            const reasonSelect = document.getElementById('reasonPreset');
            const reasonInput = document.getElementById('reasonInput');

            if (type === 'delivered') {
                btn.className = "preset-btn py-2.5 px-2 bg-emerald-50 border-2 border-emerald-500 text-emerald-700 font-black rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all shadow-sm";
                input.value = totalCod.toFixed(2);
                reasonSelect.classList.add('hidden');
                reasonInput.value = '';
            } else if (type === 'returned') {
                btn.className = "preset-btn py-2.5 px-2 bg-rose-50 border-2 border-rose-500 text-rose-700 font-black rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all shadow-sm";
                input.value = '0.00';
                reasonSelect.classList.remove('hidden');
                reasonInput.value = 'الزبون لم يرد على الاتصال الهاتفي';
            } else if (type === 'partial') {
                btn.className = "preset-btn py-2.5 px-2 bg-amber-50 border-2 border-amber-500 text-amber-700 font-black rounded-xl text-[11px] flex flex-col items-center gap-1 transition-all shadow-sm";
                input.value = (totalCod / 2).toFixed(2);
                reasonSelect.classList.remove('hidden');
                reasonInput.value = 'تسليم جزئي للبضاعة';
            }
        }

        function applyReasonPreset(val) {
            if (val) {
                document.getElementById('reasonInput').value = val;
            }
        }
    </script>
</body>
</html>
