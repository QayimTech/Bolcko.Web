@{
    ViewData["Title"] = "دخول المسؤولين";
    Layout = null; // Clean layout for login
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blocko Admin</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Kufi Arabic', sans-serif; }
    </style>
</head>
<body class="bg-[#1B2235] min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full bg-white shadow-2xl border-t-4 border-[#E8A020] p-10">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-black tracking-tighter text-[#1B2235] uppercase mb-2">BLOCKO <span class="text-[#E8A020]">ADMIN</span></h1>
            <p class="text-slate-500 text-sm font-bold uppercase tracking-widest">بوابة الإدارة المركزية</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border-r-4 border-red-500 text-red-700 p-4 mb-6 text-xs font-bold">
                @ViewBag.Error
            </div>
        }

        <form asp-area="Admin" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-[0.2em] mb-2">البريد الإلكتروني للمسؤول</label>
                <input type="email" name="email" required class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-0 focus:border-[#E8A020] outline-none transition-all" placeholder="admin@blocko.com" />
            </div>
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-[0.2em] mb-2">كلمة المرور</label>
                <input type="password" name="password" required class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-0 focus:border-[#E8A020] outline-none transition-all" placeholder="********" />
            </div>

            <button type="submit" class="w-full bg-[#1B2235] text-white font-bold py-4 uppercase tracking-[0.3em] hover:bg-[#E8A020] hover:text-[#1B2235] transition-all duration-300">
                تسجيل الدخول
            </button>
        </form>

        <div class="mt-10 text-center">
            <a href="/" class="text-[10px] font-bold text-slate-400 hover:text-[#E8A020] uppercase tracking-widest transition-colors">العودة للموقع الرئيسي</a>
        </div>
    </div>
</body>
</html>
