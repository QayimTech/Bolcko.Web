@{
    ViewData["Title"] = "تغيير كلمة المرور";
    Layout = null;
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isRtl = currentCulture == "ar";
}
<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BLOCKO Admin</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Kufi Arabic', sans-serif; }
    </style>
</head>
<body class="bg-[#1B2235] min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full bg-white shadow-2xl border-t-4 border-[#E8A020] p-10">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-black tracking-tighter text-[#1B2235] uppercase mb-2">BLOCKO <span class="text-[#E8A020]">ADMIN</span></h1>
            <p class="text-slate-500 text-sm font-bold uppercase tracking-widest">تغيير كلمة المرور</p>
        </div>

        @* Security Notice *@
        <div class="bg-amber-50 border-r-4 border-[#E8A020] text-amber-800 p-4 mb-6 text-xs font-bold">
            🔐 لأسباب أمنية، يجب عليك تغيير كلمة المرور الافتراضية قبل المتابعة.
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border-r-4 border-red-500 text-red-700 p-4 mb-6 text-xs font-bold">
                @ViewBag.Error
            </div>
        }

        <form asp-area="Admin" asp-controller="Account" asp-action="ChangePassword" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-[0.2em] mb-2">كلمة المرور الجديدة</label>
                <input type="password" name="newPassword" required minlength="8"
                       class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-0 focus:border-[#E8A020] outline-none transition-all"
                       placeholder="أدخل كلمة مرور قوية" />
            </div>
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-[0.2em] mb-2">تأكيد كلمة المرور</label>
                <input type="password" name="confirmPassword" required minlength="8"
                       class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-0 focus:border-[#E8A020] outline-none transition-all"
                       placeholder="أعد إدخال كلمة المرور" />
            </div>

            <button type="submit" class="w-full bg-[#1B2235] text-white font-bold py-4 uppercase tracking-[0.3em] hover:bg-[#E8A020] hover:text-[#1B2235] transition-all duration-300">
                حفظ كلمة المرور والمتابعة
            </button>
        </form>
    </div>
</body>
</html>
