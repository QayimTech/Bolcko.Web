@using Bolcko.Domain.Entities.Catalog.DTOs
@using Bolcko.Web.App.Areas.Admin.Models.ViewModels
@model CategoryIndexViewModel
@{
    ViewData["Title"] = L["ManageCategories"];
}

<section class="p-8 space-y-8 text-right">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="font-headline-md text-on-surface">@L["ManageCategories"]</h1>
            <p class="text-on-surface-variant text-sm mt-1">@L["ManageCategoriesDescription"]</p>
        </div>
        <a href="@Url.Action("Create")" class="bg-[#E8A020] text-white px-6 py-2 font-bold flex items-center gap-2 hover:bg-[#d18f1c] transition-all">
            <span class="material-symbols-outlined">add</span>
            @L["AddNewCategory"]
        </a>
    </div>

    <div class="bg-white border border-slate-200 shadow-hard overflow-hidden">
        @* Pagination on top *@
        <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="Model.Categories" />

        <table class="w-full text-right border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">@L["CategoryName"]</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">@L["ParentCategory"]</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">@L["Description"]</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">@L["Actions"]</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model.Categories.Items)
                {
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <span class="font-bold text-slate-900">@item.Name</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-slate-600">@(item.ParentCategoryName ?? "-")</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-slate-500 text-sm">@item.Description</span>
                        </td>
                        <td class="px-6 py-4 flex gap-2">
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="text-blue-600 hover:text-blue-800 transition-colors">
                                <span class="material-symbols-outlined">edit</span>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="event.preventDefault(); requireDeleteConfirm(this, 'category');" class="inline">
                                <button type="submit" class="text-red-600 hover:text-red-800 transition-colors">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Categories.Items.Any())
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-slate-400 italic">
                            @L["NoCategoriesAvailable"]
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @* Pagination on bottom *@
        <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="Model.Categories" />
    </div>
</section>
