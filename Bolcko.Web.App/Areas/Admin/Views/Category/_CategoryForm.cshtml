@model Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto

<div class="space-y-6">
    <div>
        <label asp-for="Name" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">اسم الفئة</label>
        <input asp-for="Name" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="مثلاً: مواد البناء" />
        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="ParentCategoryId" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الفئة الأب (اختياري)</label>
        <select asp-for="ParentCategoryId" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all">
            <option value="">-- فئة رئيسية --</option>
            @foreach (var parent in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.ParentCategories)
            {
                <option value="@parent.Id">@parent.Name</option>
            }
        </select>
        <span asp-validation-for="ParentCategoryId" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="DisplayOrder" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">ترتيب العرض</label>
        <input asp-for="DisplayOrder" type="number" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="0" />
        <span asp-validation-for="DisplayOrder" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="ImageUrl" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">رابط الصورة (اختياري)</label>
        <input asp-for="ImageUrl" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="https://example.com/image.jpg" />
        <span asp-validation-for="ImageUrl" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="Description" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الوصف</label>
        <textarea asp-for="Description" rows="4" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="وصف موجز للفئة..."></textarea>
        <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
    </div>
</div>
