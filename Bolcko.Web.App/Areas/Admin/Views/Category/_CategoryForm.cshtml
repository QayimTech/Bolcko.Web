@model Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto

<div class="space-y-6">
    <div>
        <label asp-for="Name" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">@L["CategoryName"]</label>
        <input asp-for="Name" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="@L["CategoryNamePlaceholder"]" />
        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="ParentCategoryId" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">@L["ParentCategoryOptional"]</label>
        <select asp-for="ParentCategoryId" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all">
            <option value="">@L["MainCategoryOption"]</option>
            @foreach (var parent in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.ParentCategories)
            {
                <option value="@parent.Id">@parent.Name</option>
            }
        </select>
        <span asp-validation-for="ParentCategoryId" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="DisplayOrder" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">@L["DisplayOrder"]</label>
        <input asp-for="DisplayOrder" type="number" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="0" />
        <span asp-validation-for="DisplayOrder" class="text-red-500 text-xs mt-1"></span>
    </div>

    <div>
        <label asp-for="ImageUrl" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">أيقونة الفئة (اختياري)</label>
        <div class="flex flex-col gap-3">
            <input asp-for="ImageUrl" id="categoryIconInput" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="مثال: category, home, construction" dir="ltr" />
            
            <div class="flex items-center gap-3 bg-slate-50 border border-slate-100 p-3 rounded-xl w-max">
                <span class="text-xs font-bold text-slate-500">الأيقونة المختارة:</span>
                <div class="w-10 h-10 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-700 shadow-sm">
                    <span id="categoryIconPreview" class="material-symbols-outlined text-2xl">category</span>
                </div>
            </div>
        </div>
        <p class="text-[10px] text-slate-400 mt-2 font-medium">اكتب اسم الأيقونة باللغة الإنجليزية من <a href="https://fonts.google.com/icons?icon.set=Material+Symbols" target="_blank" class="text-[#E8A020] hover:underline">مكتبة Material Symbols</a> لتظهر المعاينة في المربع المجاور.</p>
        <span asp-validation-for="ImageUrl" class="text-red-500 text-xs mt-1"></span>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const input = document.getElementById('categoryIconInput');
            const preview = document.getElementById('categoryIconPreview');
            if(input && preview) {
                const updatePreview = () => {
                    let val = input.value.trim();
                    // If user pastes full HTML snippet like <span class="material-symbols-outlined">home</span>
                    if (val.includes('<') && val.includes('>')) {
                        const tempDiv = document.createElement('div');
                        tempDiv.innerHTML = val;
                        val = tempDiv.textContent.trim() || val;
                        input.value = val; // auto-correct the input
                    }
                    preview.textContent = val ? val : 'category';
                };
                input.addEventListener('input', updatePreview);
                updatePreview();
            }
        });
    </script>

    <div>
        <label asp-for="Description" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">@L["Description"]</label>
        <textarea asp-for="Description" rows="4" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="@L["CategoryDescriptionPlaceholder"]"></textarea>
        <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
    </div>
</div>
