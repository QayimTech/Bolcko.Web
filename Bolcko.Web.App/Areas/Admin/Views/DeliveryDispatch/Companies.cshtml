@using Bolcko.Domain.Entities.Delivery
@using Bolcko.Domain.Common
@model IPagedList<DeliveryCompany>
@{
    ViewData["Title"] = "شركات التوصيل";
    Layout = "_Layout";
}

<div class="p-4 md:p-8 text-right" dir="rtl">
    <!-- Header Page -->
    <div class="flex justify-between items-center mb-8 pb-4 border-b border-slate-200">
        <div>
            <h1 class="text-2xl font-black text-slate-800 flex items-center gap-3">
                <span class="material-symbols-outlined text-[#E8A020] text-3xl">local_shipping</span>
                إدارة شركات التوصيل والخدمات اللوجستية
            </h1>
            <p class="text-xs text-slate-400 mt-1">قم بتسجيل وتعديل شركات الشحن المتعاقد معها وتحديد أسعارها الأساسية وحسابات مدراءها.</p>
        </div>
        <a asp-action="Index" class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-black rounded-2xl transition-all active:scale-95 border border-slate-200 shadow-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            الرجوع للوحة التحكم
        </a>
    </div>

    <!-- Feedback Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 px-5 py-4 rounded-2xl flex items-center gap-3 animate-slide-up-fade shadow-sm">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <span class="text-xs font-bold">@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-6 bg-rose-50 border border-rose-200 text-rose-800 px-5 py-4 rounded-2xl flex items-center gap-3 animate-slide-up-fade shadow-sm">
            <span class="material-symbols-outlined text-rose-600">error</span>
            <span class="text-xs font-bold">@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 items-start">
        <!-- Section A: Register New Company Form (1 Column) -->
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6">
            <h2 class="font-black text-slate-800 text-sm uppercase tracking-wider mb-6 flex items-center gap-2 border-b pb-3 border-slate-100">
                <span class="material-symbols-outlined text-[#E8A020] text-lg">add_circle</span>
                إضافة شركة جديدة
            </h2>
            <form asp-action="CreateCompany" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1.5">اسم الشركة *</label>
                    <input name="name" type="text" required placeholder="شركة التوصيل السريع"
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1.5">البريد الإلكتروني</label>
                    <input name="email" type="email" placeholder="info@delivery.com"
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all text-left" dir="ltr" />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1.5">رقم الهاتف</label>
                    <input name="phoneNumber" type="tel" placeholder="0791234567"
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all text-left" dir="ltr" />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1.5">رقم السجل التجاري</label>
                    <input name="commercialRegister" type="text" placeholder="12345678"
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all text-left" dir="ltr" />
                </div>
                
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1.5">سعر التوصيل الأساسي (د.أ) *</label>
                    <input name="baseRate" type="number" step="0.01" min="0" value="5.00" required
                           class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                </div>

                <div class="border-t border-slate-100 pt-3 mt-2">
                    <p class="text-xs font-black text-indigo-600 mb-3 flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">lock</span>
                        إنشاء حساب مستخدم لمدير الشركة
                    </p>
                    <div class="space-y-3">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">اسم المستخدم (للدخول) *</label>
                            <input name="username" type="text" required placeholder="مثال: aramex_manager"
                                   class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all text-left" dir="ltr" autocomplete="off" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">كلمة المرور *</label>
                            <input name="password" type="password" required placeholder="••••••••"
                                   class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-xs focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all text-left" dir="ltr" autocomplete="new-password" />
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full py-3 bg-[#E8A020] hover:bg-[#d6901c] text-white text-xs font-black rounded-xl shadow-md transition-all active:scale-95 mt-4">
                    إضافة الشركة وإنشاء الحساب
                </button>
            </form>
        </div>

        <!-- Section B: Companies Table (2 Columns) -->
        <div class="xl:col-span-2 bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
                <h2 class="font-black text-xs text-slate-700 uppercase tracking-widest">الشركات والخدمات اللوجستية المسجلة</h2>
                <span class="text-[10px] bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-full font-bold">إجمالي الشركات: @Model.TotalCount</span>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-slate-100 text-slate-600 font-bold text-[10px] uppercase tracking-widest border-b border-slate-200">
                        <tr>
                            <th class="px-6 py-4">اسم الشركة</th>
                            <th class="px-6 py-4">البريد والهاتف</th>
                            <th class="px-6 py-4">السعر الأساسي</th>
                            <th class="px-6 py-4">رقم السجل</th>
                            <th class="px-6 py-4">الحالة</th>
                            <th class="px-6 py-4 text-center">خيارات التحكم</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-xs">
                        @foreach (var company in Model.Items)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 font-bold text-slate-900">
                                    <div class="flex items-center gap-2">
                                        <span class="w-2.5 h-2.5 rounded-full @(company.IsActive ? "bg-emerald-500" : "bg-slate-300")"></span>
                                        <div>
                                            <span class="block">@company.Name</span>
                                            @if (!string.IsNullOrEmpty(company.ManagerUserId))
                                            {
                                                <span class="text-[9px] bg-indigo-50 text-indigo-600 px-1.5 py-0.5 rounded font-black mt-1 inline-block">حساب المدير نشط</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="block text-slate-800 font-medium">@(company.Email ?? "—")</span>
                                    <span class="block text-slate-400 text-[10px] mt-0.5" dir="ltr">@(company.PhoneNumber ?? "—")</span>
                                </td>
                                <td class="px-6 py-4 font-bold text-slate-800">
                                    @company.BaseDeliveryRate.ToString("N2") د.أ
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-slate-700 font-bold">
                                        @(company.CommercialRegister ?? "—")
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (company.IsActive)
                                    {
                                        <span class="bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full text-[10px] font-bold">نشطة</span>
                                    }
                                    else
                                    {
                                        <span class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full text-[10px] font-bold">غير نشطة</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <form asp-action="ToggleCompanyStatus" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="companyId" value="@company.Id" />
                                            @if (company.IsActive)
                                            {
                                                <button type="submit" class="px-3 py-1.5 bg-amber-50 hover:bg-amber-100 text-amber-700 font-bold rounded-xl text-[10px] transition-all">
                                                    تعطيل الشركة
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 font-bold rounded-xl text-[10px] transition-all">
                                                    تفعيل الشركة
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Items.Any())
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center text-slate-400 italic">
                                    لا توجد شركات توصيل مسجلة حالياً.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="p-4 border-t border-slate-100 bg-slate-50/50">
                <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="@(Model as IPagedList<object>)" />
            </div>
        </div>
    </div>
</div>
