@using Bolcko.Domain.Entities.Delivery
@using Bolcko.Domain.Common
@model IPagedList<DeliveryDriver>
@{
    ViewData["Title"] = "إدارة المناديب";
    Layout = "_Layout";
}

<div class="p-6 text-right" dir="rtl">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-slate-800">👥 إدارة المناديب</h1>
        <a asp-action="Index" class="px-4 py-2 bg-slate-200 text-slate-700 rounded-lg hover:bg-slate-300 text-sm">عودة لمركز التوزيع</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 bg-emerald-50 border border-emerald-300 text-emerald-800 px-5 py-3 rounded-lg">✅ @TempData["Success"]</div>
    }

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-600 text-xs uppercase">
                    <tr>
                        <th class="px-4 py-3 text-right">الاسم</th>
                        <th class="px-4 py-3 text-right">الجوال</th>
                        <th class="px-4 py-3 text-right">المركبة</th>
                        <th class="px-4 py-3 text-right">الشركة</th>
                        <th class="px-4 py-3 text-right">التقييم</th>
                        <th class="px-4 py-3 text-right">الحالة</th>
                        <th class="px-4 py-3 text-right">إجراء</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var driver in Model.Items)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3 font-medium">@driver.User?.FirstName @driver.User?.LastName</td>
                            <td class="px-4 py-3 text-slate-500">@(driver.User?.PhoneNumber ?? "—")</td>
                            <td class="px-4 py-3">@(driver.VehicleType ?? "—") @(driver.VehiclePlateNumber != null ? $"({driver.VehiclePlateNumber})" : "")</td>
                            <td class="px-4 py-3">@(driver.Company?.Name ?? "مستقل 🎯")</td>
                            <td class="px-4 py-3">
                                @if (driver.TotalRatings > 0)
                                {
                                    <span class="text-amber-500">⭐ @driver.AverageRating.ToString("N1")</span>
                                    <span class="text-slate-400 text-xs">(@driver.TotalRatings)</span>
                                }
                                else
                                {
                                    <span class="text-slate-400">لا يوجد</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                @if (driver.IsApproved)
                                {
                                    <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-bold rounded-full">✔ مفعّل</span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-full">⏳ ينتظر الموافقة</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                @if (!driver.IsApproved)
                                {
                                    <form asp-action="ApproveDriver" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="driverId" value="@driver.Id" />
                                        <button type="submit" class="px-3 py-1 bg-emerald-600 text-white text-xs rounded hover:bg-emerald-700">تفعيل</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-slate-400 text-xs">—</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="7" class="px-4 py-8 text-center text-slate-400">لا يوجد مناديب مسجلون بعد</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="@(Model as IPagedList<object>)" />
    </div>
</div>

