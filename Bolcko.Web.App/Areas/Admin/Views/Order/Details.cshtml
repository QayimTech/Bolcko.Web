@model Bolcko.Domain.Entities.Order.DTOs.OrderDto
@{
    ViewData["Title"] = L["OrderDetails"];
    Layout = "_Layout";
}

<div class="p-6 text-right">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">تفاصيل الطلب: @Model.OrderNumber</h1>
        <a asp-action="Index" class="px-4 py-2 bg-slate-200 text-slate-800 rounded hover:bg-slate-300">عودة للقائمة</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 bg-emerald-50 border border-emerald-300 text-emerald-800 px-5 py-3 rounded-lg flex items-center gap-2">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <span class="font-bold text-sm">@TempData["SuccessMessage"]</span>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div class="bg-white p-6 shadow-sm border border-slate-200 rounded-lg">
            <h2 class="text-lg font-bold mb-4 border-b pb-2">معلومات عامة</h2>
            <p class="mb-2"><span class="font-bold">رقم الطلب:</span> @Model.OrderNumber</p>
            <p class="mb-2"><span class="font-bold">التاريخ:</span> @Model.OrderDate.ToString("yyyy/MM/dd HH:mm")</p>
            <p class="mb-3"><span class="font-bold">الحالة:</span>
                <span class="inline-block mr-2 px-3 py-1 text-[11px] font-bold uppercase rounded-full
                    @(Model.Status == Bolcko.Domain.Enums.OrderStatus.Pending ? "bg-amber-100 text-amber-700" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Processing ? "bg-blue-100 text-blue-700" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Shipped ? "bg-purple-100 text-purple-700" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Delivered ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700")">
                    @(Model.Status == Bolcko.Domain.Enums.OrderStatus.Pending ? "قيد الانتظار" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Processing ? "قيد المعالجة" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Shipped ? "تم الشحن" :
                      Model.Status == Bolcko.Domain.Enums.OrderStatus.Delivered ? "تم التوصيل" : "ملغي")
                </span>
            </p>
            <p class="mb-2"><span class="font-bold">العميل:</span> @(Model.UserName ?? "غير محدد")</p>
        </div>

        <div class="bg-white p-6 shadow-sm border border-slate-200 rounded-lg">
            <h2 class="text-lg font-bold mb-4 border-b pb-2">الدفع والشحن</h2>
            <p class="mb-2"><span class="font-bold">المبلغ الإجمالي:</span> @Model.TotalAmount.ToString("N2") د.أ</p>
            <p class="mb-2"><span class="font-bold">طريقة الدفع:</span> @(Model.PaymentMethod ?? "غير محدد")</p>
            <p class="mb-2"><span class="font-bold">حالة الدفع:</span> @Model.PaymentStatus</p>
            
            @if (Model.ShippingAddress != null)
            {
                <h3 class="font-bold mt-6 mb-2 border-b pb-1">عنوان التوصيل:</h3>
                <p class="text-sm leading-relaxed">
                    @Model.ShippingAddress.City, @Model.ShippingAddress.StateProvince<br />
                    @Model.ShippingAddress.AddressLine1<br />
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress.AddressLine2)) { <span>@Model.ShippingAddress.AddressLine2<br /></span> }
                    @if (!string.IsNullOrEmpty(Model.ShippingAddress.PostalCode)) { <span>الرمز البريدي: @Model.ShippingAddress.PostalCode</span> }
                </p>
            }
            else
            {
                <p class="text-sm mt-4 text-slate-500 italic">لا يوجد عنوان توصيل مسجل لهذا الطلب.</p>
            }
        </div>

        <div class="bg-white p-6 shadow-sm border border-slate-200 rounded-lg md:col-span-2">
            <h2 class="text-lg font-bold mb-4 border-b pb-2">تحديث حالة الطلب</h2>
            <form asp-action="UpdateStatus" method="post" class="flex flex-col sm:flex-row gap-4 items-end">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="flex-grow w-full">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 text-start">اختر الحالة الجديدة للطلب:</label>
                    <select name="status" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all rounded-sm text-start font-bold">
                        @foreach (Bolcko.Domain.Enums.OrderStatus status in Enum.GetValues(typeof(Bolcko.Domain.Enums.OrderStatus)))
                        {
                            var arStatus = status == Bolcko.Domain.Enums.OrderStatus.Pending ? "قيد الانتظار" :
                                           status == Bolcko.Domain.Enums.OrderStatus.Processing ? "قيد المعالجة" :
                                           status == Bolcko.Domain.Enums.OrderStatus.Shipped ? "تم الشحن" :
                                           status == Bolcko.Domain.Enums.OrderStatus.Delivered ? "تم التوصيل" : "ملغي";

                            if (Model.Status == status)
                            {
                                <option value="@status" selected>@arStatus</option>
                            }
                            else
                            {
                                <option value="@status">@arStatus</option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="bg-primary text-white font-bold py-3.5 px-8 hover:opacity-90 transition-all shadow-hard w-full sm:w-auto">
                    حفظ حالة الطلب
                </button>
            </form>
        </div>

        <!-- Delivery Dispatch Section -->
        <div class="bg-white p-6 shadow-sm border border-slate-200 rounded-lg md:col-span-2">
            <h2 class="text-lg font-bold mb-4 border-b pb-2">🚚 خيارات التوصيل والإرسال</h2>
            <form asp-controller="DeliveryDispatch" asp-action="CreateJob" method="post" class="flex flex-col sm:flex-row gap-4 items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.Id" />
                <div class="flex-grow w-full">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2 text-start">أدخل رسوم التوصيل المقترحة (د.أ):</label>
                    <input name="deliveryFee" type="number" step="0.01" min="0" value="5.00" required
                           class="w-full bg-slate-50 border border-slate-200 px-4 py-3.5 text-slate-900 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all rounded-sm text-start font-bold" />
                </div>
                <button type="submit" class="bg-blue-600 text-white font-bold py-3.5 px-8 hover:bg-blue-700 transition-all shadow-hard w-full sm:w-auto">
                    طرح الطلب للتوصيل
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white p-6 shadow-sm border border-slate-200 rounded-lg mb-6">
        <h2 class="text-lg font-bold mb-4 border-b pb-2">العناصر</h2>
        @if (Model.Items != null && Model.Items.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full text-right border-collapse">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-200">
                            <th class="p-3">معرف المنتج</th>
                            <th class="p-3">الاسم</th>
                            <th class="p-3">الكمية</th>
                            <th class="p-3">السعر</th>
                            <th class="p-3">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="border-b border-slate-100">
                                <td class="p-3">@item.ProductId</td>
                                <td class="p-3">@item.ProductName</td>
                                <td class="p-3">@item.Quantity</td>
                                <td class="p-3">@item.UnitPrice.ToString("N2") د.أ</td>
                                <td class="p-3">@item.TotalPrice.ToString("N2") د.أ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-secondary">لا توجد عناصر لهذا الطلب.</p>
        }
    </div>
</div>
