@using Bolcko.Domain.Entities.Order.DTOs
@using Bolcko.Web.App.Areas.Admin.Models.ViewModels
@model OrderIndexViewModel
@{
    ViewData["Title"] = L["ManageOrders"];
}

<section class="p-8 space-y-8 text-start animate-in fade-in duration-500">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="font-headline-md text-on-surface">@L["ManageOrders"]</h1>
            <p class="text-on-surface-variant text-sm mt-1">@L["ManageOrdersDescription"]</p>
        </div>
    </div>

    <div class="bg-white border border-slate-200 shadow-hard overflow-hidden rounded-2xl transition-all hover:shadow-lg">
        @{
            var statusOptions = new List<SelectListItem>();
            foreach (Bolcko.Domain.Enums.OrderStatus st in Enum.GetValues(typeof(Bolcko.Domain.Enums.OrderStatus)))
            {
                var label = st switch
                {
                    Bolcko.Domain.Enums.OrderStatus.Pending => "قيد الانتظار",
                    Bolcko.Domain.Enums.OrderStatus.Processing => "قيد المعالجة",
                    Bolcko.Domain.Enums.OrderStatus.Shipped => "تم الشحن",
                    Bolcko.Domain.Enums.OrderStatus.Delivered => "تم التسليم",
                    Bolcko.Domain.Enums.OrderStatus.Cancelled => "ملغي",
                    _ => st.ToString()
                };
                statusOptions.Add(new SelectListItem { Value = ((int)st).ToString(), Text = label, Selected = Model.Status == st });
            }

            ViewData["SearchPlaceholder"] = "بحث برقم الطلب، اسم الزبون، أو البريد الإلكتروني...";
            ViewData["SearchValue"] = Model.Search;
            ViewData["SortOrder"] = Model.SortOrder;
            ViewData["SelectName"] = "status";
            ViewData["SelectLabel"] = "جميع الحالات";
            ViewData["SelectValue"] = Model.Status.HasValue ? ((int)Model.Status.Value).ToString() : "";
            ViewData["SelectOptions"] = statusOptions;
            ViewData["Action"] = "Index";
            ViewData["Controller"] = "Order";
        }
        <partial name="~/Views/Shared/Partials/_GridFilter.cshtml" />

        @* Pagination on top *@
        <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="Model.Orders" />

        <div class="overflow-x-auto w-full">
            <table class="w-full text-start border-collapse min-w-[800px]">
                <thead>
                    <tr class="bg-slate-100/70 border-b border-slate-200 text-slate-700 text-xs font-bold uppercase tracking-wider select-none">
                        <!-- Order Number -->
                        <th class="px-6 py-4">
                            <a href="@Url.Action("Index", "Order", new { area = "Admin", page = 1, search = Model.Search, status = Model.Status, sortOrder = (Model.SortOrder == "name_asc" ? "name_desc" : "name_asc") })" 
                               class="inline-flex items-center gap-2 group hover:text-[#E8A020] transition-colors py-1 px-2 rounded-lg hover:bg-slate-200/50">
                                <span>@L["OrderNumber"]</span>
                                <div class="flex flex-col text-[10px] leading-none opacity-60 group-hover:opacity-100">
                                    <span class="material-symbols-outlined text-xs -mb-1 @(Model.SortOrder == "name_asc" ? "text-[#E8A020] font-black scale-125" : "text-slate-400")">arrow_drop_up</span>
                                    <span class="material-symbols-outlined text-xs @(Model.SortOrder == "name_desc" ? "text-[#E8A020] font-black scale-125" : "text-slate-400")">arrow_drop_down</span>
                                </div>
                            </a>
                        </th>

                        <!-- Customer -->
                        <th class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 py-1 px-2">@L["Customer"]</span>
                        </th>

                        <!-- Date -->
                        <th class="px-6 py-4">
                            <a href="@Url.Action("Index", "Order", new { area = "Admin", page = 1, search = Model.Search, status = Model.Status, sortOrder = (Model.SortOrder == "asc" ? "desc" : "asc") })" 
                               class="inline-flex items-center gap-2 group hover:text-[#E8A020] transition-colors py-1 px-2 rounded-lg hover:bg-slate-200/50">
                                <span>@L["Date"]</span>
                                <div class="flex flex-col text-[10px] leading-none opacity-60 group-hover:opacity-100">
                                    <span class="material-symbols-outlined text-xs -mb-1 @(Model.SortOrder == "asc" ? "text-[#E8A020] font-black scale-125" : "text-slate-400")">arrow_drop_up</span>
                                    <span class="material-symbols-outlined text-xs @(Model.SortOrder == "desc" || string.IsNullOrEmpty(Model.SortOrder) ? "text-[#E8A020] font-black scale-125" : "text-slate-400")">arrow_drop_down</span>
                                </div>
                            </a>
                        </th>

                        <!-- Total -->
                        <th class="px-6 py-4">
                            <span class="inline-flex items-center gap-1.5 py-1 px-2">@L["Total"]</span>
                        </th>

                        <!-- Status with quick header filter -->
                        <th class="px-6 py-4">
                            <div class="inline-flex items-center gap-1.5 py-1 px-2 relative group">
                                <span>@L["Status"]</span>
                                @if (Model.Status.HasValue)
                                {
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] bg-amber-500 text-white font-bold">نشط</span>
                                }
                            </div>
                        </th>

                        <!-- Actions -->
                        <th class="px-6 py-4 text-center">
                            <span class="inline-flex items-center justify-center py-1 px-2">@L["Actions"]</span>
                        </th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Orders.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors group">
                            <td class="px-6 py-4 font-mono text-xs font-bold text-primary whitespace-nowrap">#ORD-@item.Id.ToString("D4")</td>
                            <td class="px-6 py-4 text-slate-900 font-bold whitespace-nowrap">@item.UserName</td>
                            <td class="px-6 py-4 text-slate-600 whitespace-nowrap">@item.OrderDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-6 py-4 text-primary font-black whitespace-nowrap">@item.TotalAmount.ToString("N2") @L["Currency"]</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 text-[10px] font-bold uppercase rounded-full 
                                    @(item.Status == Bolcko.Domain.Enums.OrderStatus.Pending ? "bg-amber-100 text-amber-700" : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Processing ? "bg-blue-100 text-blue-700" : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Shipped ? "bg-purple-100 text-purple-700" : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Delivered ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700")">
                                    @(item.Status == Bolcko.Domain.Enums.OrderStatus.Pending ? L["StatusPending"] : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Processing ? L["StatusProcessing"] : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Shipped ? L["StatusShipped"] : 
                                      item.Status == Bolcko.Domain.Enums.OrderStatus.Delivered ? L["StatusDelivered"] : L["StatusCancelled"])
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <a href="@Url.Action("Details", new { id = item.Id })" class="text-slate-400 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined">visibility</span>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Orders.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-slate-400 italic">
                                @L["NoOrdersAvailable"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination on bottom *@
        <partial name="~/Views/Shared/Partials/_Pagination.cshtml" model="Model.Orders" />
    </div>
</section>
