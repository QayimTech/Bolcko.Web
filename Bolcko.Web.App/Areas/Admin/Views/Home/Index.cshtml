@{
    ViewData["Title"] = "لوحة التحكم";
}

<section class="p-8 space-y-8 flex-1 text-right">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">إجمالي المبيعات</p>
            <h3 class="font-headline-md text-on-surface">248,500.00 ر.س</h3>
            <div class="flex items-center mt-4 text-emerald-600 text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">trending_up</span> +12.5% عن الشهر الماضي
            </div>
        </div>
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">العطاءات المفتوحة</p>
            <h3 class="font-headline-md text-on-surface">42</h3>
            <div class="flex items-center mt-4 text-amber-600 text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">pending_actions</span> 8 بانتظار الموافقة
            </div>
        </div>
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">قيمة المخزون</p>
            <h3 class="font-headline-md text-on-surface">1.2 مليون</h3>
            <div class="flex items-center mt-4 text-on-surface-variant text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">inventory_2</span> 15% متوفر للكميات
            </div>
        </div>
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">مخاطر التوريد</p>
            <h3 class="font-headline-md text-emerald-600">منخفضة</h3>
            <div class="flex items-center mt-4 text-emerald-600 text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">check_circle</span> جميع القنوات نشطة
            </div>
        </div>
    </div>

    <!-- Main Data Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-gutter items-start">
        <!-- Incoming Tenders (Wide) -->
        <div class="xl:col-span-2 space-y-gutter">
            <div class="bg-white border border-slate-200 overflow-hidden shadow-hard">
                <div class="bg-[#1B2235] px-6 py-4 flex justify-between items-center">
                    <h2 class="text-white font-bold text-sm uppercase tracking-widest">طلبات العطاءات الواردة (RFQs)</h2>
                    <button class="text-[#E8A020] text-xs font-bold uppercase hover:underline">عرض الكل</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-right">
                        <thead class="bg-slate-100 text-[#1B2235] font-bold text-[10px] uppercase tracking-widest">
                            <tr>
                                <th class="px-6 py-3">اسم المشروع</th>
                                <th class="px-6 py-3">العميل</th>
                                <th class="px-6 py-3">الميزانية التقديرية</th>
                                <th class="px-6 py-3">تاريخ الإغلاق</th>
                                <th class="px-6 py-3">الحالة</th>
                                <th class="px-6 py-3">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 text-sm">
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 font-bold text-[#1B2235]">توسعة مجمع صناعي - المرحلة 4</td>
                                <td class="px-6 py-4">شركة بناء المحدودة</td>
                                <td class="px-6 py-4">45k - 60k ر.س</td>
                                <td class="px-6 py-4 text-xs">12 أكتوبر 2024</td>
                                <td class="px-6 py-4">
                                    <span class="bg-[#E8EAF0] text-[#1B2235] px-2 py-1 text-[10px] font-bold uppercase rounded">قيد المراجعة</span>
                                </td>
                                <td class="px-6 py-4 text-[#E8A020] font-bold text-xs cursor-pointer hover:underline">تحليل</td>
                            </tr>
                            <!-- More rows -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Latest Orders (Side Rail) -->
        <div class="space-y-gutter">
            <div class="bg-white border border-slate-200 shadow-hard">
                <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
                    <h2 class="text-[#1B2235] font-bold text-sm uppercase tracking-widest">آخر طلبات المتجر</h2>
                    <span class="bg-[#E8A020] text-[#1B2235] text-[10px] font-black px-2 py-0.5">مباشر</span>
                </div>
                <div class="divide-y divide-slate-100">
                    <div class="p-6 hover:bg-slate-50 transition-colors">
                        <div class="flex justify-between items-start mb-2">
                            <div>
                                <p class="text-xs font-bold text-[#8A95A8] mb-1">#ORD-9921</p>
                                <p class="text-sm font-bold text-[#1B2235]">مثقاب كهربائي عالي الأداء x2</p>
                            </div>
                            <p class="text-sm font-bold text-[#1B2235]">842.00 ر.س</p>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-[10px] font-bold text-amber-600 uppercase">قيد التنفيذ</span>
                            <span class="text-[10px] text-[#8A95A8]">منذ دقيقتين</span>
                        </div>
                    </div>
                    <!-- More orders -->
                </div>
            </div>
        </div>
    </div>
</section>