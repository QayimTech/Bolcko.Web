@model Bolcko.Domain.Entities.Product.DTOs.ProductDto

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-6">
        <div>
            <label asp-for="Name" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">اسم المنتج</label>
            <input asp-for="Name" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
        </div>

        <div>
            <label asp-for="CategoryId" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الفئة</label>
            <select asp-for="CategoryId" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all">
                <option value="">-- اختر الفئة --</option>
                @foreach (var cat in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
            <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1"></span>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="RetailPrice" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">السعر</label>
                <input asp-for="RetailPrice" type="number" step="0.01" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                <span asp-validation-for="RetailPrice" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="Sku" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">SKU</label>
                <input asp-for="Sku" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                <span asp-validation-for="Sku" class="text-red-500 text-xs mt-1"></span>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label asp-for="StockQuantity" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الكمية</label>
                <input asp-for="StockQuantity" type="number" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
                <span asp-validation-for="StockQuantity" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label asp-for="UnitOfMeasure" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">وحدة القياس</label>
                <input asp-for="UnitOfMeasure" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" placeholder="مثلاً: طن، حبة" />
                <span asp-validation-for="UnitOfMeasure" class="text-red-500 text-xs mt-1"></span>
            </div>
        </div>
    </div>

    <div class="space-y-6">
        <div>
            <label asp-for="ImageUrl" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">رابط الصورة</label>
            <input asp-for="ImageUrl" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all" />
            <span asp-validation-for="ImageUrl" class="text-red-500 text-xs mt-1"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الوصف</label>
            <textarea asp-for="Description" rows="5" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-[#E8A020] focus:ring-1 focus:ring-[#E8A020] outline-none transition-all"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
        </div>

        <div class="flex items-center gap-2">
            <input asp-for="BulkPricingAvailable" type="checkbox" class="w-4 h-4 text-[#E8A020] border-slate-300 rounded focus:ring-[#E8A020]" />
            <label asp-for="BulkPricingAvailable" class="text-sm font-bold text-slate-700">متاح لبيع الجملة</label>
        </div>
    </div>
</div>
