@model Bolcko.Domain.Entities.Product.DTOs.ProductDto

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 text-right">

    <!-- ═══════════════════════════════════════════ -->
    <!-- Main Details Panel (7 cols)                -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="lg:col-span-7 space-y-5">

        <!-- Basic Info Card -->
        <div class="bg-white border border-slate-100 rounded-3xl p-6 space-y-5 shadow-sm">
            <div class="flex items-center gap-3 border-b border-slate-100 pb-4 mb-2">
                <span class="material-symbols-outlined text-[#E8A020] text-xl">info</span>
                <h3 class="text-sm font-bold text-slate-800">@L["BasicProductDetails"]</h3>
            </div>

            <!-- Product Name -->
            <div class="space-y-1.5">
                <label asp-for="Name" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["ProductName"]</label>
                <input asp-for="Name"
                       class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                              focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                              outline-none transition-all text-sm font-medium placeholder:text-slate-400"
                       placeholder="@L["ProductNamePlaceholder"]" />
                <span asp-validation-for="Name" class="text-rose-500 text-xs font-bold"></span>
            </div>

            <!-- Category -->
            <div class="space-y-1.5">
                <label asp-for="CategoryId" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["Category"]</label>
                <div class="relative">
                    <select asp-for="CategoryId"
                            class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                   focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                   outline-none transition-all text-sm font-medium appearance-none">
                        <option value="">@L["SelectCategoryOption"]</option>
                        @foreach (var cat in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                    <span class="material-symbols-outlined absolute end-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none text-lg">expand_more</span>
                </div>
                <span asp-validation-for="CategoryId" class="text-rose-500 text-xs font-bold"></span>
            </div>

            <!-- Brand & Country of Origin -->
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label asp-for="Brand" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">الماركة / البراند</label>
                    <input asp-for="Brand"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                  focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                  outline-none transition-all text-sm font-medium"
                           placeholder="مثال: Grohe, RAK" />
                    <span asp-validation-for="Brand" class="text-rose-500 text-xs font-bold"></span>
                </div>
                <div class="space-y-1.5">
                    <label asp-for="CountryOfOrigin" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">بلد المنشأ</label>
                    <input asp-for="CountryOfOrigin"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                  focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                  outline-none transition-all text-sm font-medium"
                           placeholder="مثال: إيطاليا, إسبانيا, الصين" />
                    <span asp-validation-for="CountryOfOrigin" class="text-rose-500 text-xs font-bold"></span>
                </div>
            </div>

            <!-- Price + SKU -->
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label asp-for="RetailPrice" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["PriceLabel"]</label>
                    <div class="relative">
                        <input asp-for="RetailPrice" type="number" step="0.01"
                               class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 pe-10 text-slate-900
                                      focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                      outline-none transition-all text-sm font-medium"
                               placeholder="0.00" />
                        <span class="absolute end-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">@L["Currency"]</span>
                    </div>
                    <span asp-validation-for="RetailPrice" class="text-rose-500 text-xs font-bold"></span>
                </div>
                <div class="space-y-1.5">
                    <label asp-for="Sku" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["SkuLabel"]</label>
                    <input asp-for="Sku"
                           class="w-full bg-slate-100 border border-slate-200 rounded-2xl px-4 py-3 text-slate-500 font-mono font-bold cursor-not-allowed text-sm"
                           readonly title="يتم توليد الرمز تلقائياً ولا يمكن تعديله" />
                    <span asp-validation-for="Sku" class="text-rose-500 text-xs font-bold"></span>
                </div>
            </div>

            <!-- Stock + Unit -->
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label asp-for="StockQuantity" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["StockQuantity"]</label>
                    <input asp-for="StockQuantity" type="number"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                  focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                  outline-none transition-all text-sm font-medium"
                           placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="text-rose-500 text-xs font-bold"></span>
                </div>
                <div class="space-y-1.5">
                    <label asp-for="UnitOfMeasure" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["UnitOfMeasure"]</label>
                    <input asp-for="UnitOfMeasure"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                  focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                  outline-none transition-all text-sm font-medium"
                           placeholder="@L["UnitOfMeasurePlaceholder"]" />
                    <span asp-validation-for="UnitOfMeasure" class="text-rose-500 text-xs font-bold"></span>
                </div>
            </div>

            <!-- Description -->
            <div class="space-y-1.5">
                <label asp-for="Description" class="block text-xs font-bold text-slate-500 uppercase tracking-widest">@L["DescriptionLabel"]</label>
                <textarea asp-for="Description" rows="5"
                          class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3 text-slate-900
                                 focus:bg-white focus:border-[#E8A020] focus:ring-2 focus:ring-[#E8A020]/20
                                 outline-none transition-all text-sm font-medium leading-relaxed resize-none"
                          placeholder="@L["DescriptionPlaceholder"]"></textarea>
                <span asp-validation-for="Description" class="text-rose-500 text-xs font-bold"></span>
            </div>

            <!-- Bulk Pricing Toggle -->
            <label class="flex items-center gap-4 p-4 bg-slate-50 hover:bg-amber-50/50 rounded-2xl border border-slate-100 cursor-pointer transition-all group">
                <div class="relative flex-shrink-0">
                    <input asp-for="BulkPricingAvailable" type="checkbox"
                           class="sr-only peer" />
                    <div class="w-11 h-6 bg-slate-200 peer-checked:bg-[#E8A020] rounded-full transition-colors duration-300"></div>
                    <div class="absolute top-0.5 start-0.5 w-5 h-5 bg-white rounded-full shadow transition-transform duration-300 peer-checked:translate-x-5 rtl:peer-checked:-translate-x-5"></div>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-700">@L["BulkPricingLabel"]</p>
                    <p class="text-xs text-slate-400 mt-0.5">@L["BulkPricingDescription"]</p>
                </div>
            </label>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Media Panel (5 cols)                       -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="lg:col-span-5 space-y-5">
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm">
            <div class="flex items-center gap-3 border-b border-slate-100 pb-4 mb-5">
                <span class="material-symbols-outlined text-[#E8A020] text-xl">photo_library</span>
                <h3 class="text-sm font-bold text-slate-800">@L["ProductImages"]</h3>
            </div>

            <!-- Hidden real file input -->
            <input type="file" id="imageFileInput" name="uploadImages" multiple accept="image/*" class="hidden" />

            <!-- Drop Zone -->
            <div id="imageDropzone"
                 onclick="document.getElementById('imageFileInput').click()"
                 class="relative flex flex-col items-center justify-center gap-3 border-2 border-dashed border-slate-200
                        rounded-2xl p-8 cursor-pointer transition-all duration-200
                        hover:border-[#E8A020] hover:bg-amber-50/30 group">
                <div class="w-14 h-14 bg-slate-100 group-hover:bg-amber-100 rounded-2xl flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined text-3xl text-slate-400 group-hover:text-[#E8A020] transition-colors">cloud_upload</span>
                </div>
                <div class="text-center">
                    <p class="text-sm font-bold text-slate-700">@L["DragDropInstructions"]</p>
                    <p class="text-xs text-slate-400 mt-1">@L["DragDropConstraints"]</p>
                </div>
                <div id="dropzone-active-indicator"
                     class="hidden absolute inset-0 rounded-2xl border-2 border-[#E8A020] bg-amber-50/50 flex items-center justify-center">
                    <p class="text-sm font-bold text-[#E8A020]">@L["DropImagesHere"]</p>
                </div>
            </div>

            <!-- Preview Gallery (new files) -->
            <div id="newImagesPreview" class="mt-4 grid grid-cols-3 gap-2 hidden"></div>

            <!-- File count badge -->
            <p id="fileCountBadge" class="hidden mt-3 text-center text-xs font-bold text-[#E8A020]"></p>

            <!-- Existing Images -->
            @if (Model != null && Model.Images != null && Model.Images.Any())
            {
                <div class="mt-5">
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">@L["CurrentImages"]</p>
                    <div id="existingImagesGrid" class="grid grid-cols-3 gap-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="relative group/img rounded-xl overflow-hidden aspect-square border border-slate-100">
                                <img src="@img.Url" class="w-full h-full object-cover" alt="@img.AltText" />
                                <div class="absolute inset-0 bg-black/40 opacity-0 group-hover/img:opacity-100 transition-all flex items-center justify-center">
                                    <button type="button"
                                            onclick="removeExistingImage(this, @img.Id)"
                                            class="w-8 h-8 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center transition-colors">
                                        <span class="material-symbols-outlined text-sm">close</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (!string.IsNullOrEmpty(Model?.ImageUrl))
            {
                <div class="mt-5">
                    <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-3">@L["CurrentImage"]</p>
                    <div class="rounded-2xl overflow-hidden border border-slate-100 aspect-video">
                        <img src="@(Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : "/" + Model.ImageUrl.TrimStart('/'))" class="w-full h-full object-cover" />
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}

<!-- Variants Management Section -->
<div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm mt-8 text-right">
    <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-5">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[#E8A020] text-xl">inventory_2</span>
            <h3 class="text-sm font-bold text-slate-800">@(isRtl ? "متغيرات المنتج (الأسعار والمخزون لكل لون/قياس)" : "Product Variants (Price/Stock per Option)")</h3>
        </div>
        <button type="button" onclick="addVariantRow()" 
                class="flex items-center gap-2 bg-[#E8A020] hover:bg-[#d69018] text-white px-4 py-2 rounded-2xl text-xs font-bold transition-all">
            <span class="material-symbols-outlined text-sm">add</span>
            <span>@(isRtl ? "إضافة متغير" : "Add Variant")</span>
        </button>
    </div>

    <!-- Variants Table/List -->
    <div class="overflow-x-auto">
        <table class="w-full text-right text-sm border-collapse" id="variantsTable">
            <thead>
                <tr class="border-b border-slate-100 text-slate-400 text-xs font-bold uppercase tracking-wider">
                    <th class="pb-3 text-right">@(isRtl ? "القياس" : "Size")</th>
                    <th class="pb-3 text-right">@(isRtl ? "اللون" : "Color")</th>
                    <th class="pb-3 text-right">@(isRtl ? "وحدة البيع" : "Unit")</th>
                    <th class="pb-3 text-right">@(isRtl ? "بلد المنشأ" : "Origin")</th>
                    <th class="pb-3 text-right">@(isRtl ? "السعر" : "Price")</th>
                    <th class="pb-3 text-right">@(isRtl ? "المخزون" : "Stock")</th>
                    <th class="pb-3 text-right">@(isRtl ? "SKU" : "SKU")</th>
                    <th class="pb-3 text-center">@(isRtl ? "صورة" : "Image")</th>
                    <th class="pb-3 text-center">@(isRtl ? "إجراءات" : "Actions")</th>
                </tr>
            </thead>
            <tbody id="variantsContainer">
                <!-- Dynamic rows here -->
            </tbody>
        </table>
        <div id="noVariantsMsg" class="text-center py-8 text-slate-400 text-xs font-medium">
            @(isRtl ? "لا يوجد متغيرات مضافة لهذا المنتج بعد." : "No variants added for this product yet.")
        </div>
    </div>
</div>

<style>
    /* Checkbox toggle animation */
    input[type="checkbox"].sr-only:checked ~ div:last-child {
        transform: translateX(20px);
    }
    [dir="rtl"] input[type="checkbox"].sr-only:checked ~ div:last-child {
        transform: translateX(-20px);
    }
</style>

<script>
(function () {
    const input     = document.getElementById('imageFileInput');
    const dropzone  = document.getElementById('imageDropzone');
    const preview   = document.getElementById('newImagesPreview');
    const badge     = document.getElementById('fileCountBadge');
    const indicator = document.getElementById('dropzone-active-indicator');

    let selectedFiles = [];
    const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB

    function renderPreviews() {
        preview.innerHTML = '';

        if (!selectedFiles.length) {
            preview.classList.add('hidden');
            badge.classList.add('hidden');
            return;
        }

        selectedFiles.forEach((file, idx) => {
            const reader = new FileReader();
            reader.onload = e => {
                const wrapper = document.createElement('div');
                wrapper.className = 'relative group/thumb rounded-xl overflow-hidden aspect-square border border-slate-100 shadow-sm';
                wrapper.innerHTML = `
                    <img src="${e.target.result}" class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover/thumb:opacity-100 transition-all flex items-center justify-center">
                        <button type="button" data-idx="${idx}"
                                class="remove-preview w-8 h-8 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center transition-colors">
                            <span class="material-symbols-outlined text-sm">close</span>
                        </button>
                    </div>
                    <div class="absolute bottom-1 start-1 bg-black/50 text-white text-[9px] font-bold px-1.5 py-0.5 rounded-lg">
                        ${formatBytes(file.size)}
                    </div>
                `;
                preview.appendChild(wrapper);
            };
            reader.readAsDataURL(file);
        });

        preview.classList.remove('hidden');
        badge.innerHTML = '@Html.Raw(L["SelectedImagesCount"])'.replace("{0}", selectedFiles.length);
        badge.classList.remove('hidden');

        // Sync with input
        const dt = new DataTransfer();
        selectedFiles.forEach(f => dt.items.add(f));
        input.files = dt.files;
    }

    // Rebuild DataTransfer on remove clicks (delegated)
    preview.addEventListener('click', function (e) {
        const btn = e.target.closest('.remove-preview');
        if (!btn) return;
        const idxToRemove = parseInt(btn.dataset.idx);
        selectedFiles.splice(idxToRemove, 1);
        renderPreviews();
    });

    function formatBytes(b) {
        return b > 1048576 ? (b / 1048576).toFixed(1) + ' MB' : (b / 1024).toFixed(0) + ' KB';
    }

    function handleFiles(files) {
        const newFiles = Array.from(files);
        let validFiles = [];
        let hasOversized = false;
        
        newFiles.forEach(f => {
            if (f.type.startsWith('image/')) {
                if (f.size <= MAX_FILE_SIZE) {
                    validFiles.push(f);
                } else {
                    hasOversized = true;
                }
            }
        });

        if (hasOversized) {
            window.BlockoModal.show({ 
                title: 'تجاوز الحجم المسموح', 
                message: '@Html.Raw(L["ImageSizeExceedsLimit"] ?? "بعض الصور تتجاوز الحجم المسموح به (5 ميجابايت).")', 
                icon: 'warning' 
            });
        }

        if (validFiles.length > 0) {
            selectedFiles = [...selectedFiles, ...validFiles];
            renderPreviews();
        }
    }

    input.addEventListener('change', () => {
        handleFiles(input.files);
    });

    // Drag & Drop
    dropzone.addEventListener('dragover', e => {
        e.preventDefault();
        indicator.classList.remove('hidden');
        indicator.classList.add('flex');
    });
    dropzone.addEventListener('dragleave', () => {
        indicator.classList.add('hidden');
        indicator.classList.remove('flex');
    });
    dropzone.addEventListener('drop', e => {
        e.preventDefault();
        indicator.classList.add('hidden');
        indicator.classList.remove('flex');
        handleFiles(e.dataTransfer.files);
    });
})();

function removeExistingImage(btn, imageId) {
    // Add hidden input to mark for server-side deletion
    const form = btn.closest('form') || document.querySelector('form');
    const hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = 'deleteImageIds';
    hidden.value = imageId;
    form.appendChild(hidden);
    btn.closest('.relative').remove();
}

// ═══════════════════════════════════════════
// Dynamic Variant Row Functions
// ═══════════════════════════════════════════

// Upload token for AJAX (RequestVerificationToken)
const __variantAntiForgery = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
const __uploadVariantUrl   = '@Url.Action("UploadVariantImage", "Product", new { area = "Admin" })';

function addVariantRow(data = {}) {
    const container = document.getElementById('variantsContainer');
    const noMsg = document.getElementById('noVariantsMsg');
    if (noMsg) noMsg.classList.add('hidden');

    const imgSrc = data.imageUrl ? data.imageUrl : '';
    const imgPreviewStyle = imgSrc ? '' : 'display:none';

    const tr = document.createElement('tr');
    tr.className = 'border-b border-slate-50 hover:bg-slate-50/50 transition-colors variant-row';
    tr.innerHTML = `
        <td class="py-3 pe-2">
            <input type="hidden" name="Variants[INDEX].Id" value="${data.id || 0}" />
            <input type="hidden" name="Variants[INDEX].ProductId" value="${data.productId || 0}" />
            <input type="text" name="Variants[INDEX].Size" value="${escV(data.size)}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="مثال: 1/2 إنش" />
        </td>
        <td class="py-3 pe-2">
            <input type="text" name="Variants[INDEX].Color" value="${escV(data.color)}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="مثال: كروم" />
        </td>
        <td class="py-3 pe-2">
            <input type="text" name="Variants[INDEX].PackagingUnit" value="${escV(data.packagingUnit)}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="حبة، كرتونة" />
        </td>
        <td class="py-3 pe-2">
            <input type="text" name="Variants[INDEX].CountryOfOrigin" value="${escV(data.countryOfOrigin)}" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="إيطالي، صيني" />
        </td>
        <td class="py-3 pe-2">
            <input type="number" step="0.01" name="Variants[INDEX].Price" value="${data.price || ''}" class="w-24 bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="0.00" />
        </td>
        <td class="py-3 pe-2">
            <input type="number" name="Variants[INDEX].StockQuantity" value="${data.stockQuantity !== undefined ? data.stockQuantity : ''}" class="w-20 bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all" placeholder="0" />
        </td>
        <td class="py-3 pe-2">
            <input type="text" name="Variants[INDEX].Sku" value="${escV(data.sku)}" class="w-28 bg-slate-50 border border-slate-200 rounded-xl px-3 py-2 text-xs focus:bg-white focus:border-[#E8A020] outline-none transition-all font-mono" placeholder="BLK-VAR" />
        </td>
        <td class="py-3 pe-2 text-center">
            <!-- hidden URL field submitted with form -->
            <input type="hidden" name="Variants[INDEX].ImageUrl" class="variant-img-url" value="${escV(data.imageUrl)}" />
            <!-- preview thumbnail -->
            <div class="flex flex-col items-center gap-1">
                <div class="variant-img-preview w-10 h-10 rounded-lg overflow-hidden border border-slate-200 bg-slate-100" style="${imgPreviewStyle}">
                    <img src="${imgSrc}" class="w-full h-full object-cover variant-img-tag" alt="" />
                </div>
                <label class="cursor-pointer text-[10px] text-[#E8A020] font-bold hover:underline variant-img-label">
                    <span class="material-symbols-outlined text-[13px] align-middle">photo_camera</span>
                    <input type="file" accept="image/*" class="hidden variant-img-file" />
                </label>
                <span class="variant-img-spinner hidden text-[10px] text-slate-400">جاري...</span>
            </div>
        </td>
        <td class="py-3 text-center">
            <button type="button" onclick="removeVariantRow(this)" class="w-8 h-8 bg-red-50 hover:bg-red-100 text-red-500 rounded-xl flex items-center justify-center transition-colors mx-auto">
                <span class="material-symbols-outlined text-sm">delete</span>
            </button>
        </td>
    `;
    container.appendChild(tr);

    // Attach image upload listener to the new row's file input
    const fileInput = tr.querySelector('.variant-img-file');
    fileInput.addEventListener('change', function() {
        if (!this.files || !this.files[0]) return;
        uploadVariantImage(this.files[0], tr);
    });

    reindexVariants();
}

// AJAX upload for a single variant image
function uploadVariantImage(file, tr) {
    const spinner = tr.querySelector('.variant-img-spinner');
    const urlInput = tr.querySelector('.variant-img-url');
    const preview = tr.querySelector('.variant-img-preview');
    const img     = tr.querySelector('.variant-img-tag');

    spinner.classList.remove('hidden');

    const fd = new FormData();
    fd.append('variantImage', file);
    fd.append('__RequestVerificationToken', __variantAntiForgery);

    fetch(__uploadVariantUrl, { method: 'POST', body: fd })
        .then(r => r.json())
        .then(data => {
            spinner.classList.add('hidden');
            if (data.success) {
                urlInput.value = data.url;
                img.src = data.url;
                preview.style.display = '';
            } else {
                alert('خطأ في رفع الصورة: ' + data.message);
            }
        })
        .catch(() => {
            spinner.classList.add('hidden');
            alert('تعذّر رفع الصورة. تحقق من الاتصال.');
        });
}

function escV(v) { return (v == null ? '' : String(v).replace(/"/g, '&quot;').replace(/'/g, '&#39;')); }

function removeVariantRow(btn) {
    btn.closest('tr').remove();
    reindexVariants();
}

function reindexVariants() {
    const rows = document.querySelectorAll('.variant-row');
    const noMsg = document.getElementById('noVariantsMsg');
    if (rows.length === 0) {
        if (noMsg) noMsg.classList.remove('hidden');
    } else {
        if (noMsg) noMsg.classList.add('hidden');
    }

    rows.forEach((row, idx) => {
        row.querySelectorAll('input[name]').forEach(input => {
            const name = input.getAttribute('name');
            if (name) {
                input.setAttribute(
                    'name',
                    name.replace(/Variants\[(\d+|INDEX)\]/g, `Variants[${idx}]`)
                );
            }
        });
    });
}
</script>

<!-- Variant data stored as Base64 in data attribute to be immune to HTML/JS minifiers -->
<div id="variants-data-holder"
     data-variants="@Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(System.Text.Json.JsonSerializer.Serialize(Model?.Variants ?? new List<Bolcko.Domain.Entities.Product.DTOs.ProductVariantDto>())))" 
     style="display:none"
     aria-hidden="true"></div>

<script>
// Render existing variants on page load safely using JSON
function initVariants() {
    console.log('[initVariants] called');
    try {
        const holder = document.getElementById('variants-data-holder');
        console.log('[initVariants] holder:', holder);
        if (!holder) {
            console.error('[initVariants] variants-data-holder NOT FOUND!');
            return;
        }
        const b64 = holder.getAttribute('data-variants') || '';
        console.log('[initVariants] b64 length:', b64.length);
        if (!b64) { console.warn('[initVariants] data-variants is empty'); return; }
        const binaryString = atob(b64);
        const bytes = new Uint8Array(binaryString.length);
        for (let i = 0; binaryString.length > i; i++) {
            bytes[i] = binaryString.charCodeAt(i);
        }
        const json = new TextDecoder('utf-8').decode(bytes);
        console.log('[initVariants] decoded JSON:', json);
        const variants = JSON.parse(json);
        console.log('[initVariants] parsed variants:', variants);
        if (Array.isArray(variants) && variants.length > 0) {
            variants.forEach(v => {
                addVariantRow({
                    id: v.Id || v.id || 0,
                    productId: v.ProductId || v.productId || 0,
                    size: v.Size || v.size || '',
                    color: v.Color || v.color || '',
                    packagingUnit: v.PackagingUnit || v.packagingUnit || '',
                    countryOfOrigin: v.CountryOfOrigin || v.countryOfOrigin || '',
                    price: v.Price || v.price || 0,
                    stockQuantity: (v.StockQuantity !== undefined ? v.StockQuantity : (v.stockQuantity !== undefined ? v.stockQuantity : 0)),
                    sku: v.Sku || v.sku || '',
                    imageUrl: v.ImageUrl || v.imageUrl || ''
                });
            });
        } else {
            console.warn('[initVariants] variants array is empty or not array');
        }
    } catch (e) {
        console.error('[initVariants] Error:', e);
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVariants);
} else {
    // DOM already parsed – run immediately but defer to next tick
    // so all other scripts (addVariantRow, reindexVariants) are defined
    setTimeout(initVariants, 0);
}
</script>
