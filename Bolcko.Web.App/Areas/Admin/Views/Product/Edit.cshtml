@model Bolcko.Domain.Entities.Product.DTOs.ProductDto
@{
    ViewData["Title"] = "تعديل المنتج";
}

<section class="p-8 max-w-4xl mx-auto text-right">
    <div class="mb-8">
        <h1 class="font-headline-md text-on-surface">تعديل المنتج</h1>
        <p class="text-on-surface-variant text-sm mt-1">تعديل بيانات المنتج: @Model.Name</p>
    </div>

    <div class="bg-white border border-slate-200 shadow-hard p-8">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <partial name="_ProductForm" model="Model" />
            
            <div class="mt-10 flex gap-4">
                <button type="submit" class="flex-1 bg-[#E8A020] text-white px-8 py-3 font-bold hover:bg-[#d18f1c] transition-all">
                    تحديث المنتج
                </button>
                <a href="@Url.Action("Index")" class="px-8 py-3 font-bold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-all">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
