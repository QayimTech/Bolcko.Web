@model Bolcko.Domain.Entities.Product.DTOs.ProductDto
@{
    ViewData["Title"] = "إضافة منتج جديد";
}

<section class="p-8 max-w-6xl mx-auto text-right">
    <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-slate-100 pb-6">
        <div>
            <h1 class="text-2xl font-black text-slate-800">إضافة منتج جديد</h1>
            <p class="text-slate-400 text-xs mt-1.5 font-bold">أدخل تفاصيل ومواصفات المنتج الجديد في الكتالوج</p>
        </div>
        <a href="@Url.Action("Index")" class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-500 hover:text-slate-800 transition-colors bg-slate-50 border border-slate-100 px-4 py-2.5 rounded-2xl">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            <span>العودة للوحة التحكم</span>
        </a>
    </div>

    <div class="bg-white border border-slate-100 rounded-3xl p-8 shadow-[0_8px_30px_rgba(0,0,0,0.02)]">
        <form asp-action="Create" method="post">
            <partial name="_ProductForm" model="Model" />
            
            <div class="mt-10 flex gap-4 border-t border-slate-100 pt-8 justify-end">
                <a href="@Url.Action("Index")" class="px-8 py-4 font-bold border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-2xl transition-all text-sm active:scale-95">
                    إلغاء العملية
                </a>
                <button type="submit" class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] px-10 py-4 font-black rounded-2xl shadow-[0_8px_25px_rgba(232,160,32,0.15)] transition-all text-sm active:scale-95 flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">save</span>
                    <span>حفظ المنتج الجديد</span>
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

