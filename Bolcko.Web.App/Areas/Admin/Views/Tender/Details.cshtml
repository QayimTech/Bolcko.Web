@using Bolcko.Domain.Enums
@model Bolcko.Domain.Entities.Tender.Tender
@{
    ViewData["Title"] = L["TenderDetails"];
}

<section class="p-8 space-y-8 text-right animate-in fade-in duration-500">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="font-headline-md text-on-surface">@L["TenderDetails"] #RFQ-@Model.Id.ToString("D4")</h1>
            <p class="text-on-surface-variant text-sm mt-1">@Model.TenderTitle</p>
        </div>
        <a href="@Url.Action("Index")" class="text-slate-500 hover:text-primary flex items-center gap-2 font-bold text-sm">
            <span class="material-symbols-outlined text-sm rtl:-scale-x-100">arrow_back</span>
            @L["BackToList"]
        </a>
    </div>

    <!-- Feedback and Message Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-50 border-r-4 border-green-500 p-4 rounded text-green-700 text-sm font-bold shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-r-4 border-red-500 p-4 rounded text-red-700 text-sm font-bold shadow-sm">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="bg-white border border-slate-200 shadow-hard rounded-sm p-6 space-y-6">
        <!-- Customer Info Card -->
        <div class="flex justify-between items-start border-b pb-4">
            <div>
                <h2 class="font-bold text-lg">@L["CustomerInfo"]</h2>
            </div>
            <div>
                <span class="text-xs font-bold uppercase rounded px-2 py-1 @(Model.Status.ToString() switch {
                    "Pending" => "bg-amber-100 text-amber-800 border border-amber-200",
                    "Priced" => "bg-sky-100 text-sky-800 border border-sky-200",
                    "Negotiation" => "bg-purple-100 text-purple-800 border border-purple-200",
                    "Accepted" => "bg-green-100 text-green-800 border border-green-200",
                    "Rejected" => "bg-red-100 text-red-800 border border-red-200",
                    _ => "bg-slate-100 text-slate-800 border border-slate-200"
                })">
                    @(Model.Status.ToString() switch {
                        "Pending" => "قيد الانتظار",
                        "Priced" => "تم التسعير",
                        "Negotiation" => "طلب تفاوض ومفاصلة",
                        "Accepted" => "مقبول ومعتمد",
                        "Rejected" => "مرفوض",
                        _ => Model.Status.ToString()
                    })
                </span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 text-sm">
            <div>
                <span class="text-slate-500 block text-xs uppercase">@L["Customer"]</span>
                <strong>@(Model.User?.UserName ?? Model.GuestName ?? "Guest")</strong>
            </div>
            <div>
                <span class="text-slate-500 block text-xs uppercase">@L["Email"]</span>
                <strong>@(Model.User?.Email ?? Model.GuestEmail ?? "-")</strong>
            </div>
            <div>
                <span class="text-slate-500 block text-xs uppercase">@L["Phone"]</span>
                <strong>@(Model.User?.PhoneNumber ?? Model.GuestPhone ?? "-")</strong>
            </div>
            <div>
                <span class="text-slate-500 block text-xs uppercase">@L["Company"]</span>
                <strong>@(Model.GuestCompany ?? "-")</strong>
            </div>
            <div>
                <span class="text-slate-500 block text-xs uppercase">@L["City"]</span>
                <strong>@(Model.GuestCity ?? "-")</strong>
            </div>
        </div>

        <h2 class="font-bold text-lg border-b pb-2 mt-8">@L["RequestDetails"]</h2>
        <div class="text-sm whitespace-pre-line">
            <p><strong>@L["Notes"]:</strong> @Model.TenderDescription</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.NegotiationNotes))
        {
            <div class="bg-slate-50 border-r-4 border-slate-400 p-4 rounded text-sm mt-4">
                <span class="font-bold block text-slate-700">ملاحظات المفاوضات / أسباب التفاوض من العميل:</span>
                <p class="italic">"@Model.NegotiationNotes"</p>
            </div>
        }

        <!-- Pricing Form for Admin -->
        <h2 class="font-bold text-lg border-b pb-2 mt-8">@L["RequestedItems"]</h2>
        <form asp-area="Admin" asp-controller="Tender" asp-action="SubmitPricing" asp-route-id="@Model.Id" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div class="overflow-x-auto">
                <table class="w-full text-right border-collapse min-w-[500px]">
                    <thead>
                        <tr class="bg-slate-50 border-b">
                            <th class="p-3 text-xs uppercase text-slate-500">@L["ProductName"]</th>
                            <th class="p-3 text-xs uppercase text-slate-500 text-center">@L["Unit"]</th>
                            <th class="p-3 text-xs uppercase text-slate-500 text-center">@L["Quantity"]</th>
                            @if (Model.Status == TenderStatus.Negotiation)
                            {
                                <th class="p-3 text-xs uppercase text-purple-700 text-center">سعر العميل المستهدف (د.أ)</th>
                            }
                            <th class="p-3 text-xs uppercase text-slate-500 text-center">السعر المقترح للوحدة (د.أ)</th>
                            <th class="p-3 text-xs uppercase text-slate-500 text-left">المجموع الفرعي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null)
                        {
                            @foreach (var item in Model.Items)
                            {
                                <tr class="border-b hover:bg-slate-50 transition-colors">
                                    <td class="p-3 align-middle">
                                        @if (item.ProductId.HasValue)
                                        {
                                            <a href="@Url.Action("Index", "Product", new { area = "Shop", id = item.ProductId })" target="_blank" class="flex items-center gap-1.5 text-[#151B26] hover:text-primary font-semibold group">
                                                @item.ProductName
                                                <span class="material-symbols-outlined text-[14px] text-slate-300 group-hover:text-primary transition-colors">open_in_new</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="flex items-center gap-1.5">
                                                <span class="material-symbols-outlined text-[14px] text-slate-400">draw</span>
                                                @item.ProductName
                                            </span>
                                        }
                                    </td>
                                    <td class="p-3 align-middle text-center">@item.Unit</td>
                                    <td class="p-3 align-middle text-center font-bold">@item.RequestedQuantity</td>
                                    @if (Model.Status == TenderStatus.Negotiation)
                                    {
                                        <td class="p-3 align-middle text-center text-purple-700 font-bold">
                                            @(item.TargetPricePerUnit.HasValue ? item.TargetPricePerUnit.Value.ToString("N2") : "-")
                                        </td>
                                    }
                                    <td class="p-3 align-middle text-center">
                                        @if (Model.Status == TenderStatus.Pending || Model.Status == TenderStatus.Priced || Model.Status == TenderStatus.Negotiation)
                                        {
                                            <input type="number" step="0.01" min="0.01" required
                                                   name="itemPrices[@item.Id]" 
                                                   value="@(item.ProposedPricePerUnit.HasValue ? item.ProposedPricePerUnit.Value.ToString("F2") : "")" 
                                                   class="w-32 bg-slate-50 border border-slate-300 p-2 focus:ring-0 focus:border-primary text-center" />
                                        }
                                        else
                                        {
                                            <span class="font-bold">@(item.ProposedPricePerUnit.HasValue ? item.ProposedPricePerUnit.Value.ToString("N2") : "-")</span>
                                        }
                                    </td>
                                    <td class="p-3 align-middle text-left font-bold">
                                        @(item.SubtotalItem.HasValue ? item.SubtotalItem.Value.ToString("N2") + " د.أ" : "-")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex justify-between items-center pt-4">
                <div>
                    @if (Model.TotalQuotedAmount.HasValue)
                    {
                        <span class="text-xs text-slate-500 block">إجمالي القيمة المقدمة</span>
                        <strong class="text-xl text-primary font-black">@Model.TotalQuotedAmount.Value.ToString("N2") د.أ</strong>
                    }
                </div>

                <div class="flex gap-4">
                    @if (Model.Status == TenderStatus.Pending || Model.Status == TenderStatus.Priced || Model.Status == TenderStatus.Negotiation)
                    {
                        <div class="w-80">
                            <input type="text" name="notes" placeholder="ملاحظات لإرسالها للعميل..." class="w-full bg-slate-50 border border-slate-300 p-2 focus:ring-0 focus:border-primary text-right" />
                        </div>
                        <button type="submit" class="bg-primary text-white hover:bg-primary-hover font-bold px-6 py-2 rounded transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">save</span>
                            إرسال الأسعار للعميل
                        </button>
                    }
                    @if (Model.Status != TenderStatus.Accepted && Model.Status != TenderStatus.Rejected)
                    {
                        <button type="button" onclick="openRejectModal()" class="bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-2 rounded transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">cancel</span>
                            رفض الطلب
                        </button>
                    }
                </div>
            </div>
        </form>

        <!-- Reject Modal -->
        <div id="rejectModal" class="fixed inset-0 bg-[#151B26]/60 backdrop-blur-sm z-50 flex items-center justify-center hidden">
            <form asp-area="Admin" asp-controller="Tender" asp-action="Reject" asp-route-id="@Model.Id" method="post" 
                  class="bg-white border border-slate-200 shadow-hard w-full max-w-md p-8 space-y-6 text-right animate-in zoom-in duration-200">
                @Html.AntiForgeryToken()
                <h3 class="font-headline-sm text-on-surface border-b pb-2">رفض العطاء / طلب السعر</h3>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase mb-2">سبب الرفض <span class="text-error">*</span></label>
                    <textarea name="reason" required class="w-full bg-slate-50 border border-slate-300 p-3 focus:ring-0 focus:border-primary text-right h-24" placeholder="يرجى كتابة سبب رفض الطلب للعميل..."></textarea>
                </div>
                <div class="flex justify-end gap-4 border-t pt-4">
                    <button type="button" onclick="closeRejectModal()" class="bg-slate-100 hover:bg-slate-200 text-slate-800 font-bold px-6 py-2 rounded transition-colors">إلغاء</button>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold px-6 py-2 rounded transition-colors">تأكيد الرفض</button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    function openRejectModal() {
        $('#rejectModal').removeClass('hidden');
    }
    function closeRejectModal() {
        $('#rejectModal').addClass('hidden');
    }
</script>
