@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<header class="flex justify-between items-center w-full px-8 h-20 sticky top-0 z-40 bg-white border-b border-slate-200">
    <div class="flex items-center gap-4">
        <h2 class="text-lg font-bold text-slate-800">@ViewData["Title"]</h2>
    </div>
    <div class="flex items-center gap-6">
        <div class="flex items-center gap-3">
            <div class="text-left hidden sm:block">
                <p class="text-xs font-bold text-slate-900">@User.Identity?.Name</p>
                <p class="text-[10px] text-slate-500 uppercase tracking-widest">Super Admin</p>
            </div>
            <div class="w-10 h-10 bg-slate-100 border border-slate-200 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-slate-400">person</span>
            </div>
        </div>
    </div>
</header>