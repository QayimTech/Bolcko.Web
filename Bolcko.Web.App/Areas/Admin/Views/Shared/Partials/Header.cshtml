
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = currentCulture.StartsWith("ar");
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<header class="flex justify-between items-center w-full px-6 h-20 sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-200">
    <!-- Left: Toggle + Page Title -->
    <div class="flex items-center gap-4">
        <button id="sidebar-toggle"
                class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-all text-slate-600 active:scale-95 shadow-sm border border-slate-200"
                aria-label="Toggle Sidebar">
            <span class="material-symbols-outlined">menu_open</span>
        </button>
        <h2 class="text-sm font-bold text-slate-800 uppercase tracking-widest hidden sm:block">@ViewBag.Title</h2>
    </div>

    <!-- Right: Language Switcher + User Info -->
    <div class="flex items-center gap-3">

        <!-- Language Switcher -->
        <div class="relative group">
            <button type="button"
                    class="flex items-center gap-2 px-3 py-2 rounded-xl border border-slate-200 hover:bg-slate-50 transition-all text-sm font-bold text-slate-600 shadow-sm">
                <span class="material-symbols-outlined text-[18px]">language</span>
                <span class="hidden sm:inline">@(isArabic ? "AR" : "EN")</span>
                <span class="material-symbols-outlined text-[16px] text-slate-400">expand_more</span>
            </button>

            <!-- Dropdown -->
            <div class="absolute end-0 top-full mt-2 w-40 bg-white border border-slate-200 rounded-2xl shadow-xl overflow-hidden z-50
                        opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">

                <form asp-area="" asp-controller="Culture" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="culture" value="ar" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit"
                            class="w-full flex items-center gap-3 px-4 py-3 text-sm font-bold transition-colors @(isArabic ? "bg-amber-50 text-[#E8A020]" : "text-slate-700 hover:bg-slate-50")">
                        <span class="text-base">🇸🇦</span>
                        @L["Arabic"]
                        @if (isArabic) { <span class="material-symbols-outlined text-[16px] ms-auto">check</span> }
                    </button>
                </form>

                <div class="border-t border-slate-100"></div>

                <form asp-area="" asp-controller="Culture" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="culture" value="en" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit"
                            class="w-full flex items-center gap-3 px-4 py-3 text-sm font-bold transition-colors @(!isArabic ? "bg-amber-50 text-[#E8A020]" : "text-slate-700 hover:bg-slate-50")">
                        <span class="text-base">🇺🇸</span>
                        @L["English"]
                        @if (!isArabic) { <span class="material-symbols-outlined text-[16px] ms-auto">check</span> }
                    </button>
                </form>
            </div>
        </div>

        <!-- Divider -->
        <div class="h-8 w-px bg-slate-200 hidden sm:block"></div>

        <!-- Notifications Center -->
        <div class="relative" id="notification-center-dropdown">
            <button type="button"
                    class="relative w-10 h-10 flex items-center justify-center rounded-xl hover:bg-slate-100 transition-all text-slate-600 active:scale-95 shadow-sm border border-slate-200"
                    aria-label="Notifications" onclick="toggleNotificationDropdown(event)">
                <span class="material-symbols-outlined">notifications</span>
                <!-- Badge -->
                <span id="notification-badge" class="absolute top-1.5 end-1.5 w-2.5 h-2.5 bg-red-500 rounded-full border border-white hidden"></span>
            </button>

            <!-- Dropdown -->
            <div id="notification-menu" class="absolute end-0 top-full mt-2 w-80 sm:w-96 bg-white border border-slate-200 rounded-2xl shadow-xl overflow-hidden z-50 hidden opacity-0 transition-all duration-200 transform translate-y-1">
                <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                    <h3 class="text-xs font-bold text-slate-800 m-0 uppercase tracking-widest">الإشعارات</h3>
                    <button type="button" class="text-[11px] font-bold text-indigo-600 hover:underline" onclick="markAllNotificationsAsRead()">تحديد الكل كمقروء</button>
                </div>
                <div id="notification-list" class="max-h-80 overflow-y-auto divide-y divide-slate-100 custom-scrollbar">
                    <!-- Notifications will be injected here via JS -->
                </div>
            </div>
        </div>

        <!-- User Info -->
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-center text-[#E8A020] shadow-sm">
                <span class="material-symbols-outlined">person</span>
            </div>
            <div class="text-start hidden sm:block">
                <p class="text-[11px] font-black text-slate-900 leading-none">@User.Identity?.Name</p>
                <p class="text-[9px] text-[#E8A020] font-bold uppercase tracking-tighter mt-1">@L["SystemAdmin"]</p>
            </div>
        </div>
    </div>
</header>