@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<aside class="fixed left-0 top-0 h-full flex flex-col pt-6 pb-4 bg-[#1B2235] dark:bg-slate-950 h-screen w-64 border-r border-white/10 z-50">
    <div class="px-6 mb-8">
        <h1 class="text-white text-lg font-bold tracking-widest uppercase">Project Alpha</h1>
        <p class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest text-[#8A95A8]">Site Foreman</p>
    </div>
    <nav class="flex-1 px-0 overflow-y-auto">
        <div class="flex flex-col">
            <a class="flex items-center px-6 py-4 bg-[#E8A020] text-[#1B2235] rounded-none border-l-4 border-white transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="dashboard">dashboard</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Dashboard</span>
            </a>
            <a class="flex items-center px-6 py-4 text-[#8A95A8] hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="inventory_2">inventory_2</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Orders</span>
            </a>
            <a class="flex items-center px-6 py-4 text-[#8A95A8] hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="gavel">gavel</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Tenders</span>
            </a>
            <a class="flex items-center px-6 py-4 text-[#8A95A8] hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="warehouse">warehouse</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Inventory</span>
            </a>
            <a class="flex items-center px-6 py-4 text-[#8A95A8] hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="local_shipping">local_shipping</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Suppliers</span>
            </a>
            <a class="flex items-center px-6 py-4 text-[#8A95A8] hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined mr-3" data-icon="settings">settings</span>
                <span class="font-['Work_Sans'] text-xs uppercase font-bold tracking-widest">Settings</span>
            </a>
        </div>
    </nav>
    <div class="mt-auto px-6 space-y-4">
        <button class="w-full bg-[#E8A020] text-[#1B2235] font-['Work_Sans'] text-xs font-black py-3 uppercase tracking-widest hover:brightness-110 active:scale-[0.98] transition-all">
            New Tender Request
        </button>
        <div class="pt-4 border-t border-white/5 space-y-2">
            <a class="flex items-center text-[#8A95A8] text-xs font-bold uppercase tracking-widest hover:text-white transition-all" href="#">
                <span class="material-symbols-outlined mr-3 text-sm" data-icon="help">help</span> Support
            </a>
            <a class="flex items-center text-[#8A95A8] text-xs font-bold uppercase tracking-widest hover:text-white transition-all" href="#">
                <span class="material-symbols-outlined mr-3 text-sm" data-icon="logout">logout</span> Log Out
            </a>
        </div>
    </div>
</aside>