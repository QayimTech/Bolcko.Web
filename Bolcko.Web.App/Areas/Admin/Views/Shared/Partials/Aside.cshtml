@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<aside class="fixed right-0 top-0 h-full bg-[#1B2235] w-64 z-[100] transition-transform duration-300 transform lg:translate-x-0 overflow-y-auto border-l border-white/5 text-right">
    <div class="p-8 flex flex-col h-full">
        <div class="mb-10 flex items-center justify-between">
            <div>
                <h1 class="text-white text-xl font-black tracking-tighter uppercase">BLOCKO <span class="text-[#E8A020]">ADMIN</span></h1>
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">مدير النظام</p>
            </div>
        </div>

        <nav class="flex-1 -mx-4 space-y-1">
            <a href="@Url.Action("Index", "Home", new { area = "Admin" })" class="flex items-center gap-4 px-4 py-3 text-white bg-[#E8A020]/10 border-r-4 border-[#E8A020] transition-all group">
                <span class="material-symbols-outlined text-[#E8A020]">dashboard</span>
                <span class="text-xs font-bold uppercase tracking-widest">لوحة التحكم</span>
            </a>
            
            <a href="@Url.Action("Index", "User", new { area = "Admin" })" class="flex items-center gap-4 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
                <span class="material-symbols-outlined group-hover:text-[#E8A020]">manage_accounts</span>
                <span class="text-xs font-bold uppercase tracking-widest">إدارة المستخدمين</span>
            </a>

            <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="flex items-center gap-4 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
                <span class="material-symbols-outlined group-hover:text-[#E8A020]">category</span>
                <span class="text-xs font-bold uppercase tracking-widest">إدارة الفئات</span>
            </a>

            <a href="@Url.Action("Index", "Product", new { area = "Admin" })" class="flex items-center gap-4 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
                <span class="material-symbols-outlined group-hover:text-[#E8A020]">inventory_2</span>
                <span class="text-xs font-bold uppercase tracking-widest">إدارة المنتجات</span>
            </a>

            <a href="#" class="flex items-center gap-4 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
                <span class="material-symbols-outlined group-hover:text-[#E8A020]">gavel</span>
                <span class="text-xs font-bold uppercase tracking-widest">العطاءات</span>
            </a>

            <a href="#" class="flex items-center gap-4 px-4 py-3 text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
                <span class="material-symbols-outlined group-hover:text-[#E8A020]">settings</span>
                <span class="text-xs font-bold uppercase tracking-widest">الإعدادات</span>
            </a>
        </nav>

        <div class="mt-auto pt-6 border-t border-white/5 space-y-4">
            <a href="/" class="flex items-center gap-4 px-4 py-2 text-slate-400 hover:text-white transition-all group">
                <span class="material-symbols-outlined text-sm">home</span>
                <span class="text-[10px] font-bold uppercase tracking-widest">العودة للمتجر</span>
            </a>

            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="w-full flex items-center gap-4 px-4 py-2 text-red-400 hover:text-red-500 transition-all group">
                    <span class="material-symbols-outlined text-sm">logout</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest">تسجيل الخروج</span>
                </button>
            </form>
        </div>
    </div>
</aside>