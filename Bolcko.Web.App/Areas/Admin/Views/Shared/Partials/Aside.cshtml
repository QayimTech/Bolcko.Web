@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<aside id="admin-sidebar" class="fixed right-0 top-0 h-full bg-[#0F172A] z-[100] sidebar-transition transform lg:translate-x-0 translate-x-full overflow-hidden border-l border-white/5 text-right flex flex-col shadow-2xl" style="width: var(--sidebar-width);">
    <!-- Sidebar Header -->
    <div class="h-20 flex items-center justify-between px-6 border-b border-white/5 flex-shrink-0">
        <div class="flex items-center gap-3 overflow-hidden">
            <div class="sidebar-logo-icon hidden">
                <div class="w-10 h-10 bg-gradient-to-br from-[#E8A020] to-[#d18f1c] rounded-xl flex items-center justify-center shadow-lg shadow-[#E8A020]/20">
                    <span class="text-white font-black text-xl">B</span>
                </div>
            </div>
            <div class="sidebar-logo-full whitespace-nowrap">
                <h1 class="text-white text-xl font-black tracking-tighter uppercase flex items-center gap-2">
                    <span class="bg-gradient-to-br from-[#E8A020] to-[#d18f1c] text-white px-2.5 py-1 rounded-lg">B</span>
                    <span class="sidebar-text">BLOCKO <span class="text-[#E8A020]">ADMIN</span></span>
                </h1>
            </div>
        </div>
        <button id="close-sidebar" class="lg:hidden text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto py-6 px-3 space-y-8 custom-scrollbar">
        <div>
            <p class="sidebar-text px-4 text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] mb-4 opacity-50">القائمة الرئيسية</p>
            
            <nav class="space-y-1.5">
                <a href="@Url.Action("Index", "Home", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "" : "group-hover:scale-110") transition-transform">dashboard</span>
                    <span class="sidebar-text text-sm font-bold truncate">لوحة التحكم</span>
                </a>
                
                <a href="@Url.Action("Index", "User", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "" : "group-hover:scale-110") transition-transform">manage_accounts</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة المستخدمين</span>
                </a>

                <a href="@Url.Action("Index", "Category", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "" : "group-hover:scale-110") transition-transform">category</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة الفئات</span>
                </a>

                <a href="@Url.Action("Index", "Product", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "" : "group-hover:scale-110") transition-transform">inventory_2</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة المنتجات</span>
                </a>

                <a href="@Url.Action("Index", "Order", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "" : "group-hover:scale-110") transition-transform">shopping_bag</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة الطلبات</span>
                </a>

                <a href="@Url.Action("Index", "SEO", new { area = "Admin" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "bg-[#E8A020] text-white shadow-xl shadow-[#E8A020]/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "" : "group-hover:scale-110") transition-transform">search_check</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة SEO</span>
                </a>
            </nav>
        </div>
    </div>

    <!-- Sidebar Footer -->
    <div class="p-4 border-t border-white/5 space-y-1 flex-shrink-0">
        <a href="/" class="flex items-center gap-4 px-4 py-3.5 text-slate-400 hover:bg-white/5 hover:text-white rounded-2xl transition-all group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform">home</span>
            <span class="sidebar-text text-sm font-bold truncate">العودة للمتجر</span>
        </a>

        <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="w-full flex items-center gap-4 px-4 py-3.5 text-red-400 hover:bg-red-400/10 rounded-2xl transition-all group">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">logout</span>
                <span class="sidebar-text text-sm font-bold truncate">تسجيل الخروج</span>
            </button>
        </form>
    </div>
</aside>