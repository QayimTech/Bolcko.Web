
<!-- Overlay -->
<div id="sidebar-overlay"
     class="fixed inset-0 bg-slate-900/40 z-[90] hidden opacity-0 transition-opacity duration-300 lg:hidden">
</div>

<!-- Sidebar -->
<aside id="admin-sidebar"
       class="fixed start-0 top-0 h-full bg-white z-[100]
               -translate-x-full rtl:translate-x-full lg:translate-x-0 lg:rtl:translate-x-0
               transition-all duration-300
               overflow-hidden border-e border-slate-200
               text-start flex flex-col shadow-sm"
       style="width: var(--sidebar-width);">

    <!-- Sidebar Header / Logo -->
    <div class="sidebar-header h-20 flex items-center justify-between px-6 border-b border-slate-100 flex-shrink-0 transition-all duration-300">
        <div class="flex items-center gap-3 overflow-hidden">
            <div class="sidebar-logo-icon hidden">
                <partial name="~/Views/Shared/Partials/_BrandLogo.cshtml" model='(true, false, "light", "h-10")' />
            </div>
            <div class="sidebar-logo-full whitespace-nowrap transition-all duration-300">
                <partial name="~/Views/Shared/Partials/_BrandLogo.cshtml" model='(false, true, "light", "h-6 lg:h-9")' />
            </div>
        </div>

        <button id="close-sidebar"
                class="lg:hidden text-slate-400 hover:text-slate-600 transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto py-6 px-3 space-y-6 custom-scrollbar">
        <div>
            <p class="sidebar-text px-4 text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4">
                @L["MainMenu"]
            </p>

            <nav class="space-y-1">
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var currentAction     = ViewContext.RouteData.Values["action"]?.ToString();
                    bool isAdmin = User.IsInRole("Admin");

                    var menuItems = new List<(string Key, string Icon, string Controller, string Action)>
                    {
                        ("Dashboard",          "dashboard",       "Home",     "Index"),
                        ("ManageCategories",   "category",        "Category", "Index"),
                        ("ManageProducts",     "inventory_2",     "Product",  "Index"),
                        ("ManageSEO",          "search_check",    "SEO",      "Index"),
                        ("ManageOrders",       "shopping_bag",    "Order",    "Index"),
                        ("ManageMarketPrices", "payments",        "MarketPrice","Index"),
                    };

                    if (isAdmin)
                        menuItems.Add(("ManageUsers", "manage_accounts", "User", "Index"));
                }

                @foreach (var item in menuItems)
                {
                    bool isActive = currentController == item.Controller && currentAction != "BulkImport";
                    <a href="@Url.Action(item.Action, item.Controller, new { area = "Admin" })"
                       class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all duration-200 group @(isActive ? "bg-slate-900 text-white shadow-lg" : "text-slate-600 hover:bg-slate-50")">

                        <span class="material-symbols-outlined transition-colors @(isActive ? "text-[#E8A020]" : "text-slate-400 group-hover:text-[#E8A020]")">
                            @item.Icon
                        </span>

                        <span class="sidebar-text text-sm font-bold truncate">
                            @L[item.Key]
                        </span>

                        @if (isActive)
                        {
                            <div class="sidebar-text ms-auto w-1.5 h-1.5 rounded-full bg-[#E8A020]"></div>
                        }
                    </a>
                }
            </nav>
        </div>

        @* ===== Import Tools Section ===== *@
        <div>
            <p class="sidebar-text px-4 text-[10px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-4">
                أدوات الاستيراد
            </p>
            <nav class="space-y-1">
                @{
                    bool isImportActive = currentController == "Import" && currentAction == "BulkImport";
                }

                @* Unified Import *@
                <a href="@Url.Action("BulkImport", "Import", new { area = "Admin" })"
                   class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all duration-200 group @(isImportActive ? "bg-slate-900 text-white shadow-lg" : "text-slate-600 hover:bg-slate-50")">

                    <span class="material-symbols-outlined transition-colors @(isImportActive ? "text-[#E8A020]" : "text-slate-400 group-hover:text-[#E8A020]")">
                        upload_file
                    </span>

                    <span class="sidebar-text text-sm font-bold truncate">
                        استيراد الفئات والمنتجات
                    </span>

                    @if (isImportActive)
                    {
                        <div class="sidebar-text ms-auto w-1.5 h-1.5 rounded-full bg-[#E8A020]"></div>
                    }
                </a>

                @* Hangfire Monitor *@
                <a href="/hangfire"
                   target="_blank"
                   class="flex items-center gap-4 px-4 py-3 rounded-xl transition-all duration-200 group text-slate-600 hover:bg-violet-50 hover:text-violet-700">

                    <span class="material-symbols-outlined transition-colors text-slate-400 group-hover:text-violet-600">
                        monitoring
                    </span>

                    <span class="sidebar-text text-sm font-bold truncate">
                        مراقبة المهام
                    </span>
                    <span class="sidebar-text ms-auto">
                        <span class="text-[9px] font-bold bg-violet-100 text-violet-700 px-2 py-0.5 rounded-full">Live</span>
                    </span>
                </a>
            </nav>
        </div>
    </div>



    <!-- Footer -->
    <div class="p-4 border-t border-slate-100 space-y-1 flex-shrink-0">
        <a href="/"
           class="flex items-center gap-4 px-4 py-3 text-slate-500 hover:bg-slate-50 hover:text-slate-900 rounded-xl transition-all group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform">home</span>
            <span class="sidebar-text text-sm font-bold truncate">@L["BackToStore"]</span>
        </a>

        <form asp-area="" asp-controller="Culture" asp-action="SetLanguage" method="post" class="hidden">
        </form>

        <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit"
                    class="w-full flex items-center gap-4 px-4 py-3 text-red-500 hover:bg-red-50 rounded-xl transition-all group text-start">
                <span class="material-symbols-outlined group-hover:rotate-12 transition-transform">logout</span>
                <span class="sidebar-text text-sm font-bold truncate">@L["Logout"]</span>
            </button>
        </form>
    </div>
</aside>