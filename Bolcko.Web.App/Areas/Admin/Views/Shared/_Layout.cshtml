<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - لوحة تحكم Blocko</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <partial name="Partials/_Styles" />
</head>
<body class="bg-[#F8FAFC] text-slate-900 font-body-md min-h-screen overflow-x-hidden">
    <div class="min-h-screen relative flex">
        <!-- Sidebar -->
        <partial name="Partials/Aside" />
        
        <!-- Main Content Area -->
        <div id="main-content" class="flex-1 flex flex-col min-h-screen sidebar-transition">
            <partial name="Partials/Header" />
            
            <main role="main" class="flex-1 p-4 md:p-6 lg:p-10">
                <div class="max-w-[1600px] mx-auto">
                    @RenderBody()
                </div>
            </main>
            
            <partial name="Partials/Footer" />
        </div>

        <!-- Mobile Overlay -->
        <div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/40 z-[90] lg:hidden transition-opacity duration-300 opacity-0 pointer-events-none backdrop-blur-sm"></div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            const body = $('body');
            const sidebar = $('#admin-sidebar');
            const overlay = $('#sidebar-overlay');

            function toggleSidebar() {
                if (window.innerWidth < 1024) {
                    sidebar.toggleClass('translate-x-full');
                    overlay.toggleClass('opacity-0 pointer-events-none');
                    body.toggleClass('overflow-hidden');
                } else {
                    body.toggleClass('sidebar-collapsed');
                    
                    if (body.hasClass('sidebar-collapsed')) {
                        sidebar.css('width', 'var(--sidebar-collapsed-width)');
                        $('.sidebar-text').fadeOut(100);
                        $('.sidebar-logo-full').hide();
                        $('.sidebar-logo-icon').show();
                    } else {
                        sidebar.css('width', 'var(--sidebar-width)');
                        $('.sidebar-text').delay(100).fadeIn(200);
                        $('.sidebar-logo-full').show();
                        $('.sidebar-logo-icon').hide();
                    }
                }
            }

            $('#sidebar-toggle, #close-sidebar, #sidebar-overlay').on('click', toggleSidebar);

            // Handle window resize for UI consistency
            $(window).resize(function() {
                if (window.innerWidth >= 1024) {
                    overlay.addClass('opacity-0 pointer-events-none');
                    body.removeClass('overflow-hidden');
                    sidebar.removeClass('translate-x-full');
                } else {
                    sidebar.addClass('translate-x-full');
                    body.removeClass('sidebar-collapsed');
                    sidebar.css('width', '');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
