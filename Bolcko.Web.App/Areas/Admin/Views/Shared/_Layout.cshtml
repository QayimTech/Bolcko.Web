<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - لوحة تحكم Blocko</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <partial name="Partials/_Styles" />
</head>
<body class="bg-[#F8FAFC] text-slate-900 font-body-md min-h-screen overflow-x-hidden sidebar-expanded">
    <div class="min-h-screen flex relative">
        <partial name="Partials/Aside" />
        
        <!-- Main Content Area -->
        <div id="main-content" class="flex-1 flex flex-col min-h-screen transition-all duration-300 lg:mr-64 mr-0">
            <partial name="Partials/Header" />
            
            <main role="main" class="flex-1 p-4 md:p-6 lg:p-8">
                <div class="animate-in fade-in slide-in-from-bottom-4 duration-500">
                    @RenderBody()
                </div>
            </main>
            
            <partial name="Partials/Footer" />
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            const sidebar = $('#admin-sidebar');
            const mainContent = $('#main-content');
            const overlay = $('#sidebar-overlay');
            const body = $('body');

            function toggleSidebar() {
                const isMobile = window.innerWidth < 1024;
                
                if (isMobile) {
                    sidebar.toggleClass('translate-x-full');
                    overlay.toggleClass('opacity-0 pointer-events-none');
                    body.toggleClass('overflow-hidden');
                } else {
                    // Desktop toggle (Collapse)
                    sidebar.toggleClass('lg:w-64 lg:w-20');
                    mainContent.toggleClass('lg:mr-64 lg:mr-20');
                    $('.sidebar-text').toggleClass('hidden');
                    $('.sidebar-logo-full').toggleClass('hidden');
                    $('.sidebar-logo-icon').toggleClass('hidden');
                }
            }

            $('#sidebar-toggle, #close-sidebar, #sidebar-overlay').on('click', toggleSidebar);

            // Handle window resize
            $(window).resize(function() {
                if (window.innerWidth >= 1024) {
                    overlay.addClass('opacity-0 pointer-events-none');
                    body.removeClass('overflow-hidden');
                    sidebar.removeClass('translate-x-full');
                } else {
                    sidebar.addClass('translate-x-full');
                    sidebar.removeClass('lg:w-20').addClass('lg:w-64');
                    mainContent.removeClass('lg:mr-20').addClass('lg:mr-64');
                    $('.sidebar-text').removeClass('hidden');
                    $('.sidebar-logo-full').removeClass('hidden');
                    $('.sidebar-logo-icon').addClass('hidden');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
