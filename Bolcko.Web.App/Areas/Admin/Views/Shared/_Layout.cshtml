<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - @L["BlockoAdminPanel"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <partial name="Partials/_Styles" />
</head>
<body class="bg-[#F8FAFC] text-slate-900 font-body-md min-h-screen overflow-x-hidden">
    <div class="min-h-screen relative flex">
        <!-- Sidebar -->
        <partial name="Partials/Aside" />
        
        <!-- Main Content Area -->
        <div id="main-content" class="flex-1 flex flex-col min-h-screen sidebar-transition">
            <partial name="Partials/Header" />
            
            <main role="main" class="flex-1 p-4 md:p-6 lg:p-10">
                <div class="max-w-[1600px] mx-auto">
                    @RenderBody()
                </div>
            </main>
            
            <partial name="Partials/Footer" />
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(function () {
            const $body    = $('body');
            const $sidebar = $('#admin-sidebar');
            const $overlay = $('#sidebar-overlay');
            const isRTL    = $('html').attr('dir') === 'rtl';

            // The class that visually hides the sidebar off-screen
            const hideClass = isRTL ? 'translate-x-full' : '-translate-x-full';

            function openSidebar() {
                $sidebar.removeClass(hideClass);
                $overlay.removeClass('hidden');
                setTimeout(() => $overlay.removeClass('opacity-0'), 10);
                $body.addClass('overflow-hidden');
            }

            function closeSidebar() {
                $sidebar.addClass(hideClass);
                $overlay.addClass('opacity-0');
                setTimeout(() => $overlay.addClass('hidden'), 300);
                $body.removeClass('overflow-hidden');
            }

            $('#sidebar-toggle').on('click', function () {
                if (window.innerWidth < 1024) {
                    $sidebar.hasClass(hideClass) ? openSidebar() : closeSidebar();
                } else {
                    $body.toggleClass('sidebar-collapsed');
                    if ($body.hasClass('sidebar-collapsed')) {
                        $sidebar.css('width', 'var(--sidebar-collapsed-width)');
                        $('.sidebar-text, .sidebar-logo-full').hide();
                        $('.sidebar-logo-icon').show();
                    } else {
                        $sidebar.css('width', 'var(--sidebar-width)');
                        $('.sidebar-text, .sidebar-logo-full').show();
                        $('.sidebar-logo-icon').hide();
                    }
                }
            });

            $('#close-sidebar, #sidebar-overlay').on('click', closeSidebar);

            $(window).on('resize', function () {
                if (window.innerWidth >= 1024) {
                    $overlay.addClass('hidden opacity-0');
                    $body.removeClass('overflow-hidden');
                    $sidebar.removeClass(hideClass);
                    $sidebar.css('width', '');
                } else {
                    if (!$sidebar.hasClass(hideClass)) closeSidebar();
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
