<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - BLOCKO Admin</title>
    <link rel="apple-touch-icon" sizes="180x180" href="~/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicons/favicon-16x16.png">
    <link rel="shortcut icon" href="~/favicons/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700;800&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <partial name="Partials/_Styles" />
</head>
<body class="bg-[#F8FAFC] text-slate-900 font-body-md min-h-screen overflow-x-hidden">
    <div class="min-h-screen relative flex">
        <!-- Sidebar -->
        <partial name="Partials/Aside" />
        
        <!-- Main Content Area -->
        <div id="main-content" class="flex-1 flex flex-col min-h-screen sidebar-transition">
            <partial name="Partials/Header" />
            
            <main role="main" class="flex-1 p-4 md:p-6 lg:p-10">
                <div class="max-w-[1600px] mx-auto">
                    @RenderBody()
                </div>
            </main>
            
            <partial name="Partials/Footer" />
        </div>

        <!-- Delete Confirmation Modal -->
        <div id="deleteConfirmModal" class="fixed inset-0 z-[100] flex items-center justify-center hidden">
            <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
            <div class="bg-white rounded-3xl p-8 max-w-md w-full relative z-10 shadow-2xl transform scale-95 opacity-0 transition-all duration-300 mx-4 border border-red-100">
                <div class="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
                    <span class="material-symbols-outlined text-3xl">warning</span>
                </div>
                <h3 class="text-xl font-bold text-slate-800 text-center mb-2">تأكيد الحذف</h3>
                <p id="deleteModalMessage" class="text-slate-500 text-sm text-center mb-6 leading-relaxed">
                    هل أنت متأكد من الحذف؟ لا يمكن التراجع عن هذا الإجراء.
                </p>
                <div class="mb-6">
                    <label class="block text-xs font-bold text-slate-700 mb-2 text-start">للتأكيد، اكتب "<span class="text-red-600">حذف</span>" أو "<span class="text-red-600">delete</span>" في الصندوق أدناه:</label>
                    <input type="text" id="deleteConfirmInput" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-900 focus:border-red-500 focus:ring-1 focus:ring-red-500 outline-none text-center" autocomplete="off" />
                </div>
                <div class="flex flex-row-reverse gap-3">
                    <button type="button" onclick="closeDeleteModal()" class="w-1/2 px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-xl transition-colors">
                        إلغاء
                    </button>
                    <button type="button" id="deleteConfirmBtn" class="w-1/2 px-6 py-3 bg-slate-200 text-slate-400 font-bold rounded-xl transition-colors cursor-not-allowed" data-enabled="false">
                        تأكيد الحذف
                    </button>
                </div>
            </div>
        </div>

        <!-- Toast Notifications -->
        <div id="toast-container" class="fixed bottom-6 start-6 z-[100] flex flex-col gap-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-6 py-4 rounded-2xl shadow-lg flex items-center gap-3 animate-slide-up-fade">
                    <span class="material-symbols-outlined text-emerald-600">check_circle</span>
                    <span class="font-bold text-sm">@TempData["SuccessMessage"]</span>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="bg-rose-50 border border-rose-200 text-rose-800 px-6 py-4 rounded-2xl shadow-lg flex items-center gap-3 animate-slide-up-fade">
                    <span class="material-symbols-outlined text-rose-600">error</span>
                    <span class="font-bold text-sm">@TempData["ErrorMessage"]</span>
                </div>
            }
        </div>

    </div>

    <style>
        .animate-slide-up-fade {
            animation: slideUpFade 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @@keyframes slideUpFade {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        /* Explicit styles to prevent Tailwind JIT purging issues */
        .btn-delete-disabled {
            background-color: #e2e8f0 !important;
            color: #94a3b8 !important;
            cursor: not-allowed !important;
        }
        .btn-delete-enabled {
            background-color: #dc2626 !important;
            color: #ffffff !important;
            cursor: pointer !important;
        }
        .btn-delete-enabled:hover {
            background-color: #b91c1c !important;
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(function () {
            // Sidebar logic
            const $body    = $('body');
            const $sidebar = $('#admin-sidebar');
            const $overlay = $('#sidebar-overlay');
            const hideClasses = '-translate-x-full rtl:translate-x-full';

            function openSidebar() {
                $sidebar.removeClass(hideClasses);
                $overlay.removeClass('hidden');
                setTimeout(() => $overlay.removeClass('opacity-0'), 10);
                $body.addClass('overflow-hidden');
            }
            function closeSidebar() {
                $sidebar.addClass(hideClasses);
                $overlay.addClass('opacity-0');
                setTimeout(() => $overlay.addClass('hidden'), 300);
                $body.removeClass('overflow-hidden');
            }
            $('#sidebar-toggle').on('click', function () {
                if (window.innerWidth < 1024) {
                    $sidebar.hasClass('-translate-x-full') ? openSidebar() : closeSidebar();
                } else {
                    $body.toggleClass('sidebar-collapsed');
                }
            });
            $('#close-sidebar, #sidebar-overlay').on('click', closeSidebar);
            $(window).on('resize', function () {
                if (window.innerWidth >= 1024) {
                    $overlay.addClass('hidden opacity-0');
                    $body.removeClass('overflow-hidden');
                    $sidebar.removeClass(hideClasses);
                } else {
                    if (!$sidebar.hasClass('-translate-x-full')) closeSidebar();
                }
            });

            // Toast Auto-hide
            setTimeout(function() {
                $('#toast-container > div').fadeOut(500, function() { $(this).remove(); });
            }, 6000);
        });

        // Delete Modal Logic
        let currentDeleteForm = null;

        function requireDeleteConfirm(form, typeMsg) {
            currentDeleteForm = form;
            const modal = document.getElementById('deleteConfirmModal');
            const msgEl = document.getElementById('deleteModalMessage');
            const input = document.getElementById('deleteConfirmInput');
            const btn = document.getElementById('deleteConfirmBtn');
            
            if(typeMsg === 'category') {
                msgEl.textContent = "هل أنت متأكد من الحذف؟ سيتم حذف جميع المنتجات أو الفئات الفرعية التي تنتمي إلى هذه الفئة بشكل نهائي!";
            } else {
                msgEl.textContent = "هل أنت متأكد من الحذف؟ لا يمكن التراجع عن هذا الإجراء.";
            }

            input.value = '';
            btn.dataset.enabled = 'false';
            btn.className = 'w-1/2 px-6 py-3 font-bold rounded-xl transition-colors btn-delete-disabled';

            modal.classList.remove('hidden');
            // small delay for transition
            setTimeout(() => {
                modal.querySelector('.bg-white').classList.remove('scale-95', 'opacity-0');
                modal.querySelector('.bg-white').classList.add('scale-100', 'opacity-100');
                input.focus();
            }, 10);
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteConfirmModal');
            modal.querySelector('.bg-white').classList.remove('scale-100', 'opacity-100');
            modal.querySelector('.bg-white').classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
                currentDeleteForm = null;
            }, 300);
        }

        document.getElementById('deleteConfirmInput').addEventListener('input', function(e) {
            const val = e.target.value.trim().toLowerCase();
            const btn = document.getElementById('deleteConfirmBtn');
            if(val === 'حذف' || val === 'delete') {
                btn.dataset.enabled = 'true';
                btn.className = 'w-1/2 px-6 py-3 font-bold rounded-xl transition-colors btn-delete-enabled';
            } else {
                btn.dataset.enabled = 'false';
                btn.className = 'w-1/2 px-6 py-3 font-bold rounded-xl transition-colors btn-delete-disabled';
            }
        });

        document.getElementById('deleteConfirmInput').addEventListener('keydown', function(e) {
            if(e.key === 'Enter') {
                e.preventDefault();
                const btn = document.getElementById('deleteConfirmBtn');
                if(btn.dataset.enabled === 'true') {
                    btn.click();
                }
            }
        });

        document.getElementById('deleteConfirmBtn').addEventListener('click', function() {
            if(currentDeleteForm && this.dataset.enabled === 'true') {
                currentDeleteForm.submit();
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
