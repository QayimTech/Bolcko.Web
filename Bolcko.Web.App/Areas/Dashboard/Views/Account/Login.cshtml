@{
    ViewData["Title"] = "دخول البائعين";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blocko Dashboard</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Kufi Arabic', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full bg-white shadow-xl border border-slate-200 p-10">
        <div class="text-center mb-10">
            <div class="inline-block bg-primary text-white px-4 py-1 text-[10px] font-black uppercase tracking-[0.2em] mb-4">Seller Portal</div>
            <h1 class="text-3xl font-black tracking-tighter text-[#1B2235] uppercase mb-2">BLOCKO <span class="text-primary">DASHBOARD</span></h1>
            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest">إدارة المنتجات والمبيعات</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border-r-4 border-red-500 text-red-700 p-4 mb-6 text-xs font-bold text-right">
                @ViewBag.Error
            </div>
        }

        <form asp-area="Dashboard" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6 text-right">
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-widest mb-2">البريد الإلكتروني</label>
                <input type="email" name="email" required class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-1 focus:ring-primary outline-none transition-all text-right" placeholder="user@blocko.com" />
            </div>
            <div>
                <label class="block text-[10px] font-black text-[#1B2235] uppercase tracking-widest mb-2">كلمة المرور</label>
                <input type="password" name="password" required class="w-full bg-slate-50 border border-slate-200 p-4 focus:ring-1 focus:ring-primary outline-none transition-all text-right" placeholder="********" />
            </div>

            <button type="submit" class="w-full bg-on-surface text-white font-bold py-4 uppercase tracking-widest hover:bg-primary transition-all duration-300">
                دخول للوحة التحكم
            </button>
        </form>

        <div class="mt-10 text-center">
            <a href="/" class="text-[10px] font-bold text-slate-400 hover:text-primary uppercase tracking-widest transition-colors">العودة للمتجر</a>
        </div>
    </div>
</body>
</html>
