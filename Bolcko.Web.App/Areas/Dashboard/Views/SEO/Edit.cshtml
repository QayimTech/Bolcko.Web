@model Bolcko.Domain.Entities.SEO.DTOs.SEOMetadataDto
@{
    ViewData["Title"] = "تعديل بيانات SEO";
}

<section class="p-8 max-w-4xl mx-auto text-right animate-in slide-in-from-bottom duration-500">
    <div class="mb-8">
        <h1 class="font-headline-md text-on-surface">تعديل بيانات SEO لصفحة: @Model.PageName</h1>
        <p class="text-on-surface-variant text-sm mt-1">قم بتحديث الكلمات المفتاحية والوصف لتحسين ظهورك</p>
    </div>

    <div class="bg-white border border-slate-200 shadow-hard p-8 rounded-sm">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PageName" />
            
            <div class="space-y-6">
                <div>
                    <label asp-for="PageTitle" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">عنوان الصفحة (Page Title)</label>
                    <input asp-for="PageTitle" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
                </div>

                <div>
                    <label asp-for="MetaDescription" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">وصف الصفحة (Meta Description)</label>
                    <textarea asp-for="MetaDescription" rows="4" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"></textarea>
                </div>

                <div>
                    <label asp-for="MetaKeywords" class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">الكلمات المفتاحية (Meta Keywords)</label>
                    <input asp-for="MetaKeywords" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 text-slate-900 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" />
                </div>
            </div>
            
            <div class="mt-10 flex gap-4">
                <button type="submit" class="flex-1 bg-primary text-white px-8 py-3 font-bold hover:opacity-90 transition-all shadow-hard">
                    تحديث البيانات
                </button>
                <a href="@Url.Action("Index")" class="px-8 py-3 font-bold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-all">
                    إلغاء
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
