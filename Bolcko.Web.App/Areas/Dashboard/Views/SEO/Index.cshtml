@model IEnumerable<Bolcko.Domain.Entities.SEO.DTOs.SEOMetadataDto>
@{
    ViewData["Title"] = "إدارة SEO لمتجري";
}

<section class="p-8 space-y-8 text-right animate-in fade-in duration-500">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="font-headline-md text-on-surface">إدارة SEO لمتجري</h1>
            <p class="text-on-surface-variant text-sm mt-1">تخصيص ظهور صفحاتك في محركات البحث</p>
        </div>
    </div>

    <div class="bg-white border border-slate-200 shadow-hard overflow-hidden rounded-sm transition-all hover:shadow-lg">
        <table class="w-full text-right border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">الصفحة</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">العنوان (Title)</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-widest">الإجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors group">
                        <td class="px-6 py-4 font-bold text-slate-900">@item.PageName</td>
                        <td class="px-6 py-4 text-slate-600">@item.PageTitle</td>
                        <td class="px-6 py-4">
                            <a href="@Url.Action("Edit", new { id = item.Id })" class="text-primary font-bold hover:underline">
                                تعديل البيانات
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="px-6 py-12 text-center text-slate-400 italic">
                            لا توجد صفحات مخصصة لك حالياً
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
