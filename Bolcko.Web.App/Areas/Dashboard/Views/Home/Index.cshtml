@{
    ViewData["Title"] = "لوحة التحكم";
}

<section class="p-8 space-y-8 flex-1 text-right">
    <!-- Dashboard Header Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">المنتجات النشطة</p>
            <h3 class="font-headline-md text-on-surface">@ViewBag.ProductCount</h3>
            <div class="flex items-center mt-4 text-emerald-600 text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">inventory</span> متاح للبيع
            </div>
        </div>
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">الفئات المسجلة</p>
            <h3 class="font-headline-md text-on-surface">@ViewBag.CategoryCount</h3>
            <div class="flex items-center mt-4 text-amber-600 text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">category</span> فئات رئيسية
            </div>
        </div>
        <div class="bg-white p-6 border border-slate-200 shadow-hard">
            <p class="text-xs font-bold text-[#8A95A8] uppercase tracking-widest mb-1">طلبات البيع</p>
            <h3 class="font-headline-md text-on-surface">0</h3>
            <div class="flex items-center mt-4 text-on-surface-variant text-xs font-bold">
                <span class="material-symbols-outlined text-sm ml-1">shopping_cart</span> مبيعات التجزئة
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white border border-slate-200 p-8 shadow-hard">
        <h2 class="text-[#1B2235] font-bold text-sm uppercase tracking-widest mb-6">إجراءات سريعة</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <a href="@Url.Action("Create", "Product", new { area = "Dashboard" })" class="flex flex-col items-center justify-center p-6 border border-slate-100 hover:bg-slate-50 transition-all group">
                <span class="material-symbols-outlined text-3xl text-primary mb-2 group-hover:scale-110 transition-transform">add_box</span>
                <span class="text-xs font-bold text-[#1B2235]">إضافة منتج</span>
            </a>
            <a href="@Url.Action("Index", "Product", new { area = "Dashboard" })" class="flex flex-col items-center justify-center p-6 border border-slate-100 hover:bg-slate-50 transition-all group">
                <span class="material-symbols-outlined text-3xl text-primary mb-2 group-hover:scale-110 transition-transform">list_alt</span>
                <span class="text-xs font-bold text-[#1B2235]">قائمة المنتجات</span>
            </a>
            <a href="@Url.Action("Index", "Tender", new { area = "Dashboard" })" class="flex flex-col items-center justify-center p-6 border border-slate-100 hover:bg-slate-50 transition-all group">
                <span class="material-symbols-outlined text-3xl text-primary mb-2 group-hover:scale-110 transition-transform">gavel</span>
                <span class="text-xs font-bold text-[#1B2235]">العطاءات</span>
            </a>
            <a href="#" class="flex flex-col items-center justify-center p-6 border border-slate-100 hover:bg-slate-50 transition-all group">
                <span class="material-symbols-outlined text-3xl text-primary mb-2 group-hover:scale-110 transition-transform">person</span>
                <span class="text-xs font-bold text-[#1B2235]">الملف الشخصي</span>
            </a>
        </div>
    </div>
</section>
