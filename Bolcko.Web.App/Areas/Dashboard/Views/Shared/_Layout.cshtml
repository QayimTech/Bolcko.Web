<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.Name" dir="@(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - لوحة البائع Blocko</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <partial name="Partials/_Styles" />
</head>
<body class="bg-slate-50 text-slate-900 font-body-md min-h-screen overflow-x-hidden">
    <div class="min-h-screen flex">
        <partial name="Partials/Aside" />
        
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col min-h-screen transition-all duration-300 lg:pr-64">
            <partial name="Partials/Header" />
            
            <main role="main" class="flex-1 p-4 md:p-8">
                @RenderBody()
            </main>
            
            <partial name="Partials/Footer" />
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() {
            // Mobile sidebar toggle
            $('#sidebar-toggle').on('click', function() {
                $('#dashboard-sidebar').toggleClass('translate-x-full');
            });
            
            // Close sidebar on overlay click
            $('#sidebar-overlay').on('click', function() {
                $('#dashboard-sidebar').addClass('translate-x-full');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
