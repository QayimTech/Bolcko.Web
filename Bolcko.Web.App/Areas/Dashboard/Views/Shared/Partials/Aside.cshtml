@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!-- Mobile Overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/40 z-[90] lg:hidden transition-opacity duration-300 opacity-0 pointer-events-none backdrop-blur-sm"></div>

<aside id="dashboard-sidebar" class="fixed right-0 top-0 h-full bg-[#111827] w-64 z-[100] transition-all duration-300 transform lg:translate-x-0 translate-x-full overflow-hidden border-l border-white/5 text-right flex flex-col shadow-2xl">
    <!-- Sidebar Header -->
    <div class="h-20 flex items-center justify-between px-6 border-b border-white/5 flex-shrink-0">
        <div class="flex items-center gap-3">
            <div class="sidebar-logo-icon hidden">
                <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
                    <span class="text-white font-black text-xl">B</span>
                </div>
            </div>
            <div class="sidebar-logo-full">
                <h1 class="text-white text-xl font-black tracking-tighter uppercase flex items-center gap-2">
                    <span class="bg-primary text-white px-2 py-0.5 rounded">B</span>
                    BLOCKO <span class="text-primary">DASHBOARD</span>
                </h1>
            </div>
        </div>
        <button id="close-sidebar-dash" class="lg:hidden text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto py-6 px-4 space-y-2 custom-scrollbar">
        <p class="sidebar-text px-2 text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] mb-4">لوحة البائع</p>
        
        <nav class="space-y-1">
            <a href="@Url.Action("Index", "Home", new { area = "Dashboard" })" 
               class="flex items-center gap-4 px-3 py-3 rounded-xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "" : "group-hover:scale-110") transition-transform">dashboard</span>
                <span class="sidebar-text text-sm font-bold truncate">لوحة التحكم</span>
            </a>
            
            <a href="@Url.Action("Index", "Product", new { area = "Dashboard" })" 
               class="flex items-center gap-4 px-3 py-3 rounded-xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "" : "group-hover:scale-110") transition-transform">inventory_2</span>
                <span class="sidebar-text text-sm font-bold truncate">إدارة المنتجات</span>
            </a>

            <a href="@Url.Action("Index", "Tender", new { area = "Dashboard" })" 
               class="flex items-center gap-4 px-3 py-3 rounded-xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tender" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tender" ? "" : "group-hover:scale-110") transition-transform">gavel</span>
                <span class="sidebar-text text-sm font-bold truncate">العطاءات</span>
            </a>

            <a href="@Url.Action("Index", "SEO", new { area = "Dashboard" })" 
               class="flex items-center gap-4 px-3 py-3 rounded-xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "bg-primary text-white shadow-lg shadow-primary/20" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "" : "group-hover:scale-110") transition-transform">search_check</span>
                <span class="sidebar-text text-sm font-bold truncate">إدارة SEO</span>
            </a>

            <a href="#" class="flex items-center gap-4 px-3 py-3 rounded-xl transition-all duration-200 group text-slate-400 hover:bg-white/5 hover:text-white">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">analytics</span>
                <span class="sidebar-text text-sm font-bold truncate">الإحصائيات</span>
            </a>
        </nav>
    </div>

    <!-- Sidebar Footer -->
    <div class="p-4 border-t border-white/5 space-y-1">
        <a href="/" class="flex items-center gap-4 px-3 py-3 text-slate-400 hover:bg-white/5 hover:text-white rounded-xl transition-all group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform">home</span>
            <span class="sidebar-text text-sm font-bold truncate">العودة للمتجر</span>
        </a>

        <form asp-area="Dashboard" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="w-full flex items-center gap-4 px-3 py-3 text-red-400 hover:bg-red-400/10 rounded-xl transition-all group">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">logout</span>
                <span class="sidebar-text text-sm font-bold truncate">تسجيل الخروج</span>
            </button>
        </form>
    </div>
</aside>
