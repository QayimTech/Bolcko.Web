@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<aside id="dashboard-sidebar" class="fixed right-0 top-0 h-full bg-[#0F172A] z-[100] sidebar-transition transform lg:translate-x-0 translate-x-full overflow-hidden border-l border-white/5 text-right flex flex-col shadow-2xl" style="width: var(--sidebar-width);">
    <!-- Sidebar Header -->
    <div class="h-20 flex items-center justify-between px-6 border-b border-white/5 flex-shrink-0">
        <div class="flex items-center gap-3 overflow-hidden">
            <div class="sidebar-logo-icon hidden">
                <div class="w-10 h-10 bg-gradient-to-br from-primary to-primary/80 rounded-xl flex items-center justify-center shadow-lg shadow-primary/20">
                    <span class="text-white font-black text-xl">B</span>
                </div>
            </div>
            <div class="sidebar-logo-full whitespace-nowrap">
                <h1 class="text-white text-xl font-black tracking-tighter uppercase flex items-center gap-2">
                    <span class="bg-gradient-to-br from-primary to-primary/80 text-white px-2.5 py-1 rounded-lg">B</span>
                    <span class="sidebar-text">BLOCKO <span class="text-primary">DASHBOARD</span></span>
                </h1>
            </div>
        </div>
        <button id="close-sidebar-dash" class="lg:hidden text-slate-400 hover:text-white transition-colors">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto py-6 px-3 space-y-8 custom-scrollbar">
        <div>
            <p class="sidebar-text px-4 text-[10px] font-bold text-slate-500 uppercase tracking-[0.2em] mb-4 opacity-50">لوحة البائع</p>
            
            <nav class="space-y-1.5">
                <a href="@Url.Action("Index", "Home", new { area = "Dashboard" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-primary text-white shadow-xl shadow-primary/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "" : "group-hover:scale-110") transition-transform">dashboard</span>
                    <span class="sidebar-text text-sm font-bold truncate">لوحة التحكم</span>
                </a>
                
                <a href="@Url.Action("Index", "Product", new { area = "Dashboard" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "bg-primary text-white shadow-xl shadow-primary/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "" : "group-hover:scale-110") transition-transform">inventory_2</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة المنتجات</span>
                </a>

                <a href="@Url.Action("Index", "Tender", new { area = "Dashboard" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tender" ? "bg-primary text-white shadow-xl shadow-primary/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tender" ? "" : "group-hover:scale-110") transition-transform">gavel</span>
                    <span class="sidebar-text text-sm font-bold truncate">العطاءات</span>
                </a>

                <a href="@Url.Action("Index", "SEO", new { area = "Dashboard" })" 
                   class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "bg-primary text-white shadow-xl shadow-primary/30" : "text-slate-400 hover:bg-white/5 hover:text-white")">
                    <span class="material-symbols-outlined @(ViewContext.RouteData.Values["controller"]?.ToString() == "SEO" ? "" : "group-hover:scale-110") transition-transform">search_check</span>
                    <span class="sidebar-text text-sm font-bold truncate">إدارة SEO</span>
                </a>

                <a href="#" class="flex items-center gap-4 px-4 py-3.5 rounded-2xl transition-all duration-200 group text-slate-400 hover:bg-white/5 hover:text-white">
                    <span class="material-symbols-outlined group-hover:scale-110 transition-transform">analytics</span>
                    <span class="sidebar-text text-sm font-bold truncate">الإحصائيات</span>
                </a>
            </nav>
        </div>
    </div>

    <!-- Sidebar Footer -->
    <div class="p-4 border-t border-white/5 space-y-1 flex-shrink-0">
        <a href="/" class="flex items-center gap-4 px-4 py-3.5 text-slate-400 hover:bg-white/5 hover:text-white rounded-2xl transition-all group">
            <span class="material-symbols-outlined group-hover:scale-110 transition-transform">home</span>
            <span class="sidebar-text text-sm font-bold truncate">العودة للمتجر</span>
        </a>

        <form asp-area="Dashboard" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="w-full flex items-center gap-4 px-4 py-3.5 text-red-400 hover:bg-red-400/10 rounded-2xl transition-all group">
                <span class="material-symbols-outlined group-hover:scale-110 transition-transform">logout</span>
                <span class="sidebar-text text-sm font-bold truncate">تسجيل الخروج</span>
            </button>
        </form>
    </div>
</aside>
