@model Bolcko.Domain.Entities.Product.DTOs.ProductDto

<div class="bg-white border border-slate-100 rounded-3xl p-5 flex flex-col shadow-[0_4px_20px_rgba(0,0,0,0.02)] group text-right h-full transition-all duration-300 hover:border-[#E8A020]/30 hover:shadow-[0_12px_30px_rgba(232,160,32,0.05)] hover:-translate-y-1.5 relative">
    
    <!-- Image Gallery Wrapper -->
    <div onclick="location.href='@Url.Action("Index", "Product", new { area = "Shop", id = Model.Id })'" 
         class="aspect-[4/3] bg-slate-50 relative overflow-hidden rounded-2xl cursor-pointer">
        
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                 src="@(Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : "/" + Model.ImageUrl.TrimStart('/'))"
                 onerror="this.src='https://placehold.co/600x400/f8fafc/475569?text=@(Uri.EscapeDataString(Model.Name))'"
                 alt="@Model.Name" />
        }
        else
        {
            <div class="w-full h-full flex flex-col items-center justify-center bg-slate-50">
                <span class="material-symbols-outlined text-4xl text-slate-300">image</span>
            </div>
        }
        
        <!-- Floating SKU badge -->
        <span class="absolute top-3 right-3 bg-[#151B26] text-white/95 font-bold px-2.5 py-1 rounded-xl text-[9px] uppercase tracking-wider shadow-sm">
            SKU: @Model.Sku
        </span>
    </div>

    <!-- Product Text Content -->
    <div class="pt-4 flex flex-col flex-1">
        <!-- Category Tag -->
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <span class="text-[10px] font-bold text-[#E8A020] uppercase tracking-widest mb-1">@Model.CategoryName</span>
        }
        
        <!-- Product Title -->
        <h5 class="font-bold text-base text-slate-800 cursor-pointer hover:text-[#E8A020] transition-colors line-clamp-1 mb-2"
            onclick="location.href='@Url.Action("Index", "Product", new { area = "Shop", id = Model.Id })'">
            @Model.Name
        </h5>
        
        <!-- Description -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed mb-4">@Model.Description</p>
        }
        
        <!-- Bottom Pricing and Add to Cart Section -->
        <div class="mt-auto">
            <div class="flex justify-between items-center border-t border-slate-50 pt-4 mb-4">
                <span class="font-bold text-lg text-slate-900">
                    @Model.RetailPrice.ToString("N2") <span class="text-[10px] font-medium text-slate-400">د.أ</span>
                </span>
                
                <!-- Glowing Stock Indicator -->
                <div class="flex items-center gap-1.5">
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        <span class="text-[10px] font-bold text-emerald-600">@SharedLocalizer["ItemInStock"]</span>
                    }
                    else
                    {
                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                        <span class="text-[10px] font-bold text-rose-500">@SharedLocalizer["ItemOutOfStock"]</span>
                    }
                </div>
            </div>
            
            <!-- Add to Cart Form -->
            <form asp-action="AddToCart" asp-controller="ShoppingCart" asp-area="Shop" method="post" class="space-y-2">
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="quantity" value="1" />
                <div class="flex gap-2">
                    <button type="submit" 
                            class="w-full bg-[#151B26] hover:bg-[#E8A020] text-white hover:text-[#151B26] font-bold py-3 rounded-xl flex items-center justify-center gap-2 transition-all duration-300 shadow-sm active:scale-95">
                        <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                        <span class="text-xs tracking-wider">@SharedLocalizer["AddToCart"]</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
