@using Microsoft.Extensions.Options
@using Microsoft.Extensions.Localization
@using Bolcko.Web.App
@inject IOptions<Bolcko.Web.App.Models.MarketSettings> MarketSettings
@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    var uow = (Bolcko.Domain.Interfaces.IUnitOfWork)Context.RequestServices.GetService(typeof(Bolcko.Domain.Interfaces.IUnitOfWork))!;
    var dbCityAr = await uow.AppSettings.GetByKeyAsync("MarketCityAr");
    var dbCityEn = await uow.AppSettings.GetByKeyAsync("MarketCityEn");
    var dbCountryAr = await uow.AppSettings.GetByKeyAsync("MarketCountryAr");
    var dbCountryEn = await uow.AppSettings.GetByKeyAsync("MarketCountryEn");
    var dbIsOnlineOnly = await uow.AppSettings.GetByKeyAsync("MarketIsOnlineOnly");
    var dbCurrencyAr = await uow.AppSettings.GetByKeyAsync("MarketCurrencyAr");
    var dbCurrencyEn = await uow.AppSettings.GetByKeyAsync("MarketCurrencyEn");

    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    
    var city = isAr ? (dbCityAr?.Value ?? "عمان") : (dbCityEn?.Value ?? "Amman");
    var country = isAr ? (dbCountryAr?.Value ?? "الأردن") : (dbCountryEn?.Value ?? "Jordan");
    var currency = isAr ? (dbCurrencyAr?.Value ?? "دينار أردني") : (dbCurrencyEn?.Value ?? "JOD");
    var isOnline = (dbIsOnlineOnly?.Value ?? "true") == "true";
}

<footer class="bg-[#0D111A] text-white border-t border-white/5 relative z-10 font-body-md">
    
    <!-- ========================================== -->
    <!-- 1. DESKTOP ONLY FOOTER: Restore original look -->
    <!-- ========================================== -->
    <div class="hidden lg:flex w-full py-16 px-6 justify-between items-start max-w-7xl mx-auto gap-12 text-start">
        <div class="max-w-md w-full flex flex-col gap-6">
            <a href="/" class="inline-block hover:opacity-90 transition-opacity">
                <partial name="~/Views/Shared/Partials/_BrandLogo.cshtml" model='(false, false, "dark", "h-10")' />
            </a>
            <p class="text-slate-400 text-sm leading-relaxed max-w-sm">
                @SharedLocalizer["FooterAbout"]
            </p>
            <div class="flex gap-4">
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-xl">share</span>
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-xl">language</span>
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-xl">mail</span>
            </div>
        </div>
        <div class="w-full grid grid-cols-3 gap-12 max-w-3xl">
            <div class="flex flex-col gap-4">
                <h5 class="text-[#E8A020] font-bold text-sm tracking-widest uppercase">@SharedLocalizer["Navigation"]</h5>
                <nav class="flex flex-col gap-3 text-sm">
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("AboutUs","Home", new { area = "Shop" })">@SharedLocalizer["AboutUs"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Contact", "Home", new { area = "Shop" })">@SharedLocalizer["ContactUs"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Privacy", "Legal", new { area = "Shop" })">@SharedLocalizer["PrivacyPolicy"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Terms", "Legal", new { area = "Shop" })">@SharedLocalizer["TermsOfService"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Support", "Legal", new { area = "Shop" })">@SharedLocalizer["TechnicalSupport"]</a>
                </nav>
            </div>
            <div class="flex flex-col gap-4">
                <h5 class="text-[#E8A020] font-bold text-sm tracking-widest uppercase">@SharedLocalizer["Commercial"]</h5>
                <nav class="flex flex-col gap-3 text-sm">
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Contact", "Home", new { area = "Shop" })">@SharedLocalizer["ShippingInfo"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Request", "Quote", new { area = "Shop" })">@SharedLocalizer["WholesaleOrders"]</a>
                    <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Login", "Account", new { area = "Shop" })">@SharedLocalizer["PartnerLogin"]</a>
                </nav>
            </div>
            <div class="flex flex-col gap-4">
                <h5 class="text-[#E8A020] font-bold text-sm tracking-widest uppercase">@SharedLocalizer["MarketInfo"]</h5>
                <div class="text-slate-400 text-sm leading-relaxed flex flex-col gap-3">
                    <p class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-sm text-[#E8A020]">public</span>
                        <span>@city، @country</span>
                    </p>
                    <p class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-sm text-[#E8A020]">storefront</span>
                        <span>@(isOnline ? SharedLocalizer["OnlineOnly"] : SharedLocalizer["ShowroomsWarehouses"])</span>
                    </p>
                    <p class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-sm text-[#E8A020]">payments</span>
                        <span>@SharedLocalizer["ApprovedCurrency"]: @currency</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- ========================================== -->
    <!-- 2. MOBILE ONLY FOOTER: Elegant mobile grid -->
    <!-- ========================================== -->
    <div class="lg:hidden w-full py-12 px-6 flex flex-col justify-between items-stretch gap-10">
        
        <!-- Mobile Brand Section -->
        <div class="w-full flex flex-col items-start gap-4 pb-6 border-b border-white/5">
            <a href="/" class="inline-block hover:opacity-90 transition-opacity">
                <partial name="~/Views/Shared/Partials/_BrandLogo.cshtml" model='(false, false, "dark", "h-9")' />
            </a>
            <p class="text-slate-400 text-xs leading-relaxed max-w-xs">
                @SharedLocalizer["FooterAbout"]
            </p>
            <div class="flex gap-4 mt-2">
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-lg">share</span>
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-lg">language</span>
                <span class="material-symbols-outlined text-slate-400 hover:text-[#E8A020] cursor-pointer transition-colors text-lg">mail</span>
            </div>
        </div>
        
        <!-- Mobile Columns System -->
        <div class="w-full flex flex-col gap-8 text-start">
            
            <!-- Mobile Links Side-by-Side (RTL Safe) -->
            <div class="grid grid-cols-2 gap-6 w-full">
                <!-- Navigation -->
                <div class="flex flex-col gap-3">
                    <h5 class="text-[#E8A020] font-bold text-xs tracking-wider uppercase border-b border-white/5 pb-2">@SharedLocalizer["Navigation"]</h5>
                    <nav class="flex flex-col gap-2.5 text-xs">
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("AboutUs","Home", new { area = "Shop" })">@SharedLocalizer["AboutUs"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Contact", "Home", new { area = "Shop" })">@SharedLocalizer["ContactUs"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Privacy", "Legal", new { area = "Shop" })">@SharedLocalizer["PrivacyPolicy"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Terms", "Legal", new { area = "Shop" })">@SharedLocalizer["TermsOfService"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Support", "Legal", new { area = "Shop" })">@SharedLocalizer["TechnicalSupport"]</a>
                    </nav>
                </div>
                <!-- Commercial -->
                <div class="flex flex-col gap-3">
                    <h5 class="text-[#E8A020] font-bold text-xs tracking-wider uppercase border-b border-white/5 pb-2">@SharedLocalizer["Commercial"]</h5>
                    <nav class="flex flex-col gap-2.5 text-xs">
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Contact", "Home", new { area = "Shop" })">@SharedLocalizer["ShippingInfo"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Request", "Quote", new { area = "Shop" })">@SharedLocalizer["WholesaleOrders"]</a>
                        <a class="text-slate-400 hover:text-white transition-all duration-200" href="@Url.Action("Login", "Account", new { area = "Shop" })">@SharedLocalizer["PartnerLogin"]</a>
                    </nav>
                </div>
            </div>
            
            <!-- Mobile Market Info (Bottom part of mobile footer) -->
            <div class="flex flex-col gap-3 border-t border-white/5 pt-6">
                <h5 class="text-[#E8A020] font-bold text-xs tracking-wider uppercase border-b border-white/5 pb-2">@SharedLocalizer["MarketInfo"]</h5>
                <div class="text-slate-400 text-xs leading-relaxed flex flex-col gap-3.5 mt-1">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-base text-[#E8A020] shrink-0">public</span>
                        <span>@city، @country</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-base text-[#E8A020] shrink-0">storefront</span>
                        <span>@(isOnline ? SharedLocalizer["OnlineOnly"] : SharedLocalizer["ShowroomsWarehouses"])</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-base text-[#E8A020] shrink-0">payments</span>
                        <span>@SharedLocalizer["ApprovedCurrency"]: @currency</span>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
    
    <!-- Bottom Bar (Shared) -->
    <div class="border-t border-white/5 w-full py-5 bg-[#090C12]">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-slate-500 text-xs">© @DateTime.Now.Year BLOCKO. @SharedLocalizer["AllRightsReserved"]</p>
        </div>
    </div>
</footer>