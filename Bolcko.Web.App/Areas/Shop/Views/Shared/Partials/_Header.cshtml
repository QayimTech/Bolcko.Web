@using Microsoft.Extensions.Localization
@using Bolcko.Web.App
@inject IStringLocalizer<SharedResource> SharedLocalizer

<header class="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 sticky top-0 z-50">
    <div class="flex justify-between items-center w-full px-6 py-3 max-w-7xl mx-auto">
        <div class="flex items-center gap-8">
            <a href="/" class="flex items-center gap-2">
                <img src="~/images/logo.svg" alt="Blocko Logo" class="h-10 w-auto" />
            </a>
            <nav class="hidden md:flex gap-6 items-center font-medium text-sm">
                <a class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="@Url.Action("Index", "Category")">@SharedLocalizer["Categories"]</a>
                <a class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="#">المشاريع</a>
                <a class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="@Url.Action("AboutUs","Home")">من نحن</a>
                <a class="text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="#">اتصل بنا</a>
            </nav>
        </div>
        <div class="flex-1 max-w-md mx-8 hidden lg:block">
            <div class="relative group">
                <input class="w-full bg-surface-container-low border border-outline-variant py-2 pr-10 pl-4 focus:ring-0 focus:border-primary-container text-body-md" placeholder="بحث عن مواد البناء..." type="text" />
                <span class="material-symbols-outlined absolute right-3 top-2.5 text-on-surface-variant">search</span>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <!-- Language Switcher -->
            <div class="flex items-center gap-2 border-l border-slate-200 dark:border-slate-700 pl-4 ml-4">
                <form asp-area="" asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@Context.Request.Path" method="post" class="flex gap-2">
                    <button type="submit" name="culture" value="ar" class="text-[10px] font-bold @(System.Globalization.CultureInfo.CurrentCulture.Name == "ar" ? "text-primary" : "text-slate-400 hover:text-slate-600")">AR</button>
                    <span class="text-slate-300 text-[10px]">|</span>
                    <button type="submit" name="culture" value="en" class="text-[10px] font-bold @(System.Globalization.CultureInfo.CurrentCulture.Name == "en" ? "text-primary" : "text-slate-400 hover:text-slate-600")">EN</button>
                </form>
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="relative group">
                    <button class="flex items-center gap-2 p-2 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-slate-600 dark:text-slate-400">person</span>
                        <span class="text-sm font-medium hidden md:block">@User.Identity.Name</span>
                    </button>
                    <div class="absolute left-0 top-full mt-2 w-48 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                        <a href="@Url.Action("Index", "Account", new { area = "Shop" })" class="block px-4 py-2 text-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">لوحة التحكم</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="@Url.Action("Index", "Home", new { area = "Admin" })" class="block px-4 py-2 text-sm hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">لوحة الإدارة</a>
                        }
                        <form asp-area="Shop" asp-controller="Account" asp-action="Logout" method="post" class="border-t border-slate-200 dark:border-slate-700">
                            <button type="submit" class="w-full text-right px-4 py-2 text-sm text-red-600 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">تسجيل الخروج</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a href="@Url.Action("Login", "Account", new { area = "Shop" })" class="p-2 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                    <span class="material-symbols-outlined text-slate-600 dark:text-slate-400">person</span>
                    <span class="text-xs font-bold mr-1">@SharedLocalizer["Login"]</span>
                </a>
            }
            <a href="@Url.Action("Index", "ShoppingCart", new { area = "Shop" })" class="p-2 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors relative inline-block">
                <span class="material-symbols-outlined text-slate-600 dark:text-slate-400">shopping_cart</span>
                <span class="absolute top-0 right-0 bg-primary text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full">3</span>
            </a>
        </div>
    </div>
</header>