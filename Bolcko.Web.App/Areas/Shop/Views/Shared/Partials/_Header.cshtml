<script>
(function () {
    var drawer   = document.getElementById("mobile-drawer");
    var backdrop = document.getElementById("drawer-backdrop");
    var openBtn  = document.getElementById("drawerOpenBtn");
    var closeBtn = document.getElementById("drawerCloseBtn");
    var hamIcon  = document.getElementById("drawerHamburgerIcon");

    function openDrawer() {
        if (!drawer) return;
        drawer.classList.remove("translate-x-full");
        backdrop.classList.remove("opacity-0", "pointer-events-none");
        backdrop.classList.add("opacity-100");
        if (hamIcon) hamIcon.textContent = "close";
        document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
        if (!drawer) return;
        drawer.classList.add("translate-x-full");
        backdrop.classList.add("opacity-0", "pointer-events-none");
        backdrop.classList.remove("opacity-100");
        if (hamIcon) hamIcon.textContent = "menu";
        document.body.style.overflow = "";
    }

    window.closeDrawer = closeDrawer;

    if (openBtn)  openBtn.addEventListener("click", openDrawer);
    if (closeBtn) closeBtn.addEventListener("click", closeDrawer);
    if (backdrop) backdrop.addEventListener("click", closeDrawer);
    document.addEventListener("keydown", function (e) { if (e.key === "Escape") closeDrawer(); });

    // Spotlight Search
    var searchToggle   = document.getElementById("search-toggle-btn");
    var spotlightEl    = document.getElementById("spotlight-search");
    var spotlightInput = document.getElementById("spotlight-input");
    var spotlightClose = document.getElementById("spotlight-close-btn");

    function openSpotlight() {
        if (!spotlightEl) return;
        spotlightEl.classList.remove("opacity-0", "pointer-events-none");
        var box = spotlightEl.querySelector(".transform");
        if (box) { box.classList.remove("scale-95"); box.classList.add("scale-100"); }
        setTimeout(function () { if (spotlightInput) spotlightInput.focus(); }, 150);
    }
    function closeSpotlight() {
        if (!spotlightEl) return;
        spotlightEl.classList.add("opacity-0", "pointer-events-none");
        var box = spotlightEl.querySelector(".transform");
        if (box) { box.classList.remove("scale-100"); box.classList.add("scale-95"); }
        if (spotlightInput) spotlightInput.value = "";
    }

    if (searchToggle) searchToggle.addEventListener("click", function (e) { e.preventDefault(); openSpotlight(); });
    if (spotlightClose) spotlightClose.addEventListener("click", function (e) { e.preventDefault(); closeSpotlight(); });
    if (spotlightEl) spotlightEl.addEventListener("click", function (e) { if (e.target === spotlightEl) closeSpotlight(); });
    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && spotlightEl && !spotlightEl.classList.contains("opacity-0")) closeSpotlight();
    });
})();

// =========================================================
// MEGA MENU — JS-positioned fixed panel (RTL-safe)
// =========================================================
(function () {
    var btn          = document.getElementById("mega-menu-btn");
    var panel        = document.getElementById("mega-menu-panel");
    var inner        = document.getElementById("mega-menu-inner");
    var backdrop     = document.getElementById("mega-menu-backdrop");
    var chevron      = document.getElementById("mega-menu-chevron");
    var isOpen       = false;
    var closeTimer   = null;  // delay timer to survive the hover-gap
    var isRTL        = document.documentElement.dir === "rtl";
    var CLOSE_DELAY  = 120;   // ms — enough time to move from btn to panel

    if (!btn || !panel) return;

    function positionPanel() {
        var btnRect = btn.getBoundingClientRect();
        var panelW  = inner ? inner.offsetWidth : 820;
        var vpW     = window.innerWidth;

        // Sit 4px below the bottom of the trigger button
        panel.style.top = (btnRect.bottom + 4) + "px";

        if (isRTL) {
            var rightOffset = vpW - btnRect.right;
            var leftEdge    = vpW - rightOffset - panelW;
            if (leftEdge < 12) rightOffset = vpW - panelW - 12;
            panel.style.right = rightOffset + "px";
            panel.style.left  = "auto";
        } else {
            var leftOffset = btnRect.left;
            if (leftOffset + panelW > vpW - 12) leftOffset = vpW - panelW - 12;
            if (leftOffset < 12) leftOffset = 12;
            panel.style.left  = leftOffset + "px";
            panel.style.right = "auto";
        }
    }

    function openMenu() {
        clearTimeout(closeTimer);
        if (isOpen) return;
        isOpen = true;
        positionPanel();
        panel.style.display = "block";
        panel.removeAttribute("aria-hidden");
        btn.setAttribute("aria-expanded", "true");
        if (chevron) chevron.style.transform = "rotate(180deg)";
        btn.classList.add("text-[#E8A020]", "bg-white/5");
    }

    function scheduleClose() {
        clearTimeout(closeTimer);
        closeTimer = setTimeout(closeMenu, CLOSE_DELAY);
    }

    function closeMenu() {
        clearTimeout(closeTimer);
        if (!isOpen) return;
        isOpen = false;
        panel.style.display = "none";
        panel.setAttribute("aria-hidden", "true");
        btn.setAttribute("aria-expanded", "false");
        if (chevron) chevron.style.transform = "";
        btn.classList.remove("text-[#E8A020]", "bg-white/5");
    }

    // --- Button events ---
    btn.addEventListener("click",       function (e) { e.stopPropagation(); isOpen ? closeMenu() : openMenu(); });
    btn.addEventListener("mouseenter",  function ()  { openMenu(); });
    btn.addEventListener("mouseleave",  function ()  { scheduleClose(); });

    // --- Panel events: cancel close when cursor enters panel ---
    panel.addEventListener("mouseenter", function () { clearTimeout(closeTimer); });
    panel.addEventListener("mouseleave", function () { scheduleClose(); });

    // --- Keyboard + resize ---
    document.addEventListener("keydown", function (e) { if (e.key === "Escape" && isOpen) closeMenu(); });
    window.addEventListener("resize",   function ()  { if (isOpen) positionPanel(); });

    // --- Click outside ---
    document.addEventListener("click",   function (e) {
        if (isOpen && !panel.contains(e.target) && e.target !== btn) closeMenu();
    });

    // -------------------------------------------------------
    // Active state for root category sidebar items
    // -------------------------------------------------------
    window.megaMenuActivate = function (element, catId) {
        document.querySelectorAll(".root-cat-item").forEach(function (el) {
            var active = el === element;
            // Background
            el.classList.toggle("bg-[#1d2640]",  active);
            el.classList.toggle("text-[#E8A020]", active);
            el.classList.toggle("active-root",    active);
            el.classList.toggle("text-slate-300", !active);
            // Icon box
            var icon = el.querySelector(".w-8");
            if (icon) {
                icon.classList.toggle("bg-[#E8A020]/20", active);
                icon.classList.toggle("text-[#E8A020]",  active);
                icon.classList.toggle("bg-white/5",      !active);
                icon.classList.toggle("text-slate-400",  !active);
            }
        });
        // Switch visible pane
        document.querySelectorAll(".subcats-pane").forEach(function (p) { p.classList.add("hidden"); });
        var pane = document.getElementById("mm-pane-" + catId);
        if (pane) pane.classList.remove("hidden");
    };
})();
</script>

