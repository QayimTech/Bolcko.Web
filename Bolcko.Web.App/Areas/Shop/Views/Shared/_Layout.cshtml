@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Bolcko.Web.App.SharedResource> SharedLocalizer
@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var soundEnabled = true;
    var soundUrl = "/sounds/default-notification.wav";
    var resolvedSoundUrl = soundUrl;
    if (!string.IsNullOrEmpty(resolvedSoundUrl) && !resolvedSoundUrl.StartsWith("http") && !resolvedSoundUrl.StartsWith("/"))
    {
        resolvedSoundUrl = "/" + resolvedSoundUrl;
    }
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName" dir="@(isRtl ? "rtl" : "ltr")" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @await Component.InvokeAsync("SeoMeta", new { defaultTitle = "بلوكو لتوريد مواد البناء" })
    
    <!-- Premium Orange Favicons Cache Busted v5 -->
    <link rel="apple-touch-icon" sizes="180x180" href="~/favicons/apple-touch-icon.png?v=5" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicons/favicon-32x32.png?v=5" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicons/favicon-16x16.png?v=5" />
    <link rel="shortcut icon" href="~/favicons/favicon.ico?v=5" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#e8a020" />
    <meta name="msapplication-TileColor" content="#0d111a" />
    <meta name="theme-color" content="#0d111a" />

    <!-- Google Fonts (non-blocking async load; noscript fallback below) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Preload primary Arabic font file (variable font, covers weights 400-700) -->
    <link rel="preload" as="font" type="font/woff2" crossorigin
          href="https://fonts.gstatic.com/s/notokufiarabic/v27/CSRk4ydQnPyaDxEXLFF6LZVLKrodrOYFFlKp.woff2">
    <!-- Icon CLS guard: reserve the final 1em x 1em glyph box and keep icons
         invisible until the icon FONT itself is loaded (ms-ready), so nothing
         shifts and no raw ligature names ever flash. The base class is inlined
         so the box metrics are correct before any external CSS arrives. -->
    <style>
        .material-symbols-outlined{font-family:'Material Symbols Outlined';font-weight:normal;font-style:normal;font-size:24px;line-height:1;letter-spacing:normal;text-transform:none;display:inline-block;white-space:nowrap;word-wrap:normal;direction:ltr;-webkit-font-smoothing:antialiased}
        html:not(.ms-ready) .material-symbols-outlined{visibility:hidden;width:1em;height:1em;overflow:hidden}
    </style>
    <link rel="preload" as="style"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700;800&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap"
          onload="this.onload=null;this.rel='stylesheet'">
    <link rel="preload" as="style"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght@24,200..700&display=block"
          onload='this.onload=null;this.rel="stylesheet";document.fonts.load("24px \"Material Symbols Outlined\"").then(function(){document.documentElement.classList.add("ms-ready")})'>
    <script>setTimeout(function () { document.documentElement.classList.add('ms-ready'); }, 4000);</script>
    <noscript>
        <link rel="stylesheet"
              href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700;800&family=Work+Sans:wght@600;700&family=Noto+Kufi+Arabic:wght@400;500;600;700&display=swap">
        <link rel="stylesheet"
              href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght@24,200..700&display=block">
        <style>.material-symbols-outlined{visibility:visible !important;width:auto !important;height:auto !important;overflow:visible !important}</style>
    </noscript>

    <!-- Performance Optimizations: Preconnect, Preload, Critical CSS -->
    <partial name="~/Views/Shared/_PerformanceOptimizations.cshtml" />

    <partial name="~/Areas/Shop/Views/Shared/Partials/_Styles.cshtml" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="bg-surface text-on-surface font-body-md min-h-screen">
    <partial name="~/Areas/Shop/Views/Shared/Partials/_Header.cshtml" />
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mx-auto max-w-7xl mt-4 rounded-md shadow-sm">
            <div class="flex items-center">
                <span class="material-symbols-outlined text-red-500 me-2">error</span>
                <p class="text-sm text-red-700 font-bold">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-emerald-50 border-l-4 border-emerald-500 p-4 mx-auto max-w-7xl mt-4 rounded-md shadow-sm">
            <div class="flex items-center">
                <span class="material-symbols-outlined text-emerald-500 me-2">check_circle</span>
                <p class="text-sm text-emerald-700 font-bold">@TempData["SuccessMessage"]</p>
            </div>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>
    
    <partial name="~/Areas/Shop/Views/Shared/Partials/_Footer.cshtml" />
    
    <!-- Audio Notification Support (always rendered so JS can find it) -->
    @{
        var resolvedSoundUrl = soundUrl;
        if (!string.IsNullOrEmpty(resolvedSoundUrl) && !resolvedSoundUrl.StartsWith("http") && !resolvedSoundUrl.StartsWith("/"))
        {
            resolvedSoundUrl = "/" + resolvedSoundUrl;
        }
    }
    <audio id="notification-sound"
           src="@resolvedSoundUrl"
           preload="auto"
           @(!soundEnabled ? "data-sound-disabled=\"true\"" : "")>
    </audio>

    <!-- Glassmorphic Premium Toast Container -->
    <div id="toast-container" class="fixed bottom-6 start-6 z-[99999] flex flex-col gap-3 pointer-events-none"></div>

    <partial name="~/Areas/Shop/Views/Shared/Partials/_Scripts.cshtml" />

    <script>
        // Global SignalR setup (Exactly like Admin)
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotification", function (notification) {
            // Play sound via AudioContext engine (bypasses browser autoplay restriction)
            if (typeof window.playNotificationSound === 'function') {
                window.playNotificationSound();
            }

            // Determine appropriate icon based on title/content
            let iconName = "notifications";
            const titleLower = (notification.title || "").toLowerCase();
            const msgLower = (notification.message || "").toLowerCase();
            if (titleLower.includes("order") || titleLower.includes("طلب") || msgLower.includes("order") || msgLower.includes("طلب")) {
                iconName = "shopping_cart";
            } else if (titleLower.includes("delivery") || titleLower.includes("توصيل") || titleLower.includes("سائق") || titleLower.includes("مندوب")) {
                iconName = "local_shipping";
            }

            const isClickable = !!notification.actionUrl;
            const clickAttr = isClickable ? `onclick="window.location.href='${notification.actionUrl}'"` : '';
            const cursorClass = isClickable ? 'cursor-pointer hover:bg-[#161d2d]/90 hover:border-indigo-500/60 transition-all duration-300' : '';

            // Create and append dynamic premium toast notification
            const toastHtml = `
                <div ${clickAttr} class="pointer-events-auto bg-[#0d111a]/85 backdrop-blur-md border border-indigo-500/30 text-white px-5 py-4 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.3)] flex items-center gap-3.5 transform translate-y-4 opacity-0 transition-all duration-500 ease-out select-none border-s-4 border-s-[#E8A020] ${cursorClass}" style="min-width: 320px; max-width: 400px;">
                    <div class="w-10 h-10 rounded-xl bg-[#E8A020]/10 flex items-center justify-center text-[#E8A020] shrink-0">
                        <span class="material-symbols-outlined text-[22px]">${iconName}</span>
                    </div>
                    <div class="flex-grow text-start">
                        <strong class="block text-xs uppercase tracking-wider text-[#E8A020] font-bold">${notification.title || 'إشعار جديد'}</strong>
                        <p class="text-xs text-slate-200 mt-1 font-medium leading-relaxed">${notification.message}</p>
                    </div>
                </div>
            `;
            
            let container = $('#toast-container');
            if (container.length === 0) {
                $('body').append('<div id="toast-container" class="fixed bottom-6 start-6 z-[99999] flex flex-col gap-3 pointer-events-none"></div>');
                container = $('#toast-container');
            }
            
            const $toast = $(toastHtml);
            container.append($toast);

            // Trigger animation
            setTimeout(() => {
                $toast.removeClass('translate-y-4 opacity-0').addClass('translate-y-0 opacity-100');
            }, 10);

            // Auto fade out toast
            setTimeout(function() {
                $toast.removeClass('translate-y-0 opacity-100').addClass('translate-y-4 opacity-0');
                setTimeout(() => {
                    $toast.remove();
                }, 500);
            }, 10000);

            // Inject new notification directly into dropdown UI dynamically (bypassing REST/API GET requests)
            if (window.NotificationService && typeof window.NotificationService.injectNotification === 'function') {
                window.NotificationService.injectNotification(notification);
            }
        });

        // Start connection
        connection.start()
            .then(() => console.log("SignalR Connected successfully (Shop)!"))
            .catch(err => console.error("SignalR Connection Error (Shop): ", err));
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
