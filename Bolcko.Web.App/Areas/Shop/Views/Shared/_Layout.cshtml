@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Bolcko.Web.App.SharedResource> SharedLocalizer
@{
    var isRtl = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var soundEnabled = true;
    var soundUrl = "/sounds/notification.mp3";
    var resolvedSoundUrl = soundUrl;
    if (!string.IsNullOrEmpty(resolvedSoundUrl) && !resolvedSoundUrl.StartsWith("http") && !resolvedSoundUrl.StartsWith("/"))
    {
        resolvedSoundUrl = "/" + resolvedSoundUrl;
    }
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName" dir="@(isRtl ? "rtl" : "ltr")" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - بلوكو لتوريد مواد البناء</title>
    
    <!-- Premium Favicons Cache Busted v3 (LinkedIn/SoundCloud Square Style) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#e8a020" />
    <meta name="msapplication-TileColor" content="#0d111a" />
    <meta name="theme-color" content="#0d111a" />

    <!-- Google Fonts Async Loading with preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@600;700;800&amp;family=Work+Sans:wght@600;700&amp;family=Noto+Kufi+Arabic:wght@400;500;600;700&amp;display=swap" as="style" />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" as="style" />
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@600;700;800&amp;family=Work+Sans:wght@600;700&amp;family=Noto+Kufi+Arabic:wght@400;500;600;700&amp;display=swap" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" media="print" onload="this.media='all'" />
    
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@600;700;800&amp;family=Work+Sans:wght@600;700&amp;family=Noto+Kufi+Arabic:wght@400;500;600;700&amp;display=swap" />
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    </noscript>

    <!-- Preload critical stylesheets to optimize First Contentful Paint (FCP) -->
    <link rel="preload" href="/css/site.css" as="style" />
    <link rel="preload" href="/css/output.css" as="style" />

    <partial name="~/Areas/Shop/Views/Shared/Partials/_Styles.cshtml" />
</head>
<body class="bg-surface text-on-surface font-body-md min-h-screen">
    <partial name="~/Areas/Shop/Views/Shared/Partials/_Header.cshtml" />
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mx-auto max-w-7xl mt-4 rounded-md shadow-sm">
            <div class="flex items-center">
                <span class="material-symbols-outlined text-red-500 me-2">error</span>
                <p class="text-sm text-red-700 font-bold">@TempData["ErrorMessage"]</p>
            </div>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-emerald-50 border-l-4 border-emerald-500 p-4 mx-auto max-w-7xl mt-4 rounded-md shadow-sm">
            <div class="flex items-center">
                <span class="material-symbols-outlined text-emerald-500 me-2">check_circle</span>
                <p class="text-sm text-emerald-700 font-bold">@TempData["SuccessMessage"]</p>
            </div>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>
    
    <partial name="~/Areas/Shop/Views/Shared/Partials/_Footer.cshtml" />
    
    <!-- Audio Notification Support -->
    @if (soundEnabled)
    {
        <audio id="shop-notification-sound" src="@resolvedSoundUrl" preload="auto"></audio>
    }

    <!-- Glassmorphic Premium Toast Container -->
    <div id="toast-container" class="fixed bottom-6 start-6 z-[99999] flex flex-col gap-3 pointer-events-none"></div>

    <partial name="~/Areas/Shop/Views/Shared/Partials/_Scripts.cshtml" />

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // SignalR connection setup
            const shopConnection = new signalR.HubConnectionBuilder()
                .withUrl("/notificationHub")
                .withAutomaticReconnect()
                .build();

            shopConnection.on("ReceiveNotification", function (notification) {
                if (typeof window.playNotificationSound === 'function') {
                    window.playNotificationSound();
                }

                // Add premium glassmorphism toast
                let iconName = "notifications_active";
                const titleLower = (notification.title || "").toLowerCase();
                const msgLower = (notification.message || "").toLowerCase();
                if (titleLower.includes("order") || titleLower.includes("طلب") || msgLower.includes("order") || msgLower.includes("طلب")) {
                    iconName = "shopping_cart";
                } else if (titleLower.includes("delivery") || titleLower.includes("توصيل")) {
                    iconName = "local_shipping";
                }

                const toastHtml = `
                    <div class="pointer-events-auto bg-[#0d111a]/85 backdrop-blur-md border border-indigo-500/30 text-white px-5 py-4 rounded-2xl shadow-2xl flex items-center gap-3.5 border-s-4 border-s-[#E8A020]" style="min-width: 320px; max-width: 400px;">
                        <div class="w-10 h-10 rounded-xl bg-[#E8A020]/10 flex items-center justify-center text-[#E8A020] shrink-0">
                            <span class="material-symbols-outlined text-[22px]">${iconName}</span>
                        </div>
                        <div class="flex-grow text-start">
                            <strong class="block text-xs uppercase tracking-wider text-[#E8A020] font-bold">${notification.title || 'Notification'}</strong>
                            <p class="text-xs text-slate-200 mt-1 font-medium leading-relaxed">${notification.message}</p>
                        </div>
                    </div>
                `;
                
                const toastContainer = document.getElementById('toast-container');
                if (toastContainer) {
                    const tempDiv = document.createElement('div');
                    tempDiv.innerHTML = toastHtml.trim();
                    const toastNode = tempDiv.firstChild;
                    toastContainer.appendChild(toastNode);
                    setTimeout(() => toastNode.remove(), 7000);
                }
            });

            shopConnection.start().catch(err => console.warn('SignalR Connection issue: ', err));
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
