@model Bolcko.Domain.Entities.Tender.DTOs.QuoteRequestDto
@{
    ViewData["Title"] = "طلب عرض سعر";
}
<main class="max-w-4xl mx-auto px-6 py-12 text-right">
    <header class="mb-12 border-r-4 border-primary-container pr-6">
        <h1 class="font-headline-xl text-on-surface uppercase mb-2">طلب عرض سعر للكميات</h1>
        <p class="font-body-lg text-secondary">يرجى تعبئة النموذج أدناه للحصول على تسعير مخصص لمشروعك.</p>
    </header>

    <form asp-action="Request" asp-controller="Quote" method="post" class="space-y-8">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-error text-xs mb-4"></div>
        <!-- Customer & Company Info -->
        <div class="bg-white border border-outline-variant p-8 shadow-hard">
            <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">معلومات العميل والشركة</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">نوع المشروع</label>
                    <select asp-for="ProjectType" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right">
                        <option>مشروع سكني</option>
                        <option>مشروع تجاري</option>
                        <option>بنية تحتية</option>
                        <option>غير ذلك</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">اسم الشركة</label>
                    <input asp-for="CompanyName" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="text" placeholder="أدخل اسم الشركة" />
                    <span asp-validation-for="CompanyName" class="text-error text-xs"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">الاسم الكامل للمسؤول</label>
                    <input asp-for="FullName" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="text" placeholder="أدخل اسمك الكامل" />
                    <span asp-validation-for="FullName" class="text-error text-xs"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">البريد الإلكتروني</label>
                    <input asp-for="Email" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="email" placeholder="example@domain.com" />
                    <span asp-validation-for="Email" class="text-error text-xs"></span>
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">رقم الهاتف</label>
                    <input asp-for="Phone" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="tel" placeholder="05xxxxxxxx" />
                    <span asp-validation-for="Phone" class="text-error text-xs"></span>
                </div>
            </div>
        </div>

        <!-- Project Info -->
        <div class="bg-white border border-outline-variant p-8 shadow-hard">
            <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">معلومات المشروع</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">اسم المشروع</label>
                    <input asp-for="ProjectName" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="text" placeholder="مثلاً: مجمع سكني حطين" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">موقع المشروع (المدينة)</label>
                    <select asp-for="City" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right">
                        <option value="عمان">عمان</option>
                        <option value="الزرقاء">الزرقاء</option>
                        <option value="إربد">إربد</option>
                    </select>
                    <span asp-validation-for="City" class="text-error text-xs"></span>
                </div>
            </div>
        </div>

        <!-- Products List -->
        <div class="bg-white border border-outline-variant p-8 shadow-hard">
            <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">المنتجات المطلوبة</h2>
            <div class="space-y-4">
                <div class="grid grid-cols-12 gap-4 items-end border-b border-outline-variant pb-4">
                    <div class="col-span-6">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">المنتج</label>
                        <input class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="text" placeholder="اسم المنتج أو SKU" value="أسمنت بورتلاندي 50 كجم" />
                    </div>
                    <div class="col-span-3">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">الكمية</label>
                        <input class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" type="number" value="1000" />
                    </div>
                    <div class="col-span-3">
                        <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">الوحدة</label>
                        <select class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right">
                            <option>كيس</option>
                            <option>طن</option>
                            <option>متر مكعب</option>
                        </select>
                    </div>
                </div>
                <button type="button" class="text-primary font-bold text-sm flex items-center gap-1 hover:underline">
                    <span class="material-symbols-outlined text-sm">add_circle</span>
                    إضافة منتج آخر
                </button>
            </div>
        </div>

        <!-- Additional Notes -->
        <div class="bg-white border border-outline-variant p-8 shadow-hard">
            <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">ملاحظات إضافية والتفاصيل</h2>
            <textarea asp-for="Notes" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right h-32" placeholder="أدخل أي متطلبات خاصة أو جداول زمنية للتوصيل"></textarea>
        </div>

        <div class="flex justify-end">
            <button type="submit" class="bg-primary text-white font-bold px-12 py-4 uppercase shadow-hard hover:opacity-90 transition-all flex items-center gap-2">
                إرسال طلب عرض السعر
                <span class="material-symbols-outlined">send</span>
            </button>
        </div>
    </form>
</main>