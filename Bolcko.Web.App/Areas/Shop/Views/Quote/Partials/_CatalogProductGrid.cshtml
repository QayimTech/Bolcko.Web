@model IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>
@{
    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name == "ar";
}

@if (!Model.Any())
{
    <div style="grid-column: 1/-1; padding: 48px 16px; text-align: center; color: #94a3b8; font-weight: 700; font-size: 14px;" class="empty-state-indicator">
        <span class="material-symbols-outlined" style="font-size: 40px; color: #cbd5e1; display: block; margin-bottom: 8px;">search_off</span>
        @(isAr ? "لا يوجد منتجات تطابق بحثك" : "No products match your search")
    </div>
}
else
{
    @foreach (var p in Model)
    {
        var imgUrl = string.IsNullOrEmpty(p.ImageUrl) ? "" : (p.ImageUrl.StartsWith("http") ? p.ImageUrl : "/" + p.ImageUrl.TrimStart('/'));
        var unit = string.IsNullOrEmpty(p.UnitOfMeasure) ? "كيس" : p.UnitOfMeasure;
        var safeName = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(p.Name);
        var safeSku = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(p.Sku ?? "");
        var safeImg = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(imgUrl);

        <div class="q-catalog-card"
             data-product-id="@p.Id"
             data-product-name="@p.Name"
             data-product-unit="@unit"
             data-product-sku="@(p.Sku ?? "")"
             data-product-img="@imgUrl">
            @if (!string.IsNullOrEmpty(imgUrl))
            {
                <img src="@imgUrl" style="width: 100%; height: 120px; object-fit: cover;" alt="@p.Name" onerror="this.style.display='none'" />
            }
            else
            {
                <div style="width: 100%; height: 120px; background: #f1f5f9; display: flex; align-items: center; justify-content: center;">
                    <span class="material-symbols-outlined" style="font-size: 36px; color: #cbd5e1;">image</span>
                </div>
            }
            <div style="padding: 12px;">
                <span style="font-size: 10px; color: #E8A020; font-weight: 700; text-transform: uppercase; display: block; margin-bottom: 4px;">@(p.CategoryName ?? "")</span>
                <h4 style="font-weight: 700; font-size: 13px; color: #1e293b; margin: 0 0 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@p.Name">@p.Name</h4>
                <span style="font-size: 11px; color: #94a3b8; font-family: monospace;">@(string.IsNullOrEmpty(p.Sku) ? "-" : p.Sku)</span>
            </div>
            <div style="background: #f1f5f9; padding: 8px; text-align: center; font-weight: 700; font-size: 12px; color: #475569; display: flex; align-items: center; justify-content: center; gap: 4px; transition: background 0.18s, color 0.18s;">
                <span class="material-symbols-outlined" style="font-size: 14px;">add</span>
                @(isAr ? "إضافة للعطاء" : "Add to Tender")
            </div>
        </div>
    }
}
