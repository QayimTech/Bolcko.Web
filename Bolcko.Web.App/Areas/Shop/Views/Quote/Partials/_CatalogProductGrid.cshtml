@model IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>
@{
    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name == "ar";
}

@if (!Model.Any())
{
    <div class="col-span-full py-12 text-center text-slate-400 font-bold empty-state-indicator">
        @(isAr ? "لا يوجد منتجات تطابق بحثك" : "No products match your search")
    </div>
}
else
{
    @foreach (var p in Model)
    {
        var imgUrl = string.IsNullOrEmpty(p.ImageUrl) ? "" : (p.ImageUrl.StartsWith("http") ? p.ImageUrl : "/" + p.ImageUrl.TrimStart('/'));
        var unit = string.IsNullOrEmpty(p.UnitOfMeasure) ? "كيس" : p.UnitOfMeasure;
        var safeName = p.Name.Replace("'", "\\'");

        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col group product-card-item">
            @if (!string.IsNullOrEmpty(imgUrl))
            {
                <img src="@imgUrl" class="w-full h-32 object-cover" />
            }
            else
            {
                <div class="w-full h-32 bg-slate-100 flex items-center justify-center">
                    <span class="material-symbols-outlined text-4xl text-slate-300">image</span>
                </div>
            }
            <div class="p-4 flex-1 flex flex-col">
                <span class="text-[10px] text-[#E8A020] font-bold uppercase mb-1">@(p.CategoryName ?? "")</span>
                <h4 class="font-bold text-sm text-slate-800 mb-1 line-clamp-2" title="@p.Name">@p.Name</h4>
                <span class="text-xs text-slate-400 mb-4 block">SKU: @(string.IsNullOrEmpty(p.Sku) ? "-" : p.Sku)</span>
                
                <button type="button" onclick="selectProductFromModal(@p.Id, '@safeName', '@unit', '@(p.Sku?.Replace("'", "\\'") ?? "")', '@imgUrl')" class="mt-auto w-full bg-slate-100 hover:bg-[#151B26] hover:text-white text-slate-700 font-bold py-2 rounded-xl transition-colors text-xs flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">add</span>
                    @(isAr ? "إضافة للعطاء" : "Add to Tender")
                </button>
            </div>
        </div>
    }
}
