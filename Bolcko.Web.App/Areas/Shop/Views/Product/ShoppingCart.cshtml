<main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header -->
    <header class="mb-12 border-l-4 border-primary-container pl-6">
        <h1 class="font-headline-xl text-headline-xl text-on-surface uppercase mb-2">Shopping Cart</h1>
        <p class="font-body-lg text-body-lg text-secondary">Welcome back, you have 2 items in your industrial cart.</p>
    </header>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        <!-- Cart Items Section -->
        <div class="lg:col-span-8 space-y-6">
            <!-- Item 1 -->
            <div class="bg-surface-container-lowest border border-outline-variant flex flex-col md:flex-row overflow-hidden hard-drop-shadow">
                <div class="w-full md:w-48 h-48 bg-surface-variant flex-shrink-0">
                    <img alt="Standard Concrete Blocks" class="w-full h-full object-cover" data-alt="neatly stacked grey industrial concrete blocks in a warehouse environment with dramatic industrial lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCGzsLOFT9x8qCrbx9RuUi6q_f78GKadOywkC5eC-zF_EZhIUBInp-ZZkDZXoIE6bZLmaVpKyS7ujvwkIrIj_TQ6D4a73T3-TZEoaxKi9gI15UIsuXokAXBGGfU3vg0zQcO3AWHHtgNCJjuy51BLhjuQLUag7T0419rDPpWmLeAqPCczdk8nONJrECPMvbQ1fgcXNnHjuHCJWPJ9QOKxWlH_1lywixg8zfaS5qvtf2fSnQ2YGTGXHUqYC8hIPFRYIp0ZzEmeJSbve0" />
                </div>
                <div class="p-md flex-grow flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start">
                            <h3 class="font-headline-md text-headline-md text-on-surface uppercase">Standard Concrete Blocks</h3>
                            <button class="text-outline hover:text-error transition-colors">
                                <span class="material-symbols-outlined" data-icon="delete">delete</span>
                            </button>
                        </div>
                        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1">
                            <p class="font-label-bold text-label-sm text-outline-variant uppercase">SKU: <span class="text-on-surface-variant">BLK-500-STD</span></p>
                            <p class="font-label-bold text-label-sm text-outline-variant uppercase">Specs: <span class="text-on-surface-variant">20x20x40cm</span></p>
                        </div>
                        <div class="mt-3">
                            <span class="inline-block bg-green-100 text-green-800 text-[10px] font-bold px-2 py-1 uppercase rounded-sm border border-green-200">In Stock</span>
                        </div>
                    </div>
                    <div class="mt-6 flex flex-wrap justify-between items-end">
                        <div class="flex items-center border border-outline">
                            <button class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-r border-outline">-</button>
                            <span class="px-6 py-1 font-label-bold text-on-surface">500</span>
                            <button class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-l border-outline">+</button>
                        </div>
                        <div class="text-right">
                            <p class="font-label-bold text-label-sm text-outline uppercase mb-1">Subtotal</p>
                            <p class="font-headline-md text-headline-md text-on-surface">2,500.00 <span class="text-sm">SAR</span></p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Item 2 -->
            <div class="bg-surface-container-lowest border border-outline-variant flex flex-col md:flex-row overflow-hidden hard-drop-shadow">
                <div class="w-full md:w-48 h-48 bg-surface-variant flex-shrink-0">
                    <img alt="Premium Portland Cement" class="w-full h-full object-cover" data-alt="rows of heavy industrial cement bags on a pallet in a construction material yard during daytime" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDVAyH6FQcIHkuxpuTObI828P2vzlObnb_DUG4nvdzMIau33Mb3gF0nezgdZXnmlqtnMebJBtlc4Uxf387Vcx9GWBRCfcqOj_pnMEMpILX2B8kbmLIXE2Iwrvap-GlVTdGAEaZ-AoiIjsT3mnpNxiLd65pUY8eLVME3LilZ1x5UD7XrUW6JCNPYYSCPB63x9W8qyRveMMx_lJm2zqJm85UNwqwMRMVBjQ_erFQHlF9LBGbnNSeDpEHG8Jw4amS4v8LfkD96-M2DCcM" />
                </div>
                <div class="p-md flex-grow flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start">
                            <h3 class="font-headline-md text-headline-md text-on-surface uppercase">Premium Portland Cement</h3>
                            <button class="text-outline hover:text-error transition-colors">
                                <span class="material-symbols-outlined" data-icon="delete">delete</span>
                            </button>
                        </div>
                        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1">
                            <p class="font-label-bold text-label-sm text-outline-variant uppercase">SKU: <span class="text-on-surface-variant">CMT-120-PRM</span></p>
                            <p class="font-label-bold text-label-sm text-outline-variant uppercase">Specs: <span class="text-on-surface-variant">50kg bag</span></p>
                        </div>
                        <div class="mt-3">
                            <span class="inline-block bg-amber-100 text-amber-800 text-[10px] font-bold px-2 py-1 uppercase rounded-sm border border-amber-200">Pre-order</span>
                        </div>
                    </div>
                    <div class="mt-6 flex flex-wrap justify-between items-end">
                        <div class="flex items-center border border-outline">
                            <button class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-r border-outline">-</button>
                            <span class="px-6 py-1 font-label-bold text-on-surface">120</span>
                            <button class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-l border-outline">+</button>
                        </div>
                        <div class="text-right">
                            <p class="font-label-bold text-label-sm text-outline uppercase mb-1">Subtotal</p>
                            <p class="font-headline-md text-headline-md text-on-surface">3,600.00 <span class="text-sm">SAR</span></p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Trust Badges -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter py-8">
                <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low">
                    <span class="material-symbols-outlined text-primary text-3xl" data-icon="verified">verified</span>
                    <div>
                        <h4 class="font-label-bold text-on-surface uppercase">Industrial Quality Guaranteed</h4>
                        <p class="text-label-sm text-outline uppercase">SASO compliant materials</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low">
                    <span class="material-symbols-outlined text-primary text-3xl" data-icon="local_shipping">local_shipping</span>
                    <div>
                        <h4 class="font-label-bold text-on-surface uppercase">Site-Ready Delivery</h4>
                        <p class="text-label-sm text-outline uppercase">To any major construction site</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- Order Summary Section -->
        <div class="lg:col-span-4">
            <div class="bg-surface-container-lowest border-2 border-on-background p-md hard-drop-shadow sticky top-24">
                <h2 class="font-headline-md text-headline-md text-on-surface uppercase mb-6 pb-2 border-b-2 border-primary-container">Order Summary</h2>
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between items-center">
                        <span class="font-body-md text-outline-variant uppercase">Subtotal</span>
                        <span class="font-label-bold text-on-surface">6,100.00 SAR</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="font-body-md text-outline-variant uppercase">VAT (15%)</span>
                        <span class="font-label-bold text-on-surface">915.00 SAR</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="font-body-md text-outline-variant uppercase">Estimated Shipping</span>
                        <span class="font-label-bold text-on-surface">250.00 SAR</span>
                    </div>
                    <div class="pt-4 border-t border-outline-variant flex justify-between items-center">
                        <span class="font-headline-md text-headline-md text-on-surface uppercase">Total</span>
                        <span class="font-headline-md text-headline-md text-primary">7,265.00 SAR</span>
                    </div>
                </div>
                <!-- Promo Code -->
                <div class="mb-8">
                    <label class="block font-label-bold text-label-sm text-on-surface uppercase mb-2">Promo Code</label>
                    <div class="flex">
                        <input class="flex-grow bg-surface-container-low border border-outline px-4 py-2 text-label-bold uppercase focus:outline-none focus:border-primary-container" placeholder="ENTER CODE" type="text" />
                        <button class="bg-secondary text-white px-6 py-2 font-label-bold uppercase active:scale-95 transition-transform">Apply</button>
                    </div>
                </div>
                <!-- CTA -->
                <button class="w-full bg-primary-container text-on-primary-container font-headline-md py-4 flex items-center justify-center gap-2 uppercase active:scale-95 transition-transform hover:bg-amber-600 transition-colors">
                    Proceed to Checkout
                    <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
                </button>
                <div class="mt-6 flex flex-col items-center gap-4 border-t border-outline-variant pt-6">
                    <p class="text-label-sm text-outline-variant uppercase">We accept secure payments via</p>
                    <div class="flex gap-4 opacity-50 grayscale">
                        <span class="material-symbols-outlined" data-icon="credit_card" data-weight="fill">credit_card</span>
                        <span class="material-symbols-outlined" data-icon="account_balance" data-weight="fill">account_balance</span>
                        <span class="material-symbols-outlined" data-icon="payments" data-weight="fill">payments</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>