@model Bolcko.Domain.Entities.Product.DTOs.ProductDto
@{
    ViewData["Title"] = "تفاصيل المنتج";
}
<main class="max-w-7xl mx-auto px-6 py-8 text-right">
    @if (Model != null)
    {
        <!-- Breadcrumbs -->
        <nav class="flex mb-8 items-center gap-2 font-bold text-label-sm text-on-surface-variant uppercase tracking-widest">
            <a class="hover:text-primary" href="/">الرئيسية</a>
            <span class="material-symbols-outlined text-sm">chevron_left</span>
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <a class="hover:text-primary" href="@Url.Action("Index", "Category", new { area = "Shop", id = Model.CategoryId })">@Model.CategoryName</a>
                <span class="material-symbols-outlined text-sm">chevron_left</span>
            }
            <span class="text-on-surface font-bold">@Model.Name</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Product Gallery -->
            <div class="lg:col-span-7 space-y-6">
                <div class="border border-outline-variant bg-white overflow-hidden shadow-hard">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img alt="@Model.Name" class="w-full h-[500px] object-cover" 
                             src="@(Model.ImageUrl.StartsWith("http") ? Model.ImageUrl : "/" + Model.ImageUrl.TrimStart('/'))"
                             onerror="this.src='https://placehold.co/800x500/e2e8f0/475569?text=@(Uri.EscapeDataString(Model.Name))'" />
                    }
                    else
                    {
                        <div class="w-full h-[500px] flex items-center justify-center bg-slate-100">
                            <span class="material-symbols-outlined text-6xl text-slate-300">image</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Info -->
            <div class="lg:col-span-5 flex flex-col">
                <div class="mb-2">
                    <span class="bg-surface-container-highest text-on-surface-variant px-3 py-1 font-bold text-xs border border-outline-variant uppercase">SKU: @Model.Sku</span>
                </div>
                <h1 class="font-headline-xl text-on-surface mb-1">@Model.Name</h1>
                
                <div class="bg-white border-y border-outline-variant py-6 mb-8">
                    <div class="flex items-baseline gap-4 mb-4">
                        <span class="text-4xl font-bold text-on-surface">@Model.RetailPrice.ToString("N2") ر.س</span>
                        <span class="text-xs text-on-surface-variant uppercase">للوحدة (شامل الضريبة)</span>
                    </div>
                    
                    <div class="flex gap-4 items-center">
                        <form asp-action="AddToCart" asp-controller="ShoppingCart" asp-area="Shop" method="post" class="flex gap-4 items-center flex-1">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <div class="flex border border-outline-variant h-12 overflow-hidden shadow-hard">
                                <button type="button" data-quantity-btn="add" class="px-4 bg-surface-container hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">add</span></button>
                                <input id="quantity-input" class="w-16 border-x border-outline-variant text-center focus:ring-0 bg-white font-bold" type="number" name="quantity" value="1" min="1" />
                                <button type="button" data-quantity-btn="remove" class="px-4 bg-surface-container hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">remove</span></button>
                            </div>
                            <button type="submit" class="flex-1 h-12 bg-primary-container text-on-primary-container font-bold uppercase tracking-wider flex items-center justify-center gap-2 hover:opacity-90 transition-opacity shadow-hard">
                                <span class="material-symbols-outlined">shopping_cart</span>
                                أضف إلى السلة
                            </button>
                        </form>
                    </div>
                </div>

                <div class="space-y-6">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div>
                            <h3 class="font-bold uppercase text-on-surface-variant mb-2 border-r-4 border-primary pr-2">الوصف</h3>
                            <p class="font-body-md text-on-surface leading-relaxed">
                                @Model.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-20">
            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">inventory</span>
            <h2 class="font-headline-lg text-on-surface mb-2">المنتج غير موجود</h2>
            <p class="text-on-surface-variant mb-8">عذراً، لم يتم العثور على المنتج المطلوب</p>
            <a href="@Url.Action("Index", "Category", new { area = "Shop" })" class="bg-primary-container text-on-primary-container font-bold px-8 py-4 uppercase tracking-wider transition-all hover:opacity-90 shadow-hard inline-block">
                تصفح المنتجات
            </a>
        </div>
    }
</main>

@section Scripts {
    <script>
        $(document).ready(function() {
            const quantityInput = $('#quantity-input');
            
            $('[data-quantity-btn="add"]').click(function() {
                let current = parseInt(quantityInput.val());
                quantityInput.val(current + 1);
            });
            
            $('[data-quantity-btn="remove"]').click(function() {
                let current = parseInt(quantityInput.val());
                if (current > 1) {
                    quantityInput.val(current - 1);
                }
            });
        });
    </script>
}