@model Bolcko.Domain.Entities.Product.DTOs.ProductDto
@{
    ViewData["Title"] = SharedLocalizer["ProductDetails"];
}

<main class="max-w-7xl mx-auto px-6 py-12 text-start">
    @if (Model != null)
    {
        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 mb-12 text-[11px] font-bold text-slate-400 uppercase tracking-widest">
            <a class="hover:text-[#E8A020] transition-colors" href="/">@SharedLocalizer["Home"]</a>
            <span class="material-symbols-outlined text-xs rtl:-scale-x-100">chevron_left</span>
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <a class="hover:text-[#E8A020] transition-colors" href="@Url.Action("Index", "Category", new { area = "Shop", id = Model.CategoryId })">@Model.CategoryName</a>
                <span class="material-symbols-outlined text-xs rtl:-scale-x-100">chevron_left</span>
            }
            <span class="text-slate-800 font-bold">@Model.Name</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            <!-- Product Gallery Section (7 columns) -->
            <div class="lg:col-span-7 space-y-6">
                <div class="border border-slate-100 bg-white rounded-3xl overflow-hidden shadow-[0_4px_25px_rgba(0,0,0,0.02)] p-4 relative group">
                    <!-- SKU Badge -->
                    <span class="absolute top-8 right-8 bg-[#151B26] text-white font-bold px-3 py-1.5 rounded-xl text-[10px] uppercase tracking-wider shadow-md z-10">
                        SKU: @Model.Sku
                    </span>
                    
                    @if (Model.Images != null && Model.Images.Any())
                    {
                        var firstImage = Model.Images.OrderBy(img => img.DisplayOrder).First().Url;
                        
                        <img id="main-product-image" alt="@Model.Name" class="w-full h-[550px] object-cover rounded-2xl group-hover:scale-[1.01] transition-all duration-500 ease-out" 
                             src="@(firstImage.StartsWith("http") ? firstImage : "/" + firstImage.TrimStart('/'))"
                             onerror="this.src='https://placehold.co/800x550/f8fafc/475569?text=@(Uri.EscapeDataString(Model.Name))'" />
                             
                        @if (Model.Images.Count > 1)
                        {
                            <div class="flex flex-wrap gap-3 mt-4 justify-start">
                                @{
                                    var sortedImages = Model.Images.OrderBy(img => img.DisplayOrder).ToList();
                                }
                                @for (int i = 0; i < sortedImages.Count; i++)
                                {
                                    var img = sortedImages[i];
                                    var activeClass = i == 0 ? "border-[#E8A020] ring-1 ring-[#E8A020]" : "border-slate-100 hover:border-[#E8A020]/50";
                                    <div class="w-20 h-20 bg-slate-50 border-2 rounded-2xl overflow-hidden cursor-pointer transition-all duration-300 thumbnail-image-box @activeClass"
                                         data-image-url="@(img.Url.StartsWith("http") ? img.Url : "/" + img.Url.TrimStart('/'))">
                                        <img src="@(img.Url.StartsWith("http") ? img.Url : "/" + img.Url.TrimStart('/'))" 
                                             class="w-full h-full object-cover" 
                                             onerror="this.src='https://placehold.co/100x100/f8fafc/475569?text=Image'"
                                             alt="Thumbnail @(i+1)" />
                                    </div>
                                }
                            </div>
                        }
                    }
                    else if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        var imageUrls = Model.ImageUrl.Split(',', StringSplitOptions.RemoveEmptyEntries);
                        var firstImage = imageUrls.FirstOrDefault() ?? string.Empty;
                        
                        <img id="main-product-image" alt="@Model.Name" class="w-full h-[550px] object-cover rounded-2xl group-hover:scale-[1.01] transition-all duration-500 ease-out" 
                             src="@(firstImage.StartsWith("http") ? firstImage : "/" + firstImage.TrimStart('/'))"
                             onerror="this.src='https://placehold.co/800x550/f8fafc/475569?text=@(Uri.EscapeDataString(Model.Name))'" />
                             
                        @if (imageUrls.Length > 1)
                        {
                            <div class="flex flex-wrap gap-3 mt-4 justify-start">
                                @for (int i = 0; i < imageUrls.Length; i++)
                                {
                                    var img = imageUrls[i];
                                    var activeClass = i == 0 ? "border-[#E8A020] ring-1 ring-[#E8A020]" : "border-slate-100 hover:border-[#E8A020]/50";
                                    <div class="w-20 h-20 bg-slate-50 border-2 rounded-2xl overflow-hidden cursor-pointer transition-all duration-300 thumbnail-image-box @activeClass"
                                         data-image-url="@(img.StartsWith("http") ? img : "/" + img.TrimStart('/'))">
                                        <img src="@(img.StartsWith("http") ? img : "/" + img.TrimStart('/'))" 
                                             class="w-full h-full object-cover" 
                                             onerror="this.src='https://placehold.co/100x100/f8fafc/475569?text=Image'"
                                             alt="Thumbnail @(i+1)" />
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="w-full h-[550px] flex flex-col items-center justify-center bg-slate-50 rounded-2xl">
                            <span class="material-symbols-outlined text-7xl text-slate-200">image</span>
                            <span class="text-xs text-slate-400 mt-2 font-bold">@SharedLocalizer["ProductNotAvailable"]</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Info Section (5 columns) -->
            <div class="lg:col-span-5 flex flex-col gap-6">
                <div>
                    @if (!string.IsNullOrEmpty(Model.CategoryName))
                    {
                        <span class="text-xs font-bold text-[#E8A020] uppercase tracking-widest">@Model.CategoryName</span>
                    }
                    <h1 class="font-headline-lg text-slate-800 mt-2 mb-4 leading-snug">@Model.Name</h1>
                    
                    <!-- Glowing Stock Indicator -->
                    <div class="flex items-center gap-2">
                        @if (Model.StockQuantity > 0)
                        {
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                            <span class="text-xs font-bold text-emerald-600">@SharedLocalizer["AvailableForImmediateShipping"]</span>
                        }
                        else
                        {
                            <span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>
                            <span class="text-xs font-bold text-rose-500">@SharedLocalizer["TemporarilyOutOfStock"]</span>
                        }
                    </div>
                </div>
                
                <div class="bg-white border border-slate-100 rounded-3xl p-8 shadow-[0_4px_25px_rgba(0,0,0,0.02)]">
                    <div class="flex items-baseline gap-2 mb-6 justify-start border-b border-slate-50 pb-6">
                        <span class="text-4xl font-extrabold text-slate-900">@Model.RetailPrice.ToString("N2")</span>
                        <span class="text-sm font-bold text-slate-400">@SharedLocalizer["JordanDinarShort"] / @Model.UnitOfMeasure</span>
                        <span class="text-sm font-medium">@SharedLocalizer["VatIncluded"]</span>
                    </div>
                    
                    <form asp-action="AddToCart" asp-controller="ShoppingCart" asp-area="Shop" method="post" class="flex flex-col gap-6">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">@SharedLocalizer["QuantityRequired"]</label>
                            <div class="flex gap-4 items-center">
                                <!-- Modern Quantity Selector -->
                                <div class="flex border border-slate-100 rounded-2xl h-14 overflow-hidden shadow-sm items-center bg-white">
                                    <button type="button" data-quantity-btn="add" class="px-5 h-full text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm font-bold">add</span>
                                    </button>
                                    <input id="quantity-input" class="w-16 border-x border-slate-100 text-center focus:outline-none focus:ring-0 bg-white font-bold text-slate-800 text-base" type="number" name="quantity" value="1" min="1" />
                                    <button type="button" data-quantity-btn="remove" class="px-5 h-full text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors flex items-center justify-center">
                                        <span class="material-symbols-outlined text-sm font-bold">remove</span>
                                    </button>
                                </div>
                                
                                <!-- Modern Add to Cart Button -->
                                <button type="submit" class="flex-1 h-14 bg-[#151B26] hover:bg-[#E8A020] text-white hover:text-[#151B26] font-bold rounded-2xl flex items-center justify-center gap-3 transition-all duration-300 shadow-md active:scale-95">
                                    <span class="material-symbols-outlined text-xl">shopping_cart</span>
                                    <span class="text-sm tracking-wider">@SharedLocalizer["AddToCart"]</span>
                                </button>
                            </div>
                        </div>
                    </form>

                     <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                         <!-- Order via WhatsApp (Direct click to call/chat) -->
                         <a id="btn-whatsapp-order" href="#" target="_blank" class="h-14 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-2xl flex items-center justify-center gap-3 transition-all duration-300 shadow-sm">
                             <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.45L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.963C16.588 1.981 14.117.957 11.5.957c-5.436 0-9.86 4.37-9.864 9.8.001 2.03.547 4.004 1.581 5.793l-1.036 3.793 3.876-.988zm13.102-12.18c-.287-.144-1.702-.84-1.965-.936-.264-.096-.456-.144-.648.144-.192.288-.744.936-.912 1.128-.168.192-.336.216-.624.072-.288-.144-1.216-.448-2.316-1.43-1.04-1.128-1.704-2.52-1.912-2.904-.208-.384-.024-.592.168-.784.173-.173.384-.448.576-.672.192-.224.256-.384.384-.64.128-.256.064-.48-.032-.672-.096-.192-.648-1.56-.888-2.136-.234-.564-.472-.488-.648-.496-.168-.008-.36-.008-.552-.008s-.504.072-.768.36c-.264.288-1.008.984-1.008 2.4s1.032 2.784 1.176 2.976c.144.192 2.032 3.104 4.92 4.352.688.296 1.224.472 1.64.608.696.224 1.328.192 1.832.12.56-.08 1.704-.696 1.944-1.368.24-.672.24-1.248.168-1.368-.072-.12-.264-.216-.552-.36z"/></svg>
                             <span>طلب عبر واتساب</span>
                         </a>
                         
                         <!-- One-Click Fast Quick Order Modal trigger -->
                         <button id="btn-quick-order" type="button" class="h-14 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-2xl flex items-center justify-center gap-3 transition-all duration-300 shadow-sm">
                             <span class="material-symbols-outlined text-lg">bolt</span>
                             <span>شراء سريع بنقرة واحدة</span>
                         </button>
                     </div>
                    
                    <!-- Trust Checkout Badge -->
                    <div class="border-t border-slate-50 pt-6 mt-6 flex flex-wrap gap-4 items-center justify-between text-xs text-slate-400">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base text-slate-300">verified</span>
                            @SharedLocalizer["OriginalAndGuaranteed"]
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base text-slate-300">local_shipping</span>
                            @SharedLocalizer["FastShipping"]
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base text-slate-300">lock</span>
                            @SharedLocalizer["SecurePayment"]
                        </span>
                    </div>
                </div>

                <div class="space-y-6 bg-white border border-slate-100 rounded-3xl p-8 shadow-[0_4px_25px_rgba(0,0,0,0.02)]">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div>
                            <h3 class="font-bold text-slate-800 mb-3 border-s-4 border-[#E8A020] ps-3">@SharedLocalizer["ProductDetails"]</h3>
                            <p class="font-body-md text-slate-500 leading-relaxed">
                                @Model.Description
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-24 bg-white border border-slate-100 rounded-3xl max-w-lg mx-auto shadow-sm">
            <span class="material-symbols-outlined text-7xl text-slate-200 mb-4 animate-bounce">inventory</span>
            <h2 class="font-headline-lg text-slate-800 mb-2">@SharedLocalizer["ProductNotAvailable"]</h2>
            <p class="text-slate-400 mb-8 text-sm">@SharedLocalizer["ProductNotAvailableDesc"]</p>
            <a href="@Url.Action("Index", "Category", new { area = "Shop" })" 
               class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-8 py-4 rounded-xl transition-all shadow-md inline-block">
                @SharedLocalizer["BrowseAlternatives"]
            </a>
        </div>
    }
</main>

@section Scripts {
    <script>
        $(document).ready(function() {
            const quantityInput = $('#quantity-input');
            
            $('[data-quantity-btn="add"]').click(function() {
                let current = parseInt(quantityInput.val());
                quantityInput.val(current + 1);
            });
            
            $('[data-quantity-btn="remove"]').click(function() {
                let current = parseInt(quantityInput.val());
                if (current > 1) {
                    quantityInput.val(current - 1);
                }
            });

            // Thumbnail Click Switch Logic with Smooth Transition
            $('.thumbnail-image-box').click(function() {
                $('.thumbnail-image-box').removeClass('border-[#E8A020] ring-1 ring-[#E8A020]').addClass('border-slate-100');
                $(this).addClass('border-[#E8A020] ring-1 ring-[#E8A020]').removeClass('border-slate-100');
                
                const newUrl = $(this).data('image-url');
                const mainImg = $('#main-product-image');
                
                mainImg.fadeOut(150, function() {
                    mainImg.attr('src', newUrl);
                    mainImg.fadeIn(150);
                });
            });
        });
    </script>
}