@model dynamic
@{
    bool isRoot = ViewBag.IsRoot ?? false;
    var category = ViewBag.Category as Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto;
    ViewData["Title"] = isRoot ? "كافة الفئات" : (category?.Name ?? "الفئة");
}

<main class="max-w-7xl mx-auto px-6 py-8 text-right">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-label-sm font-bold text-on-surface-variant uppercase tracking-wider">
        <a class="hover:text-primary transition-colors" href="/">الرئيسية</a>
        <span class="material-symbols-outlined text-[14px]">chevron_left</span>
        <span class="text-on-surface font-bold">@ViewData["Title"]</span>
    </nav>

    <div class="flex flex-col lg:flex-row-reverse gap-gutter">
        @if (isRoot)
        {
            <!-- Root Categories Grid -->
            <div class="flex-1">
                <h1 class="font-headline-lg text-on-surface mb-8">تصفح الفئات</h1>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter">
                    @foreach (var cat in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)Model)
                    {
                        <div onclick="location.href='@Url.Action("Index", new { id = cat.Id })'" class="group relative aspect-square bg-surface-container overflow-hidden cursor-pointer border border-outline-variant/10 shadow-hard">
                            <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&q=80&w=1000" alt="@cat.Name" />
                            <div class="absolute inset-0 bg-gradient-to-t from-on-surface to-transparent opacity-60"></div>
                            <div class="absolute bottom-6 right-6">
                                <h4 class="font-headline-md text-white">@cat.Name</h4>
                                <span class="text-primary-container font-bold uppercase text-xs">@cat.ProductCount منتج</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- Sidebar Filters -->
            <aside class="w-full lg:w-64 flex-shrink-0 space-y-8">
                <div class="border border-outline-variant p-md bg-white shadow-hard">
                    <h3 class="font-bold text-on-surface uppercase mb-4 flex items-center justify-between">
                        الفلاتر
                        <span class="material-symbols-outlined text-sm">filter_list</span>
                    </h3>
                    <!-- Sub-categories (Placeholder) -->
                    <div class="mb-8">
                        <h4 class="font-bold text-secondary mb-3 uppercase text-[11px]">الفئات الفرعية</h4>
                        <div class="space-y-2">
                            <p class="text-xs text-slate-400 italic">لا توجد فئات فرعية</p>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Product Grid -->
            <div class="flex-1">
                <div class="flex justify-between items-end mb-6">
                    <div>
                        <h1 class="font-headline-lg text-on-surface">@category?.Name</h1>
                        <p class="text-on-surface-variant text-body-md mt-1">@(((IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>)Model).Count()) منتج متاح</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-gutter">
                    @foreach (var product in (IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>)Model)
                    {
                        <partial name="Partials/_ProductCard" model="product" />
                    }
                    @if (!((IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>)Model).Any())
                    {
                        <div class="col-span-3 py-20 text-center text-slate-400 italic">
                            لا توجد منتجات في هذه الفئة حالياً
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</main>
