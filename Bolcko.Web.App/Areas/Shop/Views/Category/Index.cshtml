@{
    ViewData["Title"] = "الفئات";
}
<main class="max-w-7xl mx-auto px-6 py-8 text-right">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-label-sm font-bold text-on-surface-variant uppercase tracking-wider">
        <a class="hover:text-primary transition-colors" href="/">الرئيسية</a>
        <span class="material-symbols-outlined text-[14px]">chevron_left</span>
        <span class="text-on-surface font-bold">مواد البناء</span>
    </nav>

    <div class="flex flex-col lg:flex-row-reverse gap-gutter">
        <!-- Sidebar Filters -->
        <aside class="w-full lg:w-64 flex-shrink-0 space-y-8">
            <div class="border border-outline-variant p-md bg-white shadow-hard">
                <h3 class="font-bold text-on-surface uppercase mb-4 flex items-center justify-between">
                    الفلاتر
                    <span class="material-symbols-outlined text-sm">filter_list</span>
                </h3>
                <!-- Sub-categories -->
                <div class="mb-8">
                    <h4 class="font-bold text-secondary mb-3 uppercase text-[11px]">الفئات</h4>
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input checked="" class="rounded-none border-outline text-primary focus:ring-primary h-4 w-4" type="checkbox" />
                            <span class="text-body-md group-hover:text-primary transition-colors">الأسمنت</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input class="rounded-none border-outline text-primary focus:ring-primary h-4 w-4" type="checkbox" />
                            <span class="text-body-md group-hover:text-primary transition-colors">الرمل والحصى</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input class="rounded-none border-outline text-primary focus:ring-primary h-4 w-4" type="checkbox" />
                            <span class="text-body-md group-hover:text-primary transition-colors">الطوب والبلوك</span>
                        </label>
                    </div>
                </div>
                <!-- Price Range -->
                <div class="mb-8">
                    <h4 class="font-bold text-secondary mb-3 uppercase text-[11px]">نطاق السعر</h4>
                    <div class="space-y-4">
                        <input class="w-full h-1 bg-surface-container-high rounded-lg appearance-none cursor-pointer accent-primary" type="range" />
                        <div class="flex items-center justify-between gap-2">
                            <div class="relative flex-1">
                                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-outline">ر.س</span>
                                <input class="w-full text-xs py-1 pr-8 pl-1 border border-outline-variant bg-surface-container-low font-bold text-right" type="text" value="0" />
                            </div>
                            <span class="text-outline">—</span>
                            <div class="relative flex-1">
                                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-outline">ر.س</span>
                                <input class="w-full text-xs py-1 pr-8 pl-1 border border-outline-variant bg-surface-container-low font-bold text-right" type="text" value="5000" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <div class="flex-1">
            <div class="flex justify-between items-end mb-6">
                <div>
                    <h1 class="font-headline-lg text-on-surface">مواد البناء</h1>
                    <p class="text-on-surface-variant text-body-md mt-1">عرض 1-12 من 84 منتج</p>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-label-sm font-bold text-secondary uppercase">ترتيب حسب:</span>
                    <select class="border-none bg-transparent font-bold text-on-surface focus:ring-0 cursor-pointer">
                        <option>الأحدث</option>
                        <option>السعر: من الأقل للأعلى</option>
                        <option>السعر: من الأعلى للأقل</option>
                        <option>الأكثر شعبية</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-gutter">
                <!-- Product Card 1 -->
                <div onclick="location.href='@Url.Action("Index", "Product", new { area = "Shop" })'" class="bg-white border border-outline-variant group hover:border-primary transition-all duration-300 shadow-hard cursor-pointer">
                    <div class="aspect-[4/3] overflow-hidden bg-surface-container-low relative">
                        <img alt="Premium Portland Cement" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&q=80&w=1000" />
                        <div class="absolute top-2 right-2 bg-primary-container text-on-primary-container px-2 py-1 text-[10px] font-bold uppercase tracking-widest">متوفر</div>
                    </div>
                    <div class="p-4 space-y-3">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-[10px] font-bold text-secondary uppercase tracking-tighter">SKU: PC-001-50KG</p>
                                <h3 class="font-headline-md text-body-lg text-on-surface leading-tight mt-1">أسمنت بورتلاندي ممتاز</h3>
                            </div>
                            <span class="material-symbols-outlined text-outline cursor-pointer hover:text-error transition-colors">favorite</span>
                        </div>
                        <div class="flex items-center gap-2 text-label-sm font-bold text-on-surface-variant">
                            <span class="material-symbols-outlined text-sm">weight</span>
                            كيس 50 كجم
                        </div>
                        <div class="flex items-baseline gap-2">
                            <span class="text-headline-md font-bold text-on-surface">14.50 ر.س</span>
                            <span class="text-xs text-outline line-through">18.00 ر.س</span>
                        </div>
                        <div class="grid grid-cols-2 gap-2 pt-2">
                            <button onclick="event.stopPropagation();" class="bg-primary-container text-on-primary-container py-3 font-bold text-xs uppercase shadow-hard hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-sm">shopping_cart</span>
                                أضف للسلة
                            </button>
                            <button onclick="event.stopPropagation();" class="bg-on-surface text-white py-3 font-bold text-xs uppercase shadow-hard hover:bg-slate-800 active:scale-95 transition-all">
                                اطلب سعر
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Product Card 2 (Bulk Only) -->
                <div class="bg-white border border-outline-variant group hover:border-primary transition-all duration-300 shadow-hard">
                    <div class="aspect-[4/3] overflow-hidden bg-surface-container-low relative">
                        <img alt="Washed River Sand" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://images.unsplash.com/photo-1516216628859-9bccecad13f7?auto=format&fit=crop&q=80&w=1000" />
                        <div class="absolute top-2 right-2 bg-secondary text-white px-2 py-1 text-[10px] font-bold uppercase tracking-widest">كميات فقط</div>
                    </div>
                    <div class="p-4 space-y-3">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-[10px] font-bold text-secondary uppercase tracking-tighter">SKU: SND-RIV-M3</p>
                                <h3 class="font-headline-md text-body-lg text-on-surface leading-tight mt-1">رمل وادي مغسول</h3>
                            </div>
                            <span class="material-symbols-outlined text-outline cursor-pointer hover:text-error transition-colors">favorite</span>
                        </div>
                        <div class="flex items-center gap-2 text-label-sm font-bold text-on-surface-variant">
                            <span class="material-symbols-outlined text-sm">square_foot</span>
                            متر مكعب
                        </div>
                        <div class="flex items-baseline gap-2">
                            <span class="text-headline-md font-bold text-on-surface">السعر حسب الكمية</span>
                        </div>
                        <div class="grid grid-cols-1 gap-2 pt-2">
                            <a href="@Url.Action("Request", "Quote", new { area = "Shop" })" class="bg-on-surface text-white py-3 font-bold text-xs uppercase shadow-hard hover:bg-slate-800 active:scale-95 transition-all flex items-center justify-center gap-2 w-full">
                                <span class="material-symbols-outlined text-sm">request_quote</span>
                                اطلب عرض سعر للكميات
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="mt-12 flex justify-center gap-2">
                <button class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-white transition-colors">1</button>
                <button class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-white transition-colors">2</button>
                <button class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-white transition-colors">3</button>
                <button class="w-10 h-10 border border-outline-variant flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
            </div>
        </div>
    </div>
</main>