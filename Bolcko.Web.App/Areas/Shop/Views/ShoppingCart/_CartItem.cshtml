@model Bolcko.Domain.Entities.ShoppingCart.DTOs.ShoppingCartItemDto
@{
    var imgSrc = string.IsNullOrEmpty(Model.ProductImage)
        ? null
        : (Model.ProductImage.StartsWith("http") ? Model.ProductImage : "/" + Model.ProductImage.TrimStart('/'));

    var stockClass = Model.StockQuantity > 0
        ? "bg-green-100 text-green-800 border-green-200"
        : "bg-red-100 text-red-800 border-red-200";

    var stockLabel = Model.StockQuantity > 0
        ? SharedLocalizer["InStock"].Value
        : SharedLocalizer["OutOfStock"].Value;
}

<div id="item-card-@Model.Id"
     class="bg-white border border-outline-variant flex flex-col md:flex-row-reverse overflow-hidden shadow-hard">

    @* Product Image *@
    <div class="w-full md:w-48 h-48 bg-surface-variant flex-shrink-0">
        @if (imgSrc != null)
        {
            <img alt="@Model.ProductName"
                 class="w-full h-full object-cover"
                 src="@imgSrc"
                 width="192" height="192" loading="lazy" decoding="async"
                 onerror="this.src='https://placehold.co/400x400/e2e8f0/475569?text=@(Uri.EscapeDataString(Model.ProductName))'" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center bg-slate-100">
                <span class="material-symbols-outlined text-4xl text-slate-300">image</span>
            </div>
        }
    </div>

    @* Product Details *@
    <div class="p-md flex-grow flex flex-col justify-between">

        <div>
            @* Name + Delete *@
            <div class="flex justify-between items-start">
                <h3 class="font-headline-md text-on-surface uppercase">@Model.ProductName</h3>
                <form asp-action="RemoveItem" asp-controller="ShoppingCart" asp-area="Shop" method="post">
                    <input type="hidden" name="itemId" value="@Model.Id" />
                    <button type="submit" class="text-outline hover:text-error transition-colors">
                        <span class="material-symbols-outlined">delete</span>
                    </button>
                </form>
            </div>

            @* SKU *@
            <p class="mt-2 font-bold text-xs text-outline-variant uppercase">
                SKU: <span class="text-on-surface-variant">@Model.ProductSku</span>
            </p>

            @* Stock badge *@
            <div class="mt-3">
                <span class="inline-block @stockClass text-[10px] font-bold px-2 py-1 uppercase rounded-sm border">
                    @stockLabel
                </span>
            </div>
        </div>

        @* Quantity + Subtotal *@
        <div class="mt-6 flex flex-wrap justify-between items-end">

            <div class="flex items-center border border-outline shadow-hard">
                <button type="button" data-decrement="@Model.Id"
                        class="px-3 py-1 font-bold border-l border-outline hover:bg-surface-container-high transition-colors">
                    -
                </button>
                <input id="quantity-@Model.Id"
                       type="number"
                       data-item-id="@Model.Id"
                       value="@Model.Quantity"
                       min="0"
                       class="w-16 border-x border-outline text-center focus:ring-0 bg-white font-bold" />
                <button type="button" data-increment="@Model.Id"
                        class="px-3 py-1 font-bold border-r border-outline hover:bg-surface-container-high transition-colors">
                    +
                </button>
                <span id="spinner-@Model.Id" class="hidden ml-2">
                    <span class="material-symbols-outlined text-base animate-spin text-primary">progress_activity</span>
                </span>
            </div>

            <div class="text-left">
                <p class="font-bold text-xs text-outline uppercase mb-1">@SharedLocalizer["Subtotal"]</p>
                <p id="subtotal-@Model.Id" class="font-headline-md text-on-surface">
                    @Model.TotalPrice.ToString("N2") <span class="text-sm">د.أ</span>
                </p>
            </div>

        </div>
    </div>

</div>
