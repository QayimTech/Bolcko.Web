@{
    ViewData["Title"] = "سلة التسوق";
}
<main class="max-w-7xl mx-auto px-6 py-12 text-right">
    <!-- Header -->
    <header class="mb-12 border-r-4 border-primary-container pr-6">
        <h1 class="font-headline-xl text-on-surface uppercase mb-2">سلة التسوق</h1>
        <p class="font-body-lg text-secondary">لديك منتجان في سلة التسوق الخاصة بك.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        <!-- Cart Items Section -->
        <div class="lg:col-span-8 space-y-6">
            <!-- Item 1 -->
            <div class="bg-white border border-outline-variant flex flex-col md:flex-row-reverse overflow-hidden shadow-hard">
                <div class="w-full md:w-48 h-48 bg-surface-variant flex-shrink-0">
                    <img alt="Concrete Blocks" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1590069230005-db3937f91f30?auto=format&fit=crop&q=80&w=400" />
                </div>
                <div class="p-md flex-grow flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start">
                            <h3 class="font-headline-md text-on-surface uppercase">بلوك أسمنتي قياسي</h3>
                            <button class="text-outline hover:text-error transition-colors">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                        <div class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1">
                            <p class="font-bold text-xs text-outline-variant uppercase">SKU: <span class="text-on-surface-variant">BLK-500-STD</span></p>
                            <p class="font-bold text-xs text-outline-variant uppercase">المواصفات: <span class="text-on-surface-variant">20x20x40سم</span></p>
                        </div>
                        <div class="mt-3">
                            <span class="inline-block bg-green-100 text-green-800 text-[10px] font-bold px-2 py-1 uppercase rounded-sm border border-green-200">متوفر</span>
                        </div>
                    </div>
                    <div class="mt-6 flex flex-wrap justify-between items-end">
                        <div class="flex items-center border border-outline shadow-hard">
                            <button type="button" data-quantity-btn="add" class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-l border-outline">+</button>
                            <span class="px-6 py-1 font-bold text-on-surface">
                                <input class="w-12 text-center border-none bg-transparent p-0 focus:ring-0" type="number" value="500" />
                            </span>
                            <button type="button" data-quantity-btn="remove" class="px-3 py-1 hover:bg-surface-container-high transition-colors font-bold border-r border-outline">-</button>
                        </div>
                        <div class="text-left">
                            <p class="font-bold text-xs text-outline uppercase mb-1">المجموع الفرعي</p>
                            <p class="font-headline-md text-on-surface">2,500.00 <span class="text-sm">ر.س</span></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trust Badges -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter py-8">
                <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low shadow-hard">
                    <span class="material-symbols-outlined text-primary text-3xl">verified</span>
                    <div>
                        <h4 class="font-bold text-on-surface uppercase">جودة مضمونة</h4>
                        <p class="text-xs text-outline uppercase">مواد متوافقة مع المواصفات السعودية</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low shadow-hard">
                    <span class="material-symbols-outlined text-primary text-3xl">local_shipping</span>
                    <div>
                        <h4 class="font-bold text-on-surface uppercase">توصيل للموقع</h4>
                        <p class="text-xs text-outline uppercase">إلى أي موقع إنشائي رئيسي</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary Section -->
        <div class="lg:col-span-4">
            <div class="bg-white border-2 border-on-background p-md shadow-hard sticky top-24">
                <h2 class="font-headline-md text-on-surface uppercase mb-6 pb-2 border-b-2 border-primary-container">ملخص الطلب</h2>
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between items-center">
                        <span class="text-outline-variant">المجموع الفرعي</span>
                        <span class="font-bold text-on-surface">6,100.00 ر.س</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-outline-variant">ضريبة القيمة المضافة (15%)</span>
                        <span class="font-bold text-on-surface">915.00 ر.س</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-outline-variant">الشحن التقديري</span>
                        <span class="font-bold text-on-surface">250.00 ر.س</span>
                    </div>
                    <div class="pt-4 border-t border-outline-variant flex justify-between items-center">
                        <span class="font-headline-md text-on-surface uppercase">الإجمالي</span>
                        <span class="font-headline-md text-primary">7,265.00 ر.س</span>
                    </div>
                </div>
                
                <!-- CTA -->
                <a href="@Url.Action("Checkout", "ShoppingCart", new { area = "Shop" })" class="w-full bg-primary-container text-on-primary-container font-bold py-4 flex items-center justify-center gap-2 uppercase shadow-hard hover:opacity-90 transition-all">
                    إتمام الطلب
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                
                <div class="mt-6 flex flex-col items-center gap-4 border-t border-outline-variant pt-6">
                    <p class="text-xs text-outline-variant uppercase">نقبل الدفع الآمن عبر</p>
                    <div class="flex gap-4 opacity-50 grayscale">
                        <span class="material-symbols-outlined">credit_card</span>
                        <span class="material-symbols-outlined">account_balance</span>
                        <span class="material-symbols-outlined">payments</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>