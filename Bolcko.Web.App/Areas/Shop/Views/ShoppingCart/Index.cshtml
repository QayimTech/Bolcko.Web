@model Bolcko.Domain.Entities.ShoppingCart.DTOs.ShoppingCartDto
@{
    ViewData["Title"] = SharedLocalizer["ShoppingCartTitle"];
}

<main class="max-w-7xl mx-auto px-6 py-12 text-start">

    @* CSRF token for AJAX *@
    <form id="ajaxTokenForm">@Html.AntiForgeryToken()</form>

    <header class="mb-12 border-e-4 border-primary-container pe-6">
        <h1 class="font-headline-xl text-on-surface uppercase mb-2">@SharedLocalizer["ShoppingCartTitle"]</h1>
        <p id="cart-item-count-text" class="font-body-lg text-secondary">
            @string.Format(SharedLocalizer["CartItemCount"], Model.TotalItems)
        </p>
    </header>

    @if (Model.Items.Any())
    {
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">

            <div class="lg:col-span-8 space-y-6">

                @foreach (var item in Model.Items)
                {
                    @await Html.PartialAsync("_CartItem", item)
                }

                @* Trust Badges *@
                <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter py-8">
                    <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low shadow-hard">
                        <span class="material-symbols-outlined text-primary text-3xl">verified</span>
                        <div>
                            <h4 class="font-bold text-on-surface uppercase">@SharedLocalizer["QualityGuaranteed"]</h4>
                            <p class="text-xs text-outline uppercase">@SharedLocalizer["QualityGuaranteedDesc"]</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-4 border border-outline-variant bg-surface-container-low shadow-hard">
                        <span class="material-symbols-outlined text-primary text-3xl">local_shipping</span>
                        <div>
                            <h4 class="font-bold text-on-surface uppercase">@SharedLocalizer["SiteDelivery"]</h4>
                            <p class="text-xs text-outline uppercase">@SharedLocalizer["SiteDeliveryDesc"]</p>
                        </div>
                    </div>
                </div>

            </div>

            <div class="lg:col-span-4">
                @await Html.PartialAsync("_CartSummary", Model)
            </div>

        </div>
    }
    else
    {
        @await Html.PartialAsync("_CartEmpty")
    }

    @await Html.PartialAsync("_RemoveModal")

</main>

@section Scripts {
    <script>
        window.CartConfig = {
            updateUrl: '@Url.Action("UpdateItemAjax", "ShoppingCart", new { area = "Shop" })'
        };
    </script>
    <script src="~/js/cart.js"></script>
}