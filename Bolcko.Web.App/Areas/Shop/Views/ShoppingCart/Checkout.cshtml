@model Bolcko.Domain.Entities.Order.DTOs.CheckoutDto
@{
    ViewData["Title"] = SharedLocalizer["CheckoutTitle"];
}
<main class="max-w-7xl mx-auto px-6 py-12 text-start">
    <header class="mb-12 border-e-4 border-primary-container pe-6">
        <h1 class="font-headline-xl text-on-surface uppercase mb-2">@SharedLocalizer["CheckoutTitle"]</h1>
        <p class="font-body-lg text-secondary">@SharedLocalizer["ShippingDeliveryInfo"]</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
        <!-- Checkout Form -->
        <div class="lg:col-span-8">
            <form id="checkoutForm" asp-action="PlaceOrder" asp-controller="ShoppingCart" method="post" class="space-y-8">
                <!-- Customer Info -->
                <div class="bg-white border border-outline-variant p-8 shadow-hard">
                    <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">@SharedLocalizer["CustomerInfo"]</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["FullName"]</label>
                            <input asp-for="FullName" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="@SharedLocalizer["EnterFullName"]" />
                            <span asp-validation-for="FullName" class="text-error text-xs"></span>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Phone"]</label>
                            <input asp-for="Phone" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="tel" placeholder="05xxxxxxxx" />
                            <span asp-validation-for="Phone" class="text-error text-xs"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Email"]</label>
                            <input asp-for="Email" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="email" placeholder="example@mail.com" />
                            <span asp-validation-for="Email" class="text-error text-xs"></span>
                        </div>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="bg-white border border-outline-variant p-8 shadow-hard">
                    <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">@SharedLocalizer["ShippingAddress"]</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["City"]</label>
                            <select asp-for="City" id="checkout-city-select" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start">
                                @if (ViewBag.ShippingRates != null)
                                {
                                    foreach (var rate in (IEnumerable<Bolcko.Domain.Entities.Setting.ShippingRate>)ViewBag.ShippingRates)
                                    {
                                        <option value="@rate.CityName" data-rate="@rate.Rate.ToString("F2")">@rate.CityName</option>
                                    }
                                }
                                else
                                {
                                    <option value="عمان" data-rate="3.00">@SharedLocalizer["Amman"]</option>
                                    <option value="الزرقاء" data-rate="4.00">@SharedLocalizer["Zarqa"]</option>
                                    <option value="إربد" data-rate="5.00">@SharedLocalizer["Irbid"]</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Area"]</label>
                            <input asp-for="Area" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="text" placeholder="@SharedLocalizer["EnterArea"]" />
                            <span asp-validation-for="Area" class="text-error text-xs"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["DetailedAddress"]</label>
                            <textarea asp-for="DetailedAddress" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start h-24" placeholder="@SharedLocalizer["EnterDetailedAddress"]"></textarea>
                            <span asp-validation-for="DetailedAddress" class="text-error text-xs"></span>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Country"]</label>
                            <input asp-for="Country" value="@SharedLocalizer["Jordan"]" readonly class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start text-outline-variant" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["PostalCode"]</label>
                            <input asp-for="PostalCode" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="text" placeholder="11111" />
                            <span asp-validation-for="PostalCode" class="text-error text-xs"></span>
                        </div>
                    </div>
                </div>

                <!-- Project Info (Optional) -->
                <div class="bg-white border border-outline-variant p-8 shadow-hard">
                    <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">@SharedLocalizer["ProjectInfo"]</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["ProjectName"]</label>
                            <input asp-for="ProjectName" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="text" placeholder="@SharedLocalizer["EnterProjectName"]" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["ProjectType"]</label>
                            <select asp-for="ProjectType" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start">
                                <option value="سكني">@SharedLocalizer["Residential"]</option>
                                <option value="تجاري">@SharedLocalizer["Commercial"]</option>
                                <option value="صناعي">@SharedLocalizer["Industrial"]</option>
                            </select>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Notes"]</label>
                            <textarea asp-for="Notes" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start h-24" placeholder="@SharedLocalizer["EnterNotes"]"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="bg-white border border-outline-variant p-8 shadow-hard">
                    <h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-2">@SharedLocalizer["PaymentMethod"]</h2>
                    <div class="flex items-center gap-4 border border-primary p-4 bg-primary-container bg-opacity-10 cursor-pointer">
                        <input asp-for="PaymentMethod" type="radio" value="COD" checked class="w-5 h-5 text-primary focus:ring-primary" id="cod" />
                        <label for="cod" class="font-bold text-on-surface flex-grow cursor-pointer">
                            @SharedLocalizer["CodLabel"]
                            <span class="block text-xs font-normal text-secondary mt-1">@SharedLocalizer["CodDesc"]</span>
                        </label>
                        <span class="material-symbols-outlined text-primary text-3xl">payments</span>
                    </div>
                </div>
            </form>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-4">
            <div class="bg-white border-2 border-on-background p-md shadow-hard sticky top-24">
                <h2 class="font-headline-md text-on-surface uppercase mb-6 pb-2 border-b-2 border-primary-container">@SharedLocalizer["OrderSummary"]</h2>
                <div class="space-y-4 mb-8">
                    <!-- Mini Cart Items -->
                    @if (ViewBag.Cart != null)
                    {
                        var cart = (Bolcko.Domain.Entities.ShoppingCart.DTOs.ShoppingCartDto)ViewBag.Cart;
                        foreach (var item in cart.Items)
                        {
                            <div class="flex gap-4 border-b border-outline-variant pb-4">
                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                {
                                    <img class="w-16 h-16 object-cover" src="@item.ProductImage" alt="@item.ProductName" width="64" height="64" loading="lazy" decoding="async" />
                                }
                                else
                                {
                                    <div class="w-16 h-16 bg-surface-container-high flex items-center justify-center text-outline">
                                        <span class="material-symbols-outlined">image</span>
                                    </div>
                                }
                                <div class="flex-grow">
                                    <h4 class="font-bold text-xs">@item.ProductName</h4>
                                    <p class="text-[10px] text-outline-variant">@string.Format(SharedLocalizer["UnitsCount"], item.Quantity)</p>
                                    <p class="font-bold text-xs">@item.TotalPrice.ToString("N2") @SharedLocalizer["JordanDinarShort"]</p>
                                </div>
                            </div>
                        }
                        
                        <div class="flex justify-between items-center pt-2">
                            <span class="text-outline-variant text-sm">@SharedLocalizer["Subtotal"]</span>
                            <span class="font-bold"><span id="checkout-subtotal-val">@cart.Subtotal.ToString("F2")</span> @SharedLocalizer["JordanDinarShort"]</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-outline-variant text-sm">@SharedLocalizer["ShippingEstimated"]</span>
                            <span class="font-bold"><span id="checkout-shipping-val">@cart.Shipping.ToString("F2")</span> @SharedLocalizer["JordanDinarShort"]</span>
                        </div>
                        <div class="flex justify-between items-center border-b border-outline-variant pb-4">
                            <span class="text-outline-variant text-sm">@SharedLocalizer["Tax"]</span>
                            <span class="font-bold"><span id="checkout-tax-val">@cart.Tax.ToString("F2")</span> @SharedLocalizer["JordanDinarShort"]</span>
                        </div>
                        <div class="flex justify-between items-center pt-4">
                            <span class="text-outline-variant font-bold">@SharedLocalizer["Total"]</span>
                            <span class="font-headline-md text-primary"><span id="checkout-total-val">@cart.Total.ToString("F2")</span> @SharedLocalizer["JordanDinarShort"]</span>
                        </div>
                    }
                </div>
                
                <button type="submit" form="checkoutForm" class="w-full bg-primary text-white font-bold py-4 flex items-center justify-center gap-2 uppercase shadow-hard hover:opacity-90 transition-all">
                    @SharedLocalizer["ConfirmAndSendOrder"]
                    <span class="material-symbols-outlined">check_circle</span>
                </button>
                
                <p class="mt-4 text-[10px] text-outline-variant text-center">@SharedLocalizer["AcceptTermsText"]</p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('#checkout-city-select').on('change', function () {
                var selectedOption = $(this).find('option:selected');
                var rate = parseFloat(selectedOption.data('rate')) || 0.0;
                
                // Read current values
                var subtotal = parseFloat($('#checkout-subtotal-val').text()) || 0.0;
                var tax = parseFloat($('#checkout-tax-val').text()) || 0.0;
                
                // Update UI values
                $('#checkout-shipping-val').text(rate.toFixed(2));
                
                var total = subtotal + tax + rate;
                $('#checkout-total-val').text(total.toFixed(2));
            });
        });
    </script>
}