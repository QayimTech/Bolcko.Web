@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<Bolcko.Web.App.SharedResource> SharedLocalizer

<div id="removeModal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">

    <div id="removeModalBackdrop"
         class="fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity opacity-0">
    </div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-4">

            <div id="removeModalPanel"
                 class="relative w-full max-w-lg bg-white rounded-2xl shadow-2xl text-start transition-all opacity-0 translate-y-4 scale-95">

                <div class="px-6 pt-6 pb-4">
                    <div class="flex items-start gap-4">
                        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-red-100">
                            <span class="material-symbols-outlined text-red-600">warning</span>
                        </div>
                        <div>
                            <h3 id="modal-title" class="text-base font-bold text-gray-900">
                                @SharedLocalizer["RemoveFromCartTitle"]
                            </h3>
                            <p class="mt-1 text-sm text-gray-500">
                                @SharedLocalizer["RemoveFromCartConfirm"]
                            </p>
                        </div>
                    </div>
                </div>

                <div class="flex gap-2 bg-gray-50 px-6 py-4 rounded-b-2xl justify-end">
                    <button id="btnCancelRemove" type="button"
                            class="px-4 py-2 text-sm font-semibold text-gray-900 bg-white rounded-lg shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 transition-colors">
                        @SharedLocalizer["CancelRemove"]
                    </button>
                    <button id="btnConfirmRemove" type="button"
                            class="px-4 py-2 text-sm font-semibold text-white bg-red-600 rounded-lg shadow-sm hover:bg-red-500 transition-colors">
                        @SharedLocalizer["ConfirmRemove"]
                    </button>
                </div>

            </div>
        </div>
    </div>

</div>
