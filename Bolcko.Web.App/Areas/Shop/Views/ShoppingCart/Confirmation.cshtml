@model Bolcko.Domain.Entities.Order.DTOs.OrderDto
@{
    ViewData["Title"] = SharedLocalizer["OrderConfirmed"];
}
<main class="max-w-3xl mx-auto px-6 py-24 text-center">
    <div class="bg-white border border-outline-variant p-12 shadow-hard">
        <span class="material-symbols-outlined text-primary text-7xl mb-6" style="font-variation-settings: 'wght' 200">check_circle</span>
        <h1 class="font-headline-xl text-on-surface mb-4">@SharedLocalizer["OrderConfirmed"]</h1>
        <p class="text-body-lg text-secondary mb-8">@string.Format(SharedLocalizer["YourOrderNumberIs"].Value, Model?.OrderNumber)</p>
        <p class="text-body-lg text-secondary mb-4">@string.Format(SharedLocalizer["TotalAmount"].Value, Model?.TotalAmount.ToString("N2") + " " + SharedLocalizer["JordanDinarShort"].Value)</p>
        
        @if(Model?.Items != null && Model.Items.Any())
        {
            <div class="bg-surface-container-low p-6 mb-8 text-start text-sm">
                <h4 class="font-bold mb-4 border-b border-outline-variant pb-2">@SharedLocalizer["OrderDetails"]</h4>
                @foreach (var item in Model.Items)
                {
                    <div class="flex justify-between mb-2">
                        <span>@item.Quantity x @item.ProductName</span>
                    </div>
                }
            </div>
        }

        @if(Model?.PaymentMethod == "COD")
        {
            <div class="bg-primary-container bg-opacity-20 p-4 border border-primary mb-8 text-start">
                <p class="font-bold text-primary">@SharedLocalizer["PaymentMethod"]: @SharedLocalizer["CodLabel"]</p>
                <p class="text-xs text-secondary mt-1">@SharedLocalizer["CodDesc"]</p>
            </div>
        }
        
        <div class="bg-surface-container-low p-6 border-e-4 border-primary text-start mb-12">
            <h3 class="font-bold text-on-surface mb-2">@SharedLocalizer["WhatHappensNow"]</h3>
            <ul class="space-y-3 text-sm text-on-surface-variant">
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    @SharedLocalizer["Step1Text"]
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    @SharedLocalizer["Step2Text"]
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    @SharedLocalizer["Step3Text"]
                </li>
            </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="@Url.Action("Index", "Category", new { area = "Shop" })" class="bg-primary-container text-on-primary-container font-bold px-8 py-4 uppercase shadow-hard hover:opacity-90 transition-all">
                @SharedLocalizer["ContinueShopping"]
            </a>
            <a href="@Url.Action("Index", "Account", new { area = "Shop" })" class="bg-on-surface text-white font-bold px-8 py-4 uppercase shadow-hard hover:bg-slate-800 transition-all">
                @SharedLocalizer["TrackOrder"]
            </a>
        </div>
    </div>
</main>