@model Bolcko.Domain.Entities.Order.DTOs.OrderDto
@{
    ViewData["Title"] = "تأكيد الطلب";
}
<main class="max-w-3xl mx-auto px-6 py-24 text-center">
    <div class="bg-white border border-outline-variant p-12 shadow-hard">
        <span class="material-symbols-outlined text-primary text-7xl mb-6" style="font-variation-settings: 'wght' 200">check_circle</span>
        <h1 class="font-headline-xl text-on-surface mb-4">تم استلام طلبك بنجاح!</h1>
        <p class="text-body-lg text-secondary mb-8">رقم الطلب الخاص بك هو: <span class="font-bold text-on-surface">@Model?.OrderNumber</span></p>
        <p class="text-body-lg text-secondary mb-4">إجمالي المبلغ: <span class="font-bold text-on-surface">@Model?.TotalAmount.ToString("N2") د.أ</span></p>
        
        @if(Model?.Items != null && Model.Items.Any())
        {
            <div class="bg-surface-container-low p-6 mb-8 text-right text-sm">
                <h4 class="font-bold mb-4 border-b border-outline-variant pb-2">تفاصيل الطلب</h4>
                @foreach (var item in Model.Items)
                {
                    <div class="flex justify-between mb-2">
                        <span>@item.Quantity x @item.ProductName (أو ما يعادله)</span>
                    </div>
                }
            </div>
        }

        @if(Model?.PaymentMethod == "COD")
        {
            <div class="bg-primary-container bg-opacity-20 p-4 border border-primary mb-8">
                <p class="font-bold text-primary">طريقة الدفع: الدفع عند الاستلام</p>
                <p class="text-xs text-secondary mt-1">يرجى تجهيز المبلغ المطلوب عند استلام الطلبية.</p>
            </div>
        }
        
        <div class="bg-surface-container-low p-6 border-r-4 border-primary text-right mb-12">
            <h3 class="font-bold text-on-surface mb-2">ماذا يحدث الآن؟</h3>
            <ul class="space-y-3 text-sm text-on-surface-variant">
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    سيقوم فريقنا بمراجعة طلبك والتأكد من توفر المواد.
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    سنتواصل معك هاتفياً لتأكيد موعد التوصيل الدقيق لموقعك.
                </li>
                <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm text-primary">circle</span>
                    ستصلك رسالة نصية وبريد إلكتروني عند تحديث حالة الطلب.
                </li>
            </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="@Url.Action("Index", "Category", new { area = "Shop" })" class="bg-primary-container text-on-primary-container font-bold px-8 py-4 uppercase shadow-hard hover:opacity-90 transition-all">
                متابعة التسوق
            </a>
            <a href="@Url.Action("Index", "Account", new { area = "Shop" })" class="bg-on-surface text-white font-bold px-8 py-4 uppercase shadow-hard hover:bg-slate-800 transition-all">
                تتبع الطلب
            </a>
        </div>
    </div>
</main>