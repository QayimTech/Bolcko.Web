@{
    ViewData["Title"] = "حسابي";
}
<main class="max-w-7xl mx-auto px-6 py-12 text-right">
    <div class="flex flex-col lg:flex-row-reverse gap-gutter">
        <!-- Sidebar Navigation -->
        <aside class="w-full lg:w-64 flex-shrink-0">
            <div class="bg-white border border-outline-variant shadow-hard overflow-hidden">
                <div class="bg-on-surface p-6 text-white text-center">
                    <div class="w-20 h-20 bg-primary-container rounded-full mx-auto mb-4 flex items-center justify-center">
                        <span class="material-symbols-outlined text-4xl text-on-primary-container">person</span>
                    </div>
                    <h2 class="font-bold">أحمد محمد</h2>
                    <p class="text-xs text-slate-400">عميل مميز</p>
                </div>
                <nav class="p-4">
                    <ul class="space-y-2">
                        <li>
                            <a href="@Url.Action("Index", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 bg-surface-container-low border-r-4 border-primary font-bold text-on-surface">
                                <span>لوحة التحكم</span>
                                <span class="material-symbols-outlined text-sm">dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Orders", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>طلباتي</span>
                                <span class="material-symbols-outlined text-sm">shopping_bag</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Quotes", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>عروض الأسعار</span>
                                <span class="material-symbols-outlined text-sm">request_quote</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Projects", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>مشاريعي</span>
                                <span class="material-symbols-outlined text-sm">architecture</span>
                            </a>
                        </li>
                        <li class="pt-4 mt-4 border-t border-outline-variant">
                            <a href="#" class="flex items-center justify-between p-3 text-error hover:bg-error-container transition-colors">
                                <span>تسجيل الخروج</span>
                                <span class="material-symbols-outlined text-sm">logout</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 space-y-8">
            <header class="border-r-4 border-primary-container pr-6 mb-8">
                <h1 class="font-headline-xl text-on-surface uppercase mb-2">لوحة التحكم</h1>
                <p class="font-body-lg text-secondary">مرحباً بك مجدداً، أحمد. إليك ملخص لنشاطك الأخير.</p>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white border border-outline-variant p-6 shadow-hard text-center">
                    <span class="material-symbols-outlined text-primary text-4xl mb-2">shopping_bag</span>
                    <h3 class="text-2xl font-bold text-on-surface">12</h3>
                    <p class="text-xs text-on-surface-variant uppercase font-bold">طلب مكتمل</p>
                </div>
                <div class="bg-white border border-outline-variant p-6 shadow-hard text-center">
                    <span class="material-symbols-outlined text-primary text-4xl mb-2">request_quote</span>
                    <h3 class="text-2xl font-bold text-on-surface">3</h3>
                    <p class="text-xs text-on-surface-variant uppercase font-bold">عروض أسعار نشطة</p>
                </div>
                <div class="bg-white border border-outline-variant p-6 shadow-hard text-center">
                    <span class="material-symbols-outlined text-primary text-4xl mb-2">architecture</span>
                    <h3 class="text-2xl font-bold text-on-surface">5</h3>
                    <p class="text-xs text-on-surface-variant uppercase font-bold">مشاريع مسجلة</p>
                </div>
            </div>

            <!-- Recent Orders Table -->
            <div class="bg-white border border-outline-variant shadow-hard overflow-hidden">
                <div class="p-6 border-b border-outline-variant flex justify-between items-center">
                    <h2 class="font-bold text-on-surface uppercase">آخر الطلبات</h2>
                    <a href="/Shop/Account/Orders" class="text-xs text-primary font-bold hover:underline">عرض الكل</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-right">
                        <thead class="bg-surface-container-low text-xs font-bold text-on-surface-variant uppercase">
                            <tr>
                                <th class="p-4">رقم الطلب</th>
                                <th class="p-4">التاريخ</th>
                                <th class="p-4">المبلغ</th>
                                <th class="p-4">الحالة</th>
                                <th class="p-4">الإجراء</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            <tr class="border-b border-outline-variant hover:bg-surface-container-lowest transition-colors">
                                <td class="p-4 font-bold">#BLK-98721</td>
                                <td class="p-4">2024/05/01</td>
                                <td class="p-4">7,265.00 ر.س</td>
                                <td class="p-4">
                                    <span class="bg-amber-100 text-amber-800 px-2 py-1 text-[10px] font-bold uppercase rounded-sm border border-amber-200">قيد المراجعة</span>
                                </td>
                                <td class="p-4">
                                    <button class="text-primary font-bold hover:underline">التفاصيل</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>