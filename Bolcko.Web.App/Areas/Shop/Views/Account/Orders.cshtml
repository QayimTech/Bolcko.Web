@using Bolcko.Domain.Entities.User
@using Bolcko.Domain.Entities.Order.DTOs
@using Bolcko.Domain.Enums
@model IEnumerable<OrderDto>
@{
    ViewData["Title"] = "طلباتي";
    var user = ViewBag.User as User;
}
<main class="max-w-7xl mx-auto px-6 py-12 text-right">
    <div class="flex flex-col lg:flex-row-reverse gap-gutter">
        <!-- Sidebar Navigation -->
        <aside class="w-full lg:w-64 flex-shrink-0">
            <div class="bg-white border border-outline-variant shadow-hard overflow-hidden">
                <div class="bg-on-surface p-6 text-white text-center">
                    <div class="w-20 h-20 bg-primary-container rounded-full mx-auto mb-4 flex items-center justify-center">
                        <span class="material-symbols-outlined text-4xl text-on-primary-container">person</span>
                    </div>
                    <h2 class="font-bold">@(user?.FirstName + " " + user?.LastName)</h2>
                    <p class="text-xs text-slate-400">@user?.UserType.ToString()</p>
                </div>
                <nav class="p-4">
                    <ul class="space-y-2">
                        <li>
                            <a href="@Url.Action("Index", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>لوحة التحكم</span>
                                <span class="material-symbols-outlined text-sm">dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Orders", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 bg-surface-container-low border-r-4 border-primary font-bold text-on-surface">
                                <span>طلباتي</span>
                                <span class="material-symbols-outlined text-sm">shopping_bag</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Quotes", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>عروض الأسعار</span>
                                <span class="material-symbols-outlined text-sm">request_quote</span>
                            </a>
                        </li>
                        <li>
                            <a href="@Url.Action("Projects", "Account", new { area = "Shop" })" class="flex items-center justify-between p-3 hover:bg-surface-container-low transition-colors text-on-surface">
                                <span>مشاريعي</span>
                                <span class="material-symbols-outlined text-sm">architecture</span>
                            </a>
                        </li>
                        <li class="pt-4 mt-4 border-t border-outline-variant">
                            <form asp-area="Shop" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="w-full flex items-center justify-between p-3 text-error hover:bg-error-container transition-colors">
                                    <span>تسجيل الخروج</span>
                                    <span class="material-symbols-outlined text-sm">logout</span>
                                </button>
                            </form>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 space-y-8">
            <header class="border-r-4 border-primary-container pr-6 mb-8">
                <h1 class="font-headline-xl text-on-surface uppercase mb-2">طلباتي</h1>
                <p class="font-body-lg text-secondary">قائمة بجميع طلباتك السابقة والحالية وحالتها.</p>
            </header>

            <!-- Orders Table -->
            <div class="bg-white border border-outline-variant shadow-hard overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-right">
                        <thead class="bg-surface-container-low text-xs font-bold text-on-surface-variant uppercase">
                            <tr>
                                <th class="p-4">رقم الطلب</th>
                                <th class="p-4">التاريخ</th>
                                <th class="p-4">المبلغ الإجمالي</th>
                                <th class="p-4">الحالة</th>
                                <th class="p-4">طريقة الدفع</th>
                                <th class="p-4">الإجراء</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var order in Model)
                                {
                                    <tr class="border-b border-outline-variant hover:bg-surface-container-lowest transition-colors">
                                        <td class="p-4 font-bold">#BLK-@order.Id.ToString("D5")</td>
                                        <td class="p-4">@order.OrderDate.ToString("yyyy/MM/dd HH:mm")</td>
                                        <td class="p-4 text-primary font-bold">@order.TotalAmount.ToString("N2") د.أ</td>
                                        <td class="p-4">
                                            @{
                                                 string statusClass = order.Status switch
                                                 {
                                                     OrderStatus.Pending    => "bg-amber-100 text-amber-800 border-amber-200",
                                                     OrderStatus.Processing => "bg-blue-100 text-blue-800 border-blue-200",
                                                     OrderStatus.Delivered  => "bg-green-100 text-green-800 border-green-200",
                                                     OrderStatus.Shipped    => "bg-indigo-100 text-indigo-800 border-indigo-200",
                                                     OrderStatus.Cancelled  => "bg-red-100 text-red-800 border-red-200",
                                                     _ => "bg-slate-100 text-slate-800 border-slate-200"
                                                 };
                                                 string statusLabel = order.Status switch
                                                 {
                                                     OrderStatus.Pending    => "قيد الانتظار",
                                                     OrderStatus.Processing => "قيد المعالجة",
                                                     OrderStatus.Shipped    => "تم الشحن",
                                                     OrderStatus.Delivered  => "تم التسليم",
                                                     OrderStatus.Cancelled  => "ملغي",
                                                     _ => order.Status.ToString()
                                                 };
                                             }
                                             <span class="px-2 py-1 text-[10px] font-bold uppercase rounded-sm border @statusClass">@statusLabel</span>
                                        </td>
                                        <td class="p-4 text-secondary">@(string.IsNullOrEmpty(order.PaymentMethod) ? "غير محدد" : order.PaymentMethod)</td>
                                        <td class="p-4">
                                            <a href="@Url.Action("OrderDetails", "Account", new { area = "Shop", id = order.Id })" class="text-primary font-bold hover:underline flex items-center gap-1">
                                                <span>تتبع الطلب</span>
                                                <span class="material-symbols-outlined text-[16px]">local_shipping</span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="p-12 text-center text-on-surface-variant flex flex-col items-center justify-center">
                                        <span class="material-symbols-outlined text-6xl text-outline-variant mb-4">shopping_cart_checkout</span>
                                        <p class="text-lg font-bold text-on-surface">لا توجد طلبات سابقة</p>
                                        <p class="text-sm mt-2">لم تقم بإجراء أي طلبات حتى الآن.</p>
                                        <a href="@Url.Action("Index", "Product", new { area = "Shop" })" class="mt-6 bg-primary text-on-primary px-6 py-2 rounded font-bold hover:bg-primary-hover transition-colors">تصفح المنتجات</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>
