@{
    ViewData["Title"] = "التحقق من رمز OTP";
    Layout = "_Layout";
}
<main class="min-h-[70vh] flex items-center justify-center py-12 px-6 text-right">
    <div class="max-w-md w-full space-y-8 bg-white p-10 border border-outline-variant shadow-hard">
        <div class="text-center">
            <h1 class="text-3xl font-black tracking-tighter text-slate-900 uppercase mb-2">BLOCKO</h1>
            <h2 class="text-xl font-bold text-on-surface">أدخل رمز التحقق</h2>
            <p class="mt-2 text-sm text-on-surface-variant">تم إرسال رمز تحقق (OTP) مكون من 6 أرقام إلى البريد الإلكتروني <br/><strong class="text-slate-800">@ViewBag.Email</strong></p>
        </div>
        
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm text-center">
                @ViewBag.Error
            </div>
        }

        <form class="mt-8 space-y-6" asp-area="Shop" asp-controller="Account" asp-action="VerifyOtp" method="post">
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2 text-center">رمز التحقق (OTP)</label>
                    <input type="text" name="otp" maxlength="6" required autocomplete="off" 
                           class="w-full bg-surface-container-low border border-outline p-4 focus:ring-0 focus:border-primary text-center text-2xl tracking-[10px] font-bold rounded-lg font-mono" 
                           placeholder="000000" />
                </div>
            </div>

            <div class="flex items-center justify-between text-sm">
                <a href="@Url.Action("ForgotPassword", "Account", new { area = "Shop" })" class="text-xs font-bold text-primary hover:underline uppercase">إعادة إرسال الرمز</a>
                <a href="@Url.Action("Login", "Account", new { area = "Shop" })" class="text-xs font-bold text-on-surface-variant hover:underline uppercase">العودة لتسجيل الدخول</a>
            </div>

            <div>
                <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-lg hover:bg-primary/90 transition-all rounded-md">
                    تأكيد الرمز
                </button>
            </div>
        </form>
    </div>
</main>
