@{
    ViewData["Title"] = SharedLocalizer["Login"];
    Layout = "_Layout";
}
<main class="min-h-[70vh] flex items-center justify-center py-12 px-6 text-start">
    <div class="max-w-md w-full space-y-8 bg-white p-10 border border-outline-variant shadow-hard">
        <div class="text-center">
            <h1 class="text-3xl font-black tracking-tighter text-slate-900 uppercase mb-2">BLOCKO</h1>
            <h2 class="text-xl font-bold text-on-surface">@SharedLocalizer["LoginTitle"]</h2>
            <p class="mt-2 text-sm text-on-surface-variant">@SharedLocalizer["OrCreateNewAccount"] <a href="@Url.Action("Register", "Account", new { area = "Shop" })" class="text-primary font-bold hover:underline">@SharedLocalizer["Register"]</a></p>
        </div>
        
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm text-center">
                @ViewBag.Error
            </div>
        }
        
        <form class="mt-8 space-y-6" asp-area="Shop" asp-controller="Account" asp-action="Login" method="post">
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Email"]</label>
                    <input type="email" name="email" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="example@mail.com" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Password"]</label>
                    <input type="password" name="password" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="********" />
                </div>
            </div>
            <div class="flex items-center justify-between text-sm">
                <label class="flex items-center cursor-pointer gap-2 select-none text-on-surface-variant font-bold text-xs uppercase">
                    <input type="checkbox" name="rememberMe" value="true" class="w-4 h-4 rounded border-outline bg-surface-container-low text-primary focus:ring-0" />
                    <span>@SharedLocalizer["RememberMe"]</span>
                </label>
                <a href="@Url.Action("ForgotPassword", "Account", new { area = "Shop" })" class="text-xs font-bold text-primary hover:underline uppercase">@SharedLocalizer["ForgotPasswordQuestion"]</a>
            </div>
            <div>
                <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-lg hover:bg-primary/90 transition-all rounded-md">
                    @SharedLocalizer["LoginBtnText"]
                </button>
            </div>
        </form>
    </div>
</main>