@{
    ViewData["Title"] = SharedLocalizer["ForgotPasswordTitle"];
    Layout = "_Layout";
}
<main class="min-h-[70vh] flex items-center justify-center py-12 px-6 text-start">
    <div class="max-w-md w-full space-y-8 bg-white p-10 border border-outline-variant shadow-hard">
        <div class="text-center">
            <h1 class="text-3xl font-black tracking-tighter text-slate-900 uppercase mb-2">BLOCKO</h1>
            <h2 class="text-xl font-bold text-on-surface">@SharedLocalizer["ForgotPasswordQuestion"]</h2>
            <p class="mt-2 text-sm text-on-surface-variant">@SharedLocalizer["ForgotPasswordInstructions"]</p>
        </div>
        
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm text-center">
                @ViewBag.Error
            </div>
        }

        @if (ViewBag.Message != null)
        {
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-md text-sm text-center">
                @ViewBag.Message
            </div>
        }

        @if (ViewBag.DebugResetLink != null)
        {
            <div class="bg-amber-50 border border-amber-200 text-amber-800 p-4 rounded-md text-xs mt-4 text-start font-mono break-all" style="direction: ltr;">
                <p class="font-bold mb-1 text-amber-950 text-start" style="direction: rtl;">@SharedLocalizer["DebugResetLinkTitle"]</p>
                <a href="@ViewBag.DebugResetLink" class="text-primary hover:underline font-bold">@ViewBag.DebugResetLink</a>
                <p class="mt-2 text-[10px] text-amber-700 text-start" style="direction: rtl;">@SharedLocalizer["DebugResetLinkNote"]</p>
            </div>
        }
        
        <form class="mt-8 space-y-6" asp-area="Shop" asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Email"]</label>
                    <input type="email" name="email" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="example@mail.com" />
                </div>
            </div>

            <div class="flex items-center justify-between text-sm">
                <a href="@Url.Action("Login", "Account", new { area = "Shop" })" class="text-xs font-bold text-primary hover:underline uppercase">@SharedLocalizer["BackToLogin"]</a>
            </div>

            <div>
                <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-lg hover:bg-primary/90 transition-all rounded-md">
                    @SharedLocalizer["SendResetLink"]
                </button>
            </div>
        </form>
    </div>
</main>
