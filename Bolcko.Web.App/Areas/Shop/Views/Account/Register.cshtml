@{
    ViewData["Title"] = SharedLocalizer["Register"];
    var isArabic = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");

    var countries = new[]
    {
        new { Flag = "🇯🇴", Dial = "+962", NameAr = "الأردن", NameEn = "Jordan" },
        new { Flag = "🇸🇦", Dial = "+966", NameAr = "السعودية", NameEn = "Saudi Arabia" },
        new { Flag = "🇦🇪", Dial = "+971", NameAr = "الإمارات", NameEn = "UAE" },
        new { Flag = "🇰🇼", Dial = "+965", NameAr = "الكويت", NameEn = "Kuwait" },
        new { Flag = "🇶🇦", Dial = "+974", NameAr = "قطر", NameEn = "Qatar" },
        new { Flag = "🇧🇭", Dial = "+973", NameAr = "البحرين", NameEn = "Bahrain" },
        new { Flag = "🇴🇲", Dial = "+968", NameAr = "عمان", NameEn = "Oman" },
        new { Flag = "🇵🇸", Dial = "+970", NameAr = "فلسطين", NameEn = "Palestine" },
        new { Flag = "🇱🇧", Dial = "+961", NameAr = "لبنان", NameEn = "Lebanon" },
        new { Flag = "🇮🇶", Dial = "+964", NameAr = "العراق", NameEn = "Iraq" },
        new { Flag = "🇪🇬", Dial = "+20",  NameAr = "مصر", NameEn = "Egypt" },
        new { Flag = "🇸🇾", Dial = "+963", NameAr = "سوريا", NameEn = "Syria" },
    };
}
<main class="min-h-[80vh] flex items-center justify-center py-12 px-6 text-start">
    <div class="max-w-xl w-full space-y-8 bg-white p-10 border border-outline-variant shadow-hard">
        <div class="text-center">
            <h1 class="text-3xl font-black tracking-tighter text-slate-900 uppercase mb-2">BLOCKO</h1>
            <h2 class="text-xl font-bold text-on-surface">@SharedLocalizer["RegisterTitle"]</h2>
            <p class="mt-2 text-sm text-on-surface-variant">@SharedLocalizer["AlreadyHaveAccount"] <a href="@Url.Action("Login", "Account", new { area = "Shop" })" class="text-primary font-bold hover:underline">@SharedLocalizer["Login"]</a></p>
        </div>

        <form id="register-form" class="mt-8 space-y-6" asp-area="Shop" asp-controller="Account" asp-action="Register" method="post">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="reg-FirstName" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["FirstName"]</label>
                    <input id="reg-FirstName" type="text" name="FirstName" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="@SharedLocalizer["FirstName"]" />
                </div>
                <div>
                    <label for="reg-LastName" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["LastName"]</label>
                    <input id="reg-LastName" type="text" name="LastName" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="@SharedLocalizer["LastName"]" />
                </div>
                <div>
                    <label for="reg-Username" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Username"]</label>
                    <input id="reg-Username" type="text" name="Username" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="username" />
                </div>
                <div>
                    <label for="reg-PhoneNumber" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["PhoneNumber"]</label>
                    <div class="flex bg-surface-container-low border border-outline focus-within:border-[#E8A020]">
                        <div class="relative flex-shrink-0">
                            <button type="button" id="phone-cc-btn"
                                    class="h-full flex items-center gap-1.5 px-3 border-e border-outline text-sm font-bold text-on-surface bg-surface-container-low hover:bg-gray-50 transition-colors"
                                    aria-haspopup="listbox" aria-expanded="false" aria-label="@(isArabic ? "رمز الدولة" : "Country code")">
                                <span id="phone-cc-flag">🇯🇴</span>
                                <span id="phone-cc-dial">+962</span>
                                <span class="material-symbols-outlined text-[14px]">expand_more</span>
                            </button>
                            <ul id="phone-cc-list" role="listbox" tabindex="-1"
                                class="hidden absolute top-full start-0 mt-1 w-64 bg-white border border-outline shadow-hard text-sm z-20"
                                style="max-height:14rem; overflow-y:auto;">
                                @foreach (var c in countries)
                                {
                                    <li role="option" data-flag="@c.Flag" data-dial="@c.Dial"
                                        class="px-3 py-2 flex items-center gap-2 cursor-pointer hover:bg-surface-container-low">
                                        <span>@c.Flag</span>
                                        <span class="flex-1">@(isArabic ? c.NameAr : c.NameEn)</span>
                                        <span class="text-on-surface-variant">@c.Dial</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <input id="reg-PhoneNumber" type="tel" inputmode="numeric" required
                               class="flex-1 min-w-0 bg-transparent p-3 focus:ring-0 focus:outline-none text-start"
                               placeholder="79xxxxxxx" autocomplete="tel-national" />
                    </div>
                    <input type="hidden" name="PhoneNumber" id="reg-PhoneNumber-full" />
                </div>
                <div class="md:col-span-2">
                    <label for="reg-Email" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Email"]</label>
                    <input id="reg-Email" type="email" name="Email" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" placeholder="example@mail.com" />
                </div>
                <div>
                    <label for="reg-Password" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["Password"]</label>
                    <div class="relative">
                        <input id="reg-Password" type="password" name="Password" required class="w-full bg-surface-container-low border border-outline p-3 pe-10 focus:ring-0 focus:border-primary text-start" placeholder="********" />
                        <button type="button" class="password-toggle-btn absolute top-0 bottom-0 end-0 flex items-center px-3 text-on-surface-variant hover:text-primary transition-colors" data-target="reg-Password" aria-label="@(isArabic ? "إظهار كلمة المرور" : "Show password")" aria-pressed="false">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                </div>
                <div>
                    <label for="reg-ConfirmPassword" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["ConfirmPassword"]</label>
                    <div class="relative">
                        <input id="reg-ConfirmPassword" type="password" name="ConfirmPassword" required class="w-full bg-surface-container-low border border-outline p-3 pe-10 focus:ring-0 focus:border-primary text-start" placeholder="********" />
                        <button type="button" class="password-toggle-btn absolute top-0 bottom-0 end-0 flex items-center px-3 text-on-surface-variant hover:text-primary transition-colors" data-target="reg-ConfirmPassword" aria-label="@(isArabic ? "إظهار كلمة المرور" : "Show password")" aria-pressed="false">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                </div>
                <div class="md:col-span-2">
                    <label for="reg-UserType" class="block text-xs font-bold text-on-surface-variant uppercase mb-1">@SharedLocalizer["UserType"]</label>
                    <select id="reg-UserType" name="UserType" class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start">
                        <option value="1">@SharedLocalizer["CustomerOption"]</option>
                    </select>
                    <p class="text-[10px] text-on-surface-variant mt-1">@SharedLocalizer["RegisterWarningText"]</p>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <input id="terms" name="terms" type="checkbox" required class="h-4 w-4 text-primary border-outline focus:ring-primary rounded-none" />
                <label for="terms" class="text-xs text-on-surface">@SharedLocalizer["IConfirmAcceptTerms"]</label>
            </div>

            <div>
                <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-lg hover:bg-primary/90 transition-all rounded-md">
                    @SharedLocalizer["RegisterBtnText"]
                </button>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <script>
        (function () {
            // 1) Auto-mark required fields with a red asterisk, derived from the actual
            //    `required` attribute already enforced on each input/select (no hardcoded list).
            var form = document.getElementById('register-form');
            if (form) {
                var requiredFields = form.querySelectorAll('input[required]:not([type="checkbox"]), select[required], textarea[required]');
                requiredFields.forEach(function (field) {
                    var label = field.id ? form.querySelector('label[for="' + field.id + '"]') : null;
                    if (label && !label.querySelector('.required-asterisk')) {
                        var asterisk = document.createElement('span');
                        asterisk.className = 'required-asterisk text-red-600';
                        asterisk.setAttribute('aria-hidden', 'true');
                        asterisk.textContent = ' *';
                        label.appendChild(asterisk);
                        field.setAttribute('aria-required', 'true');
                    }
                });
            }

            // 2) Password visibility toggles
            document.querySelectorAll('.password-toggle-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var input = document.getElementById(btn.getAttribute('data-target'));
                    if (!input) return;
                    var icon = btn.querySelector('.material-symbols-outlined');
                    var isHidden = input.type === 'password';
                    input.type = isHidden ? 'text' : 'password';
                    icon.textContent = isHidden ? 'visibility_off' : 'visibility';
                    btn.setAttribute('aria-pressed', isHidden ? 'true' : 'false');
                    btn.setAttribute('aria-label', isHidden
                        ? '@(isArabic ? "إخفاء كلمة المرور" : "Hide password")'
                        : '@(isArabic ? "إظهار كلمة المرور" : "Show password")');
                });
            });

            // 3) Country code dropdown for phone number
            var ccBtn = document.getElementById('phone-cc-btn');
            var ccList = document.getElementById('phone-cc-list');
            var ccFlag = document.getElementById('phone-cc-flag');
            var ccDial = document.getElementById('phone-cc-dial');
            var phoneInput = document.getElementById('reg-PhoneNumber');
            var phoneHidden = document.getElementById('reg-PhoneNumber-full');

            function syncPhoneHidden() {
                var digits = (phoneInput.value || '').replace(/\D/g, '').replace(/^0+/, '');
                phoneHidden.value = digits ? (ccDial.textContent + digits) : '';
            }

            if (ccBtn && ccList) {
                ccBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var willOpen = ccList.classList.contains('hidden');
                    ccList.classList.toggle('hidden', !willOpen);
                    ccBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
                });

                ccList.querySelectorAll('li[role="option"]').forEach(function (li) {
                    li.addEventListener('click', function () {
                        ccFlag.textContent = li.getAttribute('data-flag');
                        ccDial.textContent = li.getAttribute('data-dial');
                        ccList.classList.add('hidden');
                        ccBtn.setAttribute('aria-expanded', 'false');
                        syncPhoneHidden();
                        phoneInput.focus();
                    });
                });

                document.addEventListener('click', function (e) {
                    if (!ccList.contains(e.target) && e.target !== ccBtn) {
                        ccList.classList.add('hidden');
                        ccBtn.setAttribute('aria-expanded', 'false');
                    }
                });

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !ccList.classList.contains('hidden')) {
                        ccList.classList.add('hidden');
                        ccBtn.setAttribute('aria-expanded', 'false');
                    }
                });
            }

            if (phoneInput) {
                phoneInput.addEventListener('input', syncPhoneHidden);
                syncPhoneHidden();
            }

            if (form) {
                form.addEventListener('submit', function () {
                    syncPhoneHidden();
                });
            }
        })();
    </script>
}
