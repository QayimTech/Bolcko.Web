@{
    ViewData["Title"] = "إعادة تعيين كلمة المرور";
    Layout = "_Layout";
}
<main class="min-h-[70vh] flex items-center justify-center py-12 px-6 text-right">
    <div class="max-w-md w-full space-y-8 bg-white p-10 border border-outline-variant shadow-hard">
        <div class="text-center">
            <h1 class="text-3xl font-black tracking-tighter text-slate-900 uppercase mb-2">BLOCKO</h1>
            <h2 class="text-xl font-bold text-on-surface">إعادة تعيين كلمة المرور</h2>
            <p class="mt-2 text-sm text-on-surface-variant">الرجاء إدخال كلمة المرور الجديدة وتأكيدها أدناه.</p>
        </div>
        
        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm text-center">
                @ViewBag.Error
            </div>
        }
        
        <form class="mt-8 space-y-6" asp-area="Shop" asp-controller="Account" asp-action="ResetPassword" method="post">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <input type="hidden" name="token" value="@ViewBag.Token" />
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-1">كلمة المرور الجديدة</label>
                    <input type="password" name="password" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" placeholder="********" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-1">تأكيد كلمة المرور الجديدة</label>
                    <input type="password" name="confirmPassword" required class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-right" placeholder="********" />
                </div>
            </div>

            <div>
                <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-lg hover:bg-primary/90 transition-all rounded-md">
                    تحديث كلمة المرور
                </button>
            </div>
        </form>
    </div>
</main>
