@using Microsoft.Extensions.Localization
@using Bolcko.Web.App
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["ContactUs"];
}
<main class="max-w-4xl mx-auto px-6 py-12 text-start">
    <header class="mb-12 border-s-4 border-primary-container ps-6">
        <h1 class="font-headline-xl text-on-surface uppercase mb-2">@SharedLocalizer["ContactUs"]</h1>
        <p class="font-body-lg text-secondary">@SharedLocalizer["ContactDesc"]</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="space-y-8">
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl">location_on</span>
                <div>
                    <h3 class="font-bold text-lg mb-2">@SharedLocalizer["Address"]</h3>
                    <p class="text-secondary">@ViewBag.ContactAddress</p>
                </div>
            </div>
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl">phone</span>
                <div>
                    <h3 class="font-bold text-lg mb-2">@SharedLocalizer["Phone"]</h3>
                    <p class="text-secondary">@ViewBag.ContactPhone</p>
                </div>
            </div>
            <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary text-3xl">email</span>
                <div>
                    <h3 class="font-bold text-lg mb-2">@SharedLocalizer["Email"]</h3>
                    <p class="text-secondary">@ViewBag.ContactEmail</p>
                </div>
            </div>
        </div>

        <div class="bg-white border border-outline-variant p-8 shadow-hard">
            <form class="space-y-6">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Name"]</label>
                    <input class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="text" placeholder="@SharedLocalizer["YourNamePlaceholder"]" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Email"]</label>
                    <input class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start" type="email" placeholder="example@domain.com" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">@SharedLocalizer["Message"]</label>
                    <textarea class="w-full bg-surface-container-low border border-outline p-3 focus:ring-0 focus:border-primary text-start h-32" placeholder="@SharedLocalizer["WriteMessagePlaceholder"]"></textarea>
                </div>
                <button type="button" class="w-full bg-primary text-white font-bold py-4 uppercase shadow-hard hover:opacity-90 transition-all">
                    @SharedLocalizer["SendMessage"]
                </button>
            </form>
        </div>
    </div>
</main>
