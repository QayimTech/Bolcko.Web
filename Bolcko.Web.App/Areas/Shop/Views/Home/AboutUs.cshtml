@using Microsoft.Extensions.Localization
@using Bolcko.Web.App
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["AboutUs"];
}

<main class="bg-[#faf8ff]">
    <!-- Hero Section -->
    <section class="relative min-h-[700px] w-full flex items-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img alt="Construction site panorama" class="w-full h-full object-cover" 
                 src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=2070" 
                 onerror="this.src='https://placehold.co/1920x1080/0d111a/ffffff?text=LOCKO'" />
            <div class="absolute inset-0 bg-gradient-to-l from-[#0D111A]/95 via-[#0D111A]/80 to-[#0D111A]/60"></div>
        </div>
        
        <!-- Glowing orbs -->
        <div class="absolute top-20 right-20 w-[400px] h-[400px] bg-[#E8A020]/10 rounded-full blur-[120px] pointer-events-none"></div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-6 w-full text-right">
            <div class="max-w-2xl">
                <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#E8A020] bg-[#E8A020]/10 px-3.5 py-1.5 rounded-full mb-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8A020] animate-pulse"></span>
                    @SharedLocalizer["Established1995"]
                </span>
                <h1 class="font-headline-xl text-white mb-8 leading-tight">
                    @SharedLocalizer["HeroTitle"]
                </h1>
                <p class="font-body-lg text-slate-300 max-w-xl mb-10 leading-relaxed">
                    @SharedLocalizer["HeroSubtitle"]
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="@Url.Action("Index", "Category", new { area = "Shop" })" 
                       class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-8 py-4 rounded-2xl shadow-[0_8px_25px_rgba(232,160,32,0.2)] transition-all duration-300 active:scale-95 flex items-center gap-2">
                        <span>@SharedLocalizer["BrowseProducts"]</span>
                        <span class="material-symbols-outlined text-base">arrow_back</span>
                    </a>
                    <a href="#capabilities" 
                       class="bg-white/5 border border-white/10 hover:bg-white/10 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 active:scale-95">
                        @SharedLocalizer["Capabilities"]
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Company Introduction -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                <div class="lg:col-span-7 space-y-8 text-right">
                    <div>
                        <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">قصتنا</span>
                        <h2 class="font-headline-lg text-slate-800 mt-2">ثلاثة عقود من <span class="text-[#E8A020]">الريادة</span> في التوريدات الإنشائية</h2>
                        <div class="h-1 w-24 bg-[#E8A020] mt-4 rounded-full"></div>
                    </div>
                    <p class="font-body-lg text-slate-500 leading-relaxed">
                        ما بدأ عام 1995 كورشة محلية متخصصة تحوّل إلى مرجعية صناعية إقليمية. تقف LOCKO اليوم كالمورّد الأول لمواد البناء والتوريدات الإنشائية الثقيلة، وتسد الفجوة بين التحديات الهندسية المعقدة والتحف المعمارية الخالدة.
                    </p>
                    <p class="text-slate-400 leading-relaxed">
                        رحلتنا تُعرّف بالسعي الدائم نحو الإتقان التقني. من عام التأسيس إلى توريد الحديد الإنشائي عالي الجودة لأكثر ناطحات السحاب طموحاً في العالم، حافظنا على تركيز واحد: تقديم الخبرة المتخصصة والمواد التي تمكّن البنّائين من خلق إرث دائم.
                    </p>
                    
                    <!-- Stats -->
                    <div class="grid grid-cols-3 gap-8 pt-8 border-t border-slate-100">
                        <div class="text-center">
                            <div class="text-4xl font-black text-slate-800">+28</div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">سنة من النجاح المثبت</div>
                        </div>
                        <div class="text-center">
                            <div class="text-4xl font-black text-slate-800">1.2M</div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">طن تم توريدها بدقة</div>
                        </div>
                        <div class="text-center">
                            <div class="text-4xl font-black text-slate-800">+500</div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">شريك صناعي حول العالم</div>
                        </div>
                    </div>
                </div>
                
                <div class="lg:col-span-5 relative group">
                    <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[#E8A020]/30 rounded-3xl z-0 group-hover:border-[#E8A020]/60 transition-colors duration-500"></div>
                    <img alt="Industrial storage yard" class="relative z-10 w-full h-[500px] object-cover rounded-3xl shadow-2xl" 
                         src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?auto=format&fit=crop&q=80&w=1000" 
                         onerror="this.src='https://placehold.co/600x500/f8fafc/475569?text=LOCKO'" />
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-24 bg-[#faf8ff]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Mission -->
                <div class="bg-[#0D111A] p-12 rounded-3xl flex flex-col justify-between group hover:-translate-y-1 transition-all duration-300 text-right relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-[200px] h-[200px] bg-[#E8A020]/5 rounded-full blur-[80px] pointer-events-none"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center mb-8">
                            <span class="material-symbols-outlined text-[#E8A020] text-3xl">architecture</span>
                        </div>
                        <h3 class="font-headline-md text-white mb-6">مهمتنا</h3>
                        <p class="text-slate-300 leading-relaxed">
                            تقديم حلول إنشائية متكاملة تستثمر خبرتنا العميقة في الصناعة لتجمع بين القوة الهيكلية والكفاءة الاقتصادية القصوى. نقدم الدقة التقنية المطلوبة لأكثر المشاريع الصناعية تعقيداً.
                        </p>
                    </div>
                    <div class="mt-12 h-1 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                
                <!-- Vision -->
                <div class="bg-white border border-slate-100 p-12 rounded-3xl flex flex-col justify-between group hover:-translate-y-1 transition-all duration-300 shadow-[0_4px_25px_rgba(0,0,0,0.02)] text-right">
                    <div>
                        <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center mb-8">
                            <span class="material-symbols-outlined text-[#E8A020] text-3xl">precision_manufacturing</span>
                        </div>
                        <h3 class="font-headline-md text-slate-800 mb-6">رؤيتنا</h3>
                        <p class="text-slate-500 leading-relaxed">
                            أن نصبح الركيزة الأساسية للتنمية العمرانية في الشرق الأوسط. من خلال الابتكار المستمر في سلاسل التوريد وتبني التقنيات الصناعية الصديقة للبيئة، نسعى لإعادة تعريف معايير صناعة التوريدات الإنشائية.
                        </p>
                    </div>
                    <div class="mt-12 h-1 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Gallery -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4 text-right">
                <div>
                    <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">إنجازاتنا</span>
                    <h2 class="font-headline-lg text-slate-800 mt-2">مشاريع صنعت <span class="text-[#E8A020]">الفارق</span></h2>
                    <p class="text-slate-400 mt-2 max-w-lg">من ناطحات السحاب إلى البنية التحتية الضخمة، ساهمنا في بناء معالم ستبقى شاهدة على الزمن.</p>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[600px]">
                <div class="md:col-span-8 relative group overflow-hidden rounded-3xl">
                    <img alt="Skyscraper project" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105" 
                         src="https://images.unsplash.com/photo-1486325212027-8081e485255e?auto=format&fit=crop&q=80&w=1600" 
                         onerror="this.src='https://placehold.co/1200x600/f8fafc/475569?text=Project+1'" />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0D111A]/90 via-[#0D111A]/30 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 right-0 p-8 text-right">
                        <h4 class="font-headline-md text-white mb-1">حي النور المالي</h4>
                        <span class="text-[#E8A020] font-bold text-xs uppercase tracking-wider">حديد إنشائي وخرسانة مسلحة</span>
                    </div>
                </div>
                <div class="md:col-span-4 grid grid-rows-2 gap-6">
                    <div class="relative group overflow-hidden rounded-3xl">
                        <img alt="Industrial warehouse" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105" 
                             src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?auto=format&fit=crop&q=80&w=800" 
                             onerror="this.src='https://placehold.co/600x300/f8fafc/475569?text=Project+2'" />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0D111A]/90 via-[#0D111A]/30 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-6 text-right">
                            <h4 class="font-bold text-white text-lg mb-0.5">مركز اللوجستيات المركزي</h4>
                            <span class="text-[#E8A020] text-[10px] uppercase font-bold tracking-wider">مواد صناعية</span>
                        </div>
                    </div>
                    <div class="relative group overflow-hidden rounded-3xl">
                        <img alt="Highway bridge" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105" 
                             src="https://images.unsplash.com/photo-1545558014-8692077e9b5c?auto=format&fit=crop&q=80&w=800" 
                             onerror="this.src='https://placehold.co/600x300/f8fafc/475569?text=Project+3'" />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#0D111A]/90 via-[#0D111A]/30 to-transparent"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-6 text-right">
                            <h4 class="font-bold text-white text-lg mb-0.5">طريق الشرق السريع</h4>
                            <span class="text-[#E8A020] text-[10px] uppercase font-bold tracking-wider">بنية تحتية ثقيلة</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section id="capabilities" class="py-24 bg-[#0D111A] text-white relative overflow-hidden">
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#E8A020]/5 rounded-full blur-[120px] pointer-events-none"></div>
        
        <div class="max-w-7xl mx-auto px-6 text-center mb-16 relative z-10">
            <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">لماذا LOCKO؟</span>
            <h2 class="font-headline-lg text-white mt-2">خبرتنا العميقة في الصناعة</h2>
            <div class="h-1 w-20 bg-[#E8A020] mx-auto mt-4 rounded-full"></div>
        </div>
        
        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-right">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">01</div>
                    <h4 class="font-bold text-white text-lg mb-4">الجودة</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">معايير لا تقبل المساومة مدعومة بفحوصات مخبرية مكثفة تضمن أن كل دفعة من المواد تلبي تقاليدنا العريقة في التميز.</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-right">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">02</div>
                    <h4 class="font-bold text-white text-lg mb-4">النزاهة</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">شفافية مطلقة في المواصفات الفنية والتسعير والمعاملات التجارية مع كل شريك وعميل.</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-right">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">03</div>
                    <h4 class="font-bold text-white text-lg mb-4">الدقة</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">التزام صارم بجداول التسليم والقياسات الهندسية الدقيقة لكل طلب مهما كان حجمه.</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-right">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">04</div>
                    <h4 class="font-bold text-white text-lg mb-4">الخبرة</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">فريق هندسي متخصص يقدم استشارات مبنية على عقود من الخبرة الميدانية لتحسين استخدام المواد وكفاءة المشاريع.</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-[#E8A020] relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-white rounded-full blur-[100px]"></div>
        </div>
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 relative z-10">
            <h2 class="font-headline-md text-[#151B26] text-center md:text-right font-black">
                جاهز لبناء معلمك القادم مع LOCKO؟
            </h2>
            <div class="flex gap-4 flex-wrap">
                <a href="@Url.Action("Request", "Quote", new { area = "Shop" })" 
                   class="bg-[#151B26] hover:bg-[#0D111A] text-white px-8 py-4 rounded-2xl font-bold transition-all duration-300 active:scale-95 shadow-lg">
                    اطلب عرض سعر
                </a>
                <a href="#" class="bg-white hover:bg-slate-50 text-[#151B26] px-8 py-4 rounded-2xl font-bold transition-all duration-300 active:scale-95">
                    تواصل مع المبيعات
                </a>
            </div>
        </div>
    </section>
</main>