@using Microsoft.Extensions.Localization
@using Bolcko.Web.App
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["AboutUs"];
}

<main class="bg-[#faf8ff]">
    <!-- Hero Section -->
    <section class="relative min-h-[550px] w-full flex items-center overflow-hidden bg-[#0D111A]">
        <div class="absolute top-20 end-20 w-[400px] h-[400px] bg-[#E8A020]/10 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 start-0 w-[300px] h-[300px] bg-blue-500/5 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 w-full text-start">
            <div class="max-w-2xl">
                <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#E8A020] bg-[#E8A020]/10 px-3.5 py-1.5 rounded-full mb-8">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8A020] animate-pulse"></span>
                    @SharedLocalizer["AboutHeroBadge"]
                </span>
                <h1 class="font-headline-xl text-white mb-8 leading-tight">
                    @SharedLocalizer["AboutHeroTitlePre"] <span class="text-[#E8A020]">@SharedLocalizer["AboutHeroTitleHighlight"]</span> @SharedLocalizer["AboutHeroTitlePost"]
                </h1>
                <p class="font-body-lg text-slate-300 max-w-xl mb-10 leading-relaxed">
                    @SharedLocalizer["AboutHeroDesc"]
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="@Url.Action("Index", "Category", new { area = "Shop" })"
                       class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-8 py-4 rounded-2xl shadow-[0_8px_25px_rgba(232,160,32,0.2)] transition-all duration-300 active:scale-95 flex items-center gap-2">
                        <span>@SharedLocalizer["BrowseProducts"]</span>
                        <span class="material-symbols-outlined text-base rtl:-scale-x-100">arrow_back</span>
                    </a>
                    <a href="#why-blocko"
                       class="bg-white/5 border border-white/10 hover:bg-white/10 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 active:scale-95">
                        @SharedLocalizer["WhyBlocko"]
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Company Introduction -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                <div class="lg:col-span-7 space-y-8 text-start">
                    <div>
                        <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["AboutWhoWeAre"]</span>
                        <h2 class="font-headline-lg text-slate-800 mt-2">@SharedLocalizer["AboutIntroTitle"] <span class="text-[#E8A020]">@SharedLocalizer["AboutIntroTitleHighlight"]</span> @SharedLocalizer["AboutIntroTitlePost"]</h2>
                        <div class="h-1 w-24 bg-[#E8A020] mt-4 rounded-full"></div>
                    </div>
                    <p class="font-body-lg text-slate-500 leading-relaxed">
                        @SharedLocalizer["AboutIntroP1"]
                    </p>
                    <p class="text-slate-400 leading-relaxed">
                        @SharedLocalizer["AboutIntroP2"]
                    </p>

                    <!-- Stats -->
                    <div class="grid grid-cols-3 gap-8 pt-8 border-t border-slate-100">
                        <div class="text-center">
                            <div class="w-12 h-12 bg-[#E8A020]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                                <span class="material-symbols-outlined text-[#E8A020] text-2xl">storefront</span>
                            </div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">@SharedLocalizer["AboutStatOnline"]</div>
                        </div>
                        <div class="text-center">
                            <div class="w-12 h-12 bg-[#E8A020]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                                <span class="material-symbols-outlined text-[#E8A020] text-2xl">local_shipping</span>
                            </div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">@SharedLocalizer["AboutStatDelivery"]</div>
                        </div>
                        <div class="text-center">
                            <div class="w-12 h-12 bg-[#E8A020]/10 rounded-xl flex items-center justify-center mx-auto mb-3">
                                <span class="material-symbols-outlined text-[#E8A020] text-2xl">request_quote</span>
                            </div>
                            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">@SharedLocalizer["AboutStatQuotes"]</div>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-5 relative">
                    <div class="bg-[#0D111A] p-10 rounded-3xl shadow-2xl text-start relative overflow-hidden">
                        <div class="absolute top-0 end-0 w-[150px] h-[150px] bg-[#E8A020]/5 rounded-full blur-[60px] pointer-events-none"></div>
                        <div class="relative z-10 flex flex-col gap-6">
                            <div class="w-16 h-16 bg-[#E8A020] rounded-2xl flex items-center justify-center">
                                <span class="material-symbols-outlined text-[#151B26] text-3xl">rocket_launch</span>
                            </div>
                            <h3 class="font-headline-md text-white">@SharedLocalizer["AboutStartTitle"]</h3>
                            <p class="text-slate-300 text-sm leading-relaxed">
                                @SharedLocalizer["AboutStartDesc"]
                            </p>
                            <a href="@Url.Action("Register", "Account", new { area = "Shop" })"
                               class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-6 py-3 rounded-xl transition-all duration-300 active:scale-95 text-center text-sm">
                                @SharedLocalizer["AboutStartCTA"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-24 bg-[#faf8ff]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Mission -->
                <div class="bg-[#0D111A] p-12 rounded-3xl flex flex-col justify-between group hover:-translate-y-1 transition-all duration-300 text-start relative overflow-hidden">
                    <div class="absolute top-0 end-0 w-[200px] h-[200px] bg-[#E8A020]/5 rounded-full blur-[80px] pointer-events-none"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center mb-8">
                            <span class="material-symbols-outlined text-[#E8A020] text-3xl">target</span>
                        </div>
                        <h3 class="font-headline-md text-white mb-6">@SharedLocalizer["AboutMissionTitle"]</h3>
                        <p class="text-slate-300 leading-relaxed">
                            @SharedLocalizer["AboutMissionDesc"]
                        </p>
                    </div>
                    <div class="mt-12 h-1 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>

                <!-- Vision -->
                <div class="bg-white border border-slate-100 p-12 rounded-3xl flex flex-col justify-between group hover:-translate-y-1 transition-all duration-300 shadow-[0_4px_25px_rgba(0,0,0,0.02)] text-start">
                    <div>
                        <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center mb-8">
                            <span class="material-symbols-outlined text-[#E8A020] text-3xl">visibility</span>
                        </div>
                        <h3 class="font-headline-md text-slate-800 mb-6">@SharedLocalizer["AboutVisionTitle"]</h3>
                        <p class="text-slate-500 leading-relaxed">
                            @SharedLocalizer["AboutVisionDesc"]
                        </p>
                    </div>
                    <div class="mt-12 h-1 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Why BLOCKO -->
    <section id="why-blocko" class="py-24 bg-[#0D111A] text-white relative overflow-hidden">
        <div class="absolute bottom-0 start-0 w-[400px] h-[400px] bg-[#E8A020]/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-6 text-center mb-16 relative z-10">
            <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["WhyBlocko"]</span>
            <h2 class="font-headline-lg text-white mt-2">@SharedLocalizer["AboutWhySubtitle"]</h2>
            <div class="h-1 w-20 bg-[#E8A020] mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-start">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">01</div>
                    <h4 class="font-bold text-white text-lg mb-4">@SharedLocalizer["AboutVal1Title"]</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">@SharedLocalizer["AboutVal1Desc"]</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-start">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">02</div>
                    <h4 class="font-bold text-white text-lg mb-4">@SharedLocalizer["AboutVal2Title"]</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">@SharedLocalizer["AboutVal2Desc"]</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-start">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">03</div>
                    <h4 class="font-bold text-white text-lg mb-4">@SharedLocalizer["AboutVal3Title"]</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">@SharedLocalizer["AboutVal3Desc"]</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-300 group text-start">
                    <div class="text-3xl font-black text-[#E8A020] mb-4">04</div>
                    <h4 class="font-bold text-white text-lg mb-4">@SharedLocalizer["AboutVal4Title"]</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">@SharedLocalizer["AboutVal4Desc"]</p>
                    <div class="mt-6 h-0.5 w-0 group-hover:w-full bg-[#E8A020] transition-all duration-700 rounded-full"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-[#E8A020] relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 end-0 w-[300px] h-[300px] bg-white rounded-full blur-[100px]"></div>
        </div>
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 relative z-10">
            <h2 class="font-headline-md text-[#151B26] text-center md:text-start font-black">
                @SharedLocalizer["AboutCTATitle"]
            </h2>
            <div class="flex gap-4 flex-wrap">
                <a href="@Url.Action("Request", "Quote", new { area = "Shop" })"
                   class="bg-[#151B26] hover:bg-[#0D111A] text-white px-8 py-4 rounded-2xl font-bold transition-all duration-300 active:scale-95 shadow-lg">
                    @SharedLocalizer["AboutCTAQuote"]
                </a>
                <a href="@Url.Action("Contact", "Home", new { area = "Shop" })"
                   class="bg-white hover:bg-slate-50 text-[#151B26] px-8 py-4 rounded-2xl font-bold transition-all duration-300 active:scale-95">
                    @SharedLocalizer["ContactUs"]
                </a>
            </div>
        </div>
    </section>
</main>
