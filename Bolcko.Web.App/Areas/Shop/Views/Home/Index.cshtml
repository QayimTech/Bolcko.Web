@{
    ViewData["Title"] = "الرئيسية";
}

<main class="bg-[#faf8ff] text-[#161b28]">
    <!-- Hero Section -->
    <section class="relative bg-[#0D111A] text-white min-h-[650px] flex items-center overflow-hidden py-16">
        <!-- Glowing background decoration -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#E8A020]/10 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-blue-500/10 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="absolute inset-0 opacity-20 mix-blend-overlay">
            <img class="w-full h-full object-cover" 
                 src="https://images.unsplash.com/photo-1541888946425-d81bb19480c5?auto=format&fit=crop&q=80&w=2070" 
                 onerror="this.src='https://placehold.co/1920x1080/0d111a/ffffff?text=Blocko+Construction'"
                 alt="Construction site" />
        </div>
        
        <div class="relative max-w-7xl mx-auto px-6 w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class="flex flex-col gap-8 text-right">
                <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#E8A020] bg-[#E8A020]/10 px-3.5 py-1.5 rounded-full w-max">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8A020] animate-pulse"></span>
                    @SharedLocalizer["HomeHeroBadge"]
                </span>
                <h1 class="font-headline-xl text-white leading-tight">@SharedLocalizer["HomeHeroTitle"]</h1>
                <p class="font-body-lg text-slate-300 max-w-lg leading-relaxed">@SharedLocalizer["HomeHeroDesc"]</p>
                
                <div class="flex flex-wrap gap-4 justify-start">
                    <a href="@Url.Action("Index", "Category")" 
                       class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-8 py-4 rounded-2xl shadow-[0_8px_25px_rgba(232,160,32,0.2)] transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 flex items-center gap-2">
                        <span>@SharedLocalizer["BrowseProducts"]</span>
                        <span class="material-symbols-outlined text-base rtl:-scale-x-100">arrow_back</span>
                    </a>
                    <a href="@Url.Action("Request", "Quote", new { area = "Shop" })" 
                       class="bg-white/5 border border-white/10 hover:bg-white/10 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95">
                        @SharedLocalizer["RequestQuote"]
                    </a>
                </div>
            </div>
            
            <div class="hidden md:flex items-center justify-center">
                <!-- Premium Glassmorphic Feature Card -->
                <div class="bg-white/5 backdrop-blur-md border border-white/10 p-8 rounded-3xl flex flex-col gap-4 max-w-sm text-right shadow-2xl relative">
                    <div class="absolute -top-3 -right-3 w-12 h-12 bg-[#E8A020] rounded-2xl flex items-center justify-center text-[#151B26] shadow-lg">
                        <span class="material-symbols-outlined font-bold">local_shipping</span>
                    </div>
                    <span class="text-[#E8A020] font-bold uppercase text-xs tracking-wider pt-2">@SharedLocalizer["ShippingBadge"]</span>
                    <h3 class="font-headline-md text-white">@SharedLocalizer["ShippingTitle"]</h3>
                    <p class="text-sm text-slate-300 leading-relaxed">@SharedLocalizer["ShippingDesc"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="py-24 max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-12 text-right">
            <div>
                <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["BrowseSmartly"]</span>
                <h2 class="font-headline-lg border-r-4 border-[#E8A020] pr-4 mt-2">@SharedLocalizer["FeaturedCategories"]</h2>
            </div>
            <a class="font-bold text-[#E8A020] hover:underline underline-offset-4 flex items-center gap-1.5 transition-all text-sm" 
               href="@Url.Action("Index", "Category", new { area = "Shop" })">
                <span>@SharedLocalizer["ViewAll"]</span>
                <span class="material-symbols-outlined text-sm rtl:-scale-x-100">arrow_back</span>
            </a>
        </div>
        
        <div class="flex flex-wrap justify-start gap-4 rtl:justify-start" dir="rtl">
            @foreach (var cat in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.Categories)
            {
                <a href="@Url.Action("Index", "Category", new { area = "Shop", id = cat.Id })" 
                   class="group flex items-center gap-4 bg-white border border-slate-100 rounded-2xl px-5 py-4 shadow-[0_2px_10px_rgba(0,0,0,0.02)] hover:shadow-[0_8px_25px_rgba(232,160,32,0.1)] hover:border-[#E8A020]/30 hover:bg-gradient-to-l hover:from-[#fffcf5] hover:to-white transition-all duration-300 hover:-translate-y-1 min-w-[200px]">
                    
                    <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300 shadow-sm group-hover:shadow-md">
                        <span class="material-symbols-outlined text-2xl">category</span>
                    </div>
                    
                    <div class="flex flex-col text-right">
                        <span class="font-bold text-slate-800 text-base group-hover:text-[#E8A020] transition-colors duration-300">@cat.Name</span>
                        <span class="text-[11px] text-slate-500 font-medium mt-0.5 bg-slate-100 px-2 py-0.5 rounded-md w-max group-hover:bg-[#E8A020]/10 group-hover:text-[#d18f1c] transition-colors">@cat.ProductCount منتج</span>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- Best Sellers Section -->
    <section class="bg-white py-24 border-y border-slate-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex justify-between items-end mb-12 text-right">
                <div>
                    <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["CustomerFavorites"]</span>
                    <h2 class="font-headline-lg border-r-4 border-[#E8A020] pr-4 mt-2">@SharedLocalizer["BestSellingProducts"]</h2>
                </div>
                <div class="flex gap-2">
                    <button class="w-11 h-11 border border-slate-100 rounded-xl bg-white flex items-center justify-center hover:bg-[#E8A020] hover:text-[#151B26] transition-all duration-200">
                        <span class="material-symbols-outlined text-lg rtl:-scale-x-100">chevron_right</span>
                    </button>
                    <button class="w-11 h-11 border border-slate-100 rounded-xl bg-white flex items-center justify-center hover:bg-[#E8A020] hover:text-[#151B26] transition-all duration-200">
                        <span class="material-symbols-outlined text-lg rtl:-scale-x-100">chevron_left</span>
                    </button>
                </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var product in (IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>)ViewBag.FeaturedProducts)
                {
                    <partial name="Partials/_ProductCard" model="product" />
                }
            </div>
        </div>
    </section>

    <!-- Live Market Prices Section -->
    <section class="bg-[#faf8ff] py-24">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4 text-right">
                <div>
                    <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-md">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        @SharedLocalizer["LiveUpdated"]
                    </span>
                    <h2 class="font-headline-lg border-r-4 border-[#E8A020] pr-4 mt-2">@SharedLocalizer["LocalMarketPrices"]</h2>
                </div>
                <p class="text-slate-500 text-sm max-w-md md:text-left leading-relaxed">@SharedLocalizer["MarketPricesDesc"]</p>
            </div>
            
            <div id="market-prices-container">
                <!-- Loaded via AJAX -->
                <div class="flex justify-center py-16">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-[#E8A020]"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- B2B Quote Section -->
    <section class="bg-[#0D111A] py-24 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-[400px] h-[400px] bg-[#E8A020]/5 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
            <div class="flex flex-col gap-6 text-right text-white">
                <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["CorporateAccounts"]</span>
                <h2 class="font-headline-xl text-white">@SharedLocalizer["BigProjectsTitle"]</h2>
                <p class="text-slate-300 font-body-lg leading-relaxed">@SharedLocalizer["BigProjectsDesc"]</p>
                
                <div class="flex flex-col gap-6 mt-4">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#E8A020] flex-shrink-0">
                            <span class="material-symbols-outlined text-xl">verified</span>
                        </div>
                        <div>
                            <h6 class="text-white font-bold text-sm">@SharedLocalizer["GuaranteedSupply"]</h6>
                            <p class="text-xs text-slate-400 mt-1">@SharedLocalizer["GuaranteedSupplyDesc"]</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#E8A020] flex-shrink-0">
                            <span class="material-symbols-outlined text-xl">local_shipping</span>
                        </div>
                        <div>
                            <h6 class="text-white font-bold text-sm">@SharedLocalizer["AdvancedLogistics"]</h6>
                            <p class="text-xs text-slate-400 mt-1">@SharedLocalizer["AdvancedLogisticsDesc"]</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Custom Quote Form Card -->
            <div class="bg-white/5 backdrop-blur-md border border-white/10 p-10 rounded-3xl shadow-2xl text-right relative">
                <h3 class="font-headline-md text-white mb-8">@SharedLocalizer["RequestBulkQuote"]</h3>
                <form asp-action="Request" asp-controller="Quote" asp-area="Shop" method="get" class="flex flex-col gap-6">
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["CompanyName"]</label>
                        <input name="CompanyName" class="w-full bg-white/5 border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-right" type="text" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["ContactPerson"]</label>
                            <input name="FullName" class="w-full bg-white/5 border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-right" type="text" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["ProjectType"]</label>
                            <select name="ProjectType" class="w-full bg-[#151B26] border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-right">
                                <option value="Residential">@SharedLocalizer["Residential"]</option>
                                <option value="Commercial">@SharedLocalizer["Commercial"]</option>
                                <option value="Industrial">@SharedLocalizer["Industrial"]</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <button type="submit" 
                                class="w-full bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold py-4 rounded-xl transition-all duration-300 transform active:scale-95 shadow-[0_6px_20px_rgba(232,160,32,0.15)]">
                            @SharedLocalizer["SubmitRequest"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Trust Features Section -->
    <section class="bg-white py-20 border-t border-slate-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">local_shipping</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["FastDelivery"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["FastDeliveryDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">verified_user</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["WarrantyMatching"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["WarrantyMatchingDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">support_agent</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["TechnicalSupport"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["TechnicalSupportDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">payments</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["FlexiblePayments"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["FlexiblePaymentsDesc"]</p>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Load market prices via AJAX
            $.get('@Url.Action("GetMarketPrices", "Home", new { area = "Shop" })', function(data) {
                $('#market-prices-container').html(data);
            });
        });
    </script>
}