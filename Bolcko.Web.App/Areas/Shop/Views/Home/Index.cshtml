@{
    ViewData["Title"] = "الرئيسية";
}
<main>
    <section class="relative bg-on-surface text-white h-[600px] flex items-center overflow-hidden">
        <div class="absolute inset-0 opacity-40">
            <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1541888946425-d81bb19480c5?auto=format&fit=crop&q=80&w=2070" alt="Construction site" />
        </div>
        <div class="relative max-w-7xl mx-auto px-6 w-full grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="flex flex-col gap-8">
                <h1 class="font-headline-xl text-white">الأساس المتين لكل مشروع عظيم.</h1>
                <p class="font-body-lg text-secondary-fixed-dim max-w-lg">توريدات صناعية عالية الدقة للمقاولين المحترفين. من الخرسانة الخام إلى الأدوات الدقيقة، نوفر لك كل ما تحتاجه.</p>
                <div class="flex flex-wrap gap-4">
                    <a href="@Url.Action("Index", "Category")" class="bg-primary-container text-on-primary-container font-bold px-8 py-4 uppercase tracking-wider transition-all hover:opacity-90 shadow-hard">
                        تصفح المنتجات
                    </a>
                    <a href="@Url.Action("Request", "Quote", new { area = "Shop" })" class="bg-[#1B2235] text-white font-bold px-8 py-4 uppercase border border-white/20 tracking-wider transition-all hover:bg-white hover:text-on-surface">
                        اطلب عرض سعر
                    </a>
                </div>
            </div>
            <div class="hidden md:flex items-center justify-center">
                <div class="bg-on-surface/80 backdrop-blur-md border border-outline/20 p-8 flex flex-col gap-4 max-w-sm text-right">
                    <span class="text-primary-container font-bold uppercase text-xs tracking-[0.2em]">توصيل سريع</span>
                    <h3 class="font-headline-md text-white">متوفر وجاهز للشحن.</h3>
                    <p class="text-sm opacity-80 text-white">98% من كتالوجنا الأساسي جاهز للإرسال الفوري إلى موقع عملك.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-xl max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-md">
            <h2 class="font-headline-lg uppercase border-r-4 border-primary-container pr-4">الفئات المميزة</h2>
            <a class="font-bold text-primary hover:underline underline-offset-4" href="@Url.Action("Index", "Category", new { area = "Shop" })">عرض الكل</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
            <!-- Category Cards -->
            <div onclick="location.href='@Url.Action("Index", "Category", new { area = "Shop" })'" class="group relative aspect-square bg-surface-container overflow-hidden cursor-pointer border border-outline-variant/10">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&q=80&w=1000" alt="Cement" />
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface to-transparent opacity-60"></div>
                <div class="absolute bottom-6 right-6">
                    <h4 class="font-headline-md text-white">الأسمنت</h4>
                    <span class="text-primary-container font-bold uppercase text-xs">820 منتج</span>
                </div>
            </div>
            <div onclick="location.href='@Url.Action("Index", "Category", new { area = "Shop" })'" class="group relative aspect-square bg-surface-container overflow-hidden cursor-pointer border border-outline-variant/10">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1516216628859-9bccecad13f7?auto=format&fit=crop&q=80&w=1000" alt="Steel" />
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface to-transparent opacity-60"></div>
                <div class="absolute bottom-6 right-6">
                    <h4 class="font-headline-md text-white">الحديد</h4>
                    <span class="text-primary-container font-bold uppercase text-xs">450 منتج</span>
                </div>
            </div>
            <div onclick="location.href='@Url.Action("Index", "Category", new { area = "Shop" })'" class="group relative aspect-square bg-surface-container overflow-hidden cursor-pointer border border-outline-variant/10">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1590069230005-db3937f91f30?auto=format&fit=crop&q=80&w=1000" alt="Bricks" />
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface to-transparent opacity-60"></div>
                <div class="absolute bottom-6 right-6">
                    <h4 class="font-headline-md text-white">الطوب</h4>
                    <span class="text-primary-container font-bold uppercase text-xs">1,200 منتج</span>
                </div>
            </div>
            <div onclick="location.href='@Url.Action("Index", "Category", new { area = "Shop" })'" class="group relative aspect-square bg-surface-container overflow-hidden cursor-pointer border border-outline-variant/10">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&q=80&w=1000" alt="Tools" />
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface to-transparent opacity-60"></div>
                <div class="absolute bottom-6 right-6">
                    <h4 class="font-headline-md text-white">الأدوات</h4>
                    <span class="text-primary-container font-bold uppercase text-xs">2,400 منتج</span>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-surface-container-low py-xl">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex justify-between items-end mb-md">
                <h2 class="font-headline-lg uppercase border-r-4 border-primary-container pr-4">الأكثر مبيعاً</h2>
                <div class="flex gap-2">
                    <button class="w-10 h-10 border border-outline bg-white flex items-center justify-center hover:bg-primary-container hover:text-on-primary-container transition-colors">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </button>
                    <button class="w-10 h-10 border border-outline bg-white flex items-center justify-center hover:bg-primary-container hover:text-on-primary-container transition-colors">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter">
                <!-- Product Card -->
                <div onclick="location.href='@Url.Action("Index", "Product", new { area = "Shop" })'" class="bg-white border border-outline-variant/30 flex flex-col shadow-hard group text-right cursor-pointer">
                    <div class="aspect-[4/3] bg-surface-container-highest relative overflow-hidden">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://images.unsplash.com/photo-1504148455328-c376907d081c?auto=format&fit=crop&q=80&w=1000" alt="Drill" />
                        <span class="absolute top-4 right-4 bg-on-surface text-white font-bold px-2 py-1 text-[10px] uppercase">SKU: DX-4092</span>
                    </div>
                    <div class="p-4 flex flex-col gap-2">
                        <h5 class="font-bold uppercase text-on-surface">مثقاب كهربائي 20 فولت</h5>
                        <div class="flex justify-between items-center mt-2">
                            <span class="font-headline-md text-primary">189.99 ر.س</span>
                            <span class="text-xs text-on-surface-variant">متوفر</span>
                        </div>
                        <button onclick="event.stopPropagation();" class="mt-4 w-full bg-primary-container text-on-primary-container font-bold py-3 uppercase tracking-wider flex items-center justify-center gap-2 transition-all active:opacity-80">
                            <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                            أضف إلى السلة
                        </button>
                    </div>
                </div>
                <!-- Add more cards as needed -->
            </div>
        </div>
    </section>

    <section class="bg-surface py-xl">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-md gap-4">
                <div>
                    <span class="text-primary font-bold uppercase text-xs tracking-widest">تحديثات حية</span>
                    <h2 class="font-headline-lg uppercase border-r-4 border-primary-container pr-4 mt-2">أسعار السوق اليوم</h2>
                </div>
                <p class="text-on-surface-variant text-sm max-w-md md:text-left">أسعار المواد الأساسية في السوق المحلي بالأردن (تحديث كل 24 ساعة).</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
                <div class="bg-white border border-outline-variant p-6 shadow-hard flex items-center justify-between group hover:border-primary transition-colors">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-surface-container flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary">architecture</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-on-surface">حديد التسليح</h4>
                            <p class="text-[10px] text-on-surface-variant uppercase">طن / 12 ملم</p>
                        </div>
                    </div>
                    <div class="text-left">
                        <span class="font-headline-md text-on-surface">645.00 <span class="text-xs">ر.س</span></span>
                        <div class="flex items-center gap-1 text-[10px] text-success justify-end">
                            <span class="material-symbols-outlined text-[12px]">trending_up</span>
                            <span>+2.4%</span>
                        </div>
                    </div>
                </div>
                <div class="bg-white border border-outline-variant p-6 shadow-hard flex items-center justify-between group hover:border-primary transition-colors">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-surface-container flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary">foundation</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-on-surface">الأسمنت البورتلاندي</h4>
                            <p class="text-[10px] text-on-surface-variant uppercase">طن / مكيس</p>
                        </div>
                    </div>
                    <div class="text-left">
                        <span class="font-headline-md text-on-surface">112.50 <span class="text-xs">ر.س</span></span>
                        <div class="flex items-center gap-1 text-[10px] text-error justify-end">
                            <span class="material-symbols-outlined text-[12px]">trending_down</span>
                            <span>-0.8%</span>
                        </div>
                    </div>
                </div>
                <div class="bg-white border border-outline-variant p-6 shadow-hard flex items-center justify-between group hover:border-primary transition-colors">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-surface-container flex items-center justify-center">
                            <span class="material-symbols-outlined text-primary">grid_view</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-on-surface">بلوك 20 سم</h4>
                            <p class="text-[10px] text-on-surface-variant uppercase">1000 حبة</p>
                        </div>
                    </div>
                    <div class="text-left">
                        <span class="font-headline-md text-on-surface">4,200 <span class="text-xs">ر.س</span></span>
                        <div class="flex items-center gap-1 text-[10px] text-outline-variant justify-end">
                            <span class="material-symbols-outlined text-[12px]">horizontal_rule</span>
                            <span>0.0%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-on-surface py-xl">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-margin items-center">
            <div class="flex flex-col gap-6 text-right">
                <h2 class="font-headline-xl text-white">المشاريع الكبيرة تتطلب تسعيراً دقيقاً.</h2>
                <p class="text-secondary-fixed-dim font-body-lg">قم بتوسيع مشروعك بكفاءة. تقدم بوابة B2B الخاصة بنا خصومات على الكميات، وعمليات تسليم مجدولة، وإدارة حسابات مخصصة لشركات الإنشاءات.</p>
                <div class="flex flex-col gap-4">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-primary-container mt-1">verified</span>
                        <div>
                            <h6 class="text-white font-bold">توريد مضمون</h6>
                            <p class="text-sm text-slate-400">تأمين المخزون لمراحل المشروع طويلة الأجل.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-primary-container mt-1">local_shipping</span>
                        <div>
                            <h6 class="text-white font-bold">دعم لوجستي</h6>
                            <p class="text-sm text-slate-400">جداول تسليم مخصصة لمواقع متعددة.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-10 shadow-hard text-right">
                <h3 class="font-headline-md text-on-surface mb-8 uppercase tracking-tight">اطلب عرض سعر للكميات</h3>
                <form class="flex flex-col gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">اسم الشركة</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all text-right" type="text" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">اسم المسؤول</label>
                            <input class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all text-right" type="text" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">نوع المشروع</label>
                            <select class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all text-right">
                                <option>سكني</option>
                                <option>تجاري</option>
                                <option>صناعي</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <button type="submit" class="w-full bg-primary text-white font-bold py-4 uppercase tracking-widest hover:opacity-90 transition-all">
                            إرسال الطلب
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</main>