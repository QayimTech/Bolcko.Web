                <h2 class="font-headline-xl text-white">BULK PROJECTS REQUIRE PRECISION PRICING.</h2>
                <p class="text-secondary-fixed-dim font-body-lg">Scale your project efficiently. Our B2B portal offers volume discounts, scheduled deliveries, and dedicated account management for construction firms.</p>
                <div class="flex flex-col gap-4">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-primary-container mt-1">verified</span>
                        <div>
                            <h6 class="text-white font-label-bold">Guaranteed Supply</h6>
                            <p class="text-sm text-slate-400">Lock in inventory for long-term project phases.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-primary-container mt-1">local_shipping</span>
                        <div>
                            <h6 class="text-white font-label-bold">Logistic Support</h6>
                            <p class="text-sm text-slate-400">Custom multi-site delivery schedules.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-white p-10 hard-shadow">
                <h3 class="font-headline-md text-on-surface mb-8 uppercase tracking-tight">Request Bulk Quote</h3>
                <form class="flex flex-col gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">Company Name</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all" type="text" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">Contact Name</label>
                            <input class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all" type="text" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">Project Scale</label>
                            <select class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all">
                                <option>Residential</option>
                                <option>Commercial</option>
                                <option>Industrial</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-on-surface-variant mb-1">Estimated Budget</label>
                        <input class="w-full bg-surface-container-low border border-outline-variant p-3 focus:ring-0 focus:border-primary transition-all" placeholder="$5,000+" type="text" />
                    </div>
                    <button class="bg-on-surface text-white font-label-bold py-4 mt-4 uppercase tracking-widest hover:bg-primary transition-colors" type="submit">
                        Initialize Inquiry
                    </button>
                </form>
            </div>
