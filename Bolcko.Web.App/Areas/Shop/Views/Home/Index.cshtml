@{
    ViewData["Title"] = SharedLocalizer["Home"];
}

<main class="bg-[#faf8ff] text-[#161b28] w-full overflow-hidden">
    <!-- Hero Section -->
    <section class="relative bg-[#0D111A] text-white flex items-center overflow-hidden py-10 md:py-14">
        <!-- Glowing background decoration (RTL aware & bounds safe) -->
        <div class="absolute top-0 end-0 w-[350px] sm:w-[500px] h-[350px] sm:h-[500px] bg-[#E8A020]/10 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 start-0 w-[200px] sm:w-[300px] h-[200px] sm:h-[300px] bg-blue-500/10 rounded-full blur-[100px] pointer-events-none"></div>
        

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 w-full grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
            <div class="flex flex-col gap-6 md:gap-8 text-start">
                <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#E8A020] bg-[#E8A020]/10 px-3.5 py-1.5 rounded-full w-max">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#E8A020] animate-pulse"></span>
                    @SharedLocalizer["HomeHeroBadge"]
                </span>
                <h1 class="font-headline-xl text-white leading-tight text-2xl sm:text-4xl md:text-5xl">@(ViewBag.HomeHeroTitle ?? SharedLocalizer["HomeHeroTitle"].Value)</h1>
                <p class="font-body-lg text-slate-300 max-w-lg leading-relaxed text-sm sm:text-base">@(ViewBag.HomeHeroDesc ?? SharedLocalizer["HomeHeroDesc"].Value)</p>
                
                <div class="flex flex-col sm:flex-row flex-wrap gap-3 justify-start">
                    <a href="@Url.Action("Index", "Category")" 
                       class="bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold px-6 md:px-8 py-3.5 rounded-2xl shadow-[0_8px_25px_rgba(232,160,32,0.2)] transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 flex items-center justify-center gap-2 text-center text-sm">
                        <span>@SharedLocalizer["BrowseProducts"]</span>
                        <span class="material-symbols-outlined text-base rtl:-scale-x-100">arrow_forward</span>
                    </a>
                    <a href="@Url.Action("Request", "Quote", new { area = "Shop" })" 
                       class="bg-white/5 border border-white/10 hover:bg-white/10 text-white font-bold px-6 md:px-8 py-3.5 rounded-2xl transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 text-center text-sm">
                        @SharedLocalizer["RequestQuote"]
                    </a>
                </div>
            </div>
            
            <div class="hidden md:flex items-center justify-center">
                <!-- Premium Glassmorphic Feature Card -->
                <div class="bg-white/5 backdrop-blur-md border border-white/10 p-8 rounded-3xl flex flex-col gap-4 max-w-sm text-start shadow-2xl relative">
                    <div class="absolute -top-3 -end-3 w-12 h-12 bg-[#E8A020] rounded-2xl flex items-center justify-center text-[#151B26] shadow-lg">
                        <span class="material-symbols-outlined font-bold">local_shipping</span>
                    </div>
                    <span class="text-[#E8A020] font-bold uppercase text-xs tracking-wider pt-2">@SharedLocalizer["ShippingBadge"]</span>
                    <h3 class="font-headline-md text-white">@SharedLocalizer["ShippingTitle"]</h3>
                    <p class="text-sm text-slate-300 leading-relaxed">@SharedLocalizer["ShippingDesc"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="py-10 md:py-14 max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex justify-between items-end mb-6 md:mb-8 text-start">
            <div>
                <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["BrowseSmartly"]</span>
                <h2 class="font-headline-lg border-s-4 border-[#E8A020] ps-4 mt-2 text-xl sm:text-2xl md:text-3xl">@SharedLocalizer["FeaturedCategories"]</h2>
            </div>
            <a class="font-bold text-[#E8A020] hover:underline underline-offset-4 flex items-center gap-1.5 transition-all text-xs sm:text-sm" 
               href="@Url.Action("Index", "Category", new { area = "Shop" })">
                <span>@SharedLocalizer["ViewAll"]</span>
                <span class="material-symbols-outlined text-sm rtl:-scale-x-100">arrow_forward</span>
            </a>
        </div>
        
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3 sm:gap-5">
            @foreach (var cat in (IEnumerable<Bolcko.Domain.Entities.Catalog.DTOs.CategoryDto>)ViewBag.Categories)
            {
                <a href="@Url.Action("Index", "Category", new { area = "Shop", id = cat.Id })" 
                   class="group flex flex-col items-center text-center bg-white border border-slate-100 rounded-[24px] p-4 sm:p-6 shadow-sm hover:shadow-[0_15px_40px_-10px_rgba(232,160,32,0.15)] hover:border-[#E8A020]/40 transition-all duration-500 hover:-translate-y-1.5 relative overflow-hidden">
                    
                    <div class="absolute inset-0 bg-gradient-to-b from-[#fffaf0] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                    <div class="relative w-12 h-12 sm:w-16 sm:h-16 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-500 shadow-sm group-hover:shadow-md mb-3 sm:mb-4 transform group-hover:scale-110">
                        <span class="material-symbols-outlined text-2xl sm:text-3xl">@(string.IsNullOrWhiteSpace(cat.ImageUrl) ? "category" : cat.ImageUrl)</span>
                    </div>
                    
                    <div class="relative flex flex-col items-center w-full min-w-0">
                        <h3 class="font-bold text-slate-800 text-xs sm:text-sm group-hover:text-[#E8A020] transition-colors duration-300 line-clamp-2 w-full px-1" title="@cat.Name">@cat.Name</h3>
                        <span class="text-[9px] sm:text-[11px] text-slate-500 font-medium mt-2 bg-slate-100 px-2 py-0.5 rounded-lg group-hover:bg-[#E8A020]/10 group-hover:text-[#d18f1c] transition-colors truncate max-w-full">@string.Format(SharedLocalizer["ProductsAvailableForOrder"].Value, cat.ProductCount)</span>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- Best Sellers Section -->
    <section class="bg-white py-10 md:py-14 border-y border-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="flex justify-between items-end mb-8 text-start">
                <div>
                    <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["CustomerFavorites"]</span>
                    <h2 class="font-headline-lg border-s-4 border-[#E8A020] ps-4 mt-2">@SharedLocalizer["BestSellingProducts"]</h2>
                </div>
                <div class="flex gap-2">
                    <button type="button" aria-label="@SharedLocalizer["Previous"]" class="w-11 h-11 border border-slate-100 rounded-xl bg-white flex items-center justify-center hover:bg-[#E8A020] hover:text-[#151B26] transition-all duration-200">
                        <span class="material-symbols-outlined text-lg rtl:-scale-x-100">chevron_left</span>
                    </button>
                    <button type="button" aria-label="@SharedLocalizer["Next"]" class="w-11 h-11 border border-slate-100 rounded-xl bg-white flex items-center justify-center hover:bg-[#E8A020] hover:text-[#151B26] transition-all duration-200">
                        <span class="material-symbols-outlined text-lg rtl:-scale-x-100">chevron_right</span>
                    </button>
                </div>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var product in (IEnumerable<Bolcko.Domain.Entities.Product.DTOs.ProductDto>)ViewBag.FeaturedProducts)
                {
                    <partial name="Partials/_ProductCard" model="product" />
                }
            </div>
        </div>
    </section>


    <!-- B2B Quote Section -->
    <section class="bg-[#0D111A] py-14 relative overflow-hidden">
        <div class="absolute top-0 start-0 w-[400px] h-[400px] bg-[#E8A020]/5 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-8 md:gap-16 items-center">
            <div class="flex flex-col gap-6 text-start text-white">
                <span class="text-xs font-bold uppercase tracking-widest text-[#E8A020]">@SharedLocalizer["CorporateAccounts"]</span>
                <h2 class="font-headline-xl text-white">@SharedLocalizer["BigProjectsTitle"]</h2>
                <p class="text-slate-300 font-body-lg leading-relaxed">@SharedLocalizer["BigProjectsDesc"]</p>
                
                <div class="flex flex-col gap-6 mt-4">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#E8A020] flex-shrink-0">
                            <span class="material-symbols-outlined text-xl">verified</span>
                        </div>
                        <div>
                            <h6 class="text-white font-bold text-sm">@SharedLocalizer["GuaranteedSupply"]</h6>
                            <p class="text-xs text-slate-400 mt-1">@SharedLocalizer["GuaranteedSupplyDesc"]</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[#E8A020] flex-shrink-0">
                            <span class="material-symbols-outlined text-xl">local_shipping</span>
                        </div>
                        <div>
                            <h6 class="text-white font-bold text-sm">@SharedLocalizer["AdvancedLogistics"]</h6>
                            <p class="text-xs text-slate-400 mt-1">@SharedLocalizer["AdvancedLogisticsDesc"]</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Custom Quote Form Card -->
            <div class="bg-white/5 backdrop-blur-md border border-white/10 p-10 rounded-3xl shadow-2xl text-start relative">
                <h3 class="font-headline-md text-white mb-8">@SharedLocalizer["RequestBulkQuote"]</h3>
                <form asp-action="Request" asp-controller="Quote" asp-area="Shop" method="get" class="flex flex-col gap-6">
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["CompanyName"]</label>
                        <input name="CompanyName" class="w-full bg-white/5 border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-start text-xs font-semibold" type="text" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["ContactPerson"]</label>
                            <input name="FullName" class="w-full bg-white/5 border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-start text-xs font-semibold" type="text" />
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold uppercase text-slate-300 mb-2">@SharedLocalizer["ProjectType"]</label>
                             <select name="ProjectType" class="w-full bg-white/5 border border-white/10 rounded-xl p-3.5 focus:outline-none focus:ring-1 focus:ring-[#E8A020] focus:border-[#E8A020] transition-all text-white text-start text-xs font-semibold appearance-none" style="background-image: url('data:image/svg+xml;charset=utf-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%2394a3b8%22%3E%3Cpath d=%22M7 10l5 5 5-5z%22/%3E%3C/svg%3E'); background-position: inline-start 0.75rem center; background-repeat: no-repeat; background-size: 1.2em; padding-inline-start: 2.5rem;">
                                <option value="Residential" class="bg-[#151B26] text-white">@SharedLocalizer["Residential"]</option>
                                <option value="Commercial" class="bg-[#151B26] text-white">@SharedLocalizer["Commercial"]</option>
                                <option value="Industrial" class="bg-[#151B26] text-white">@SharedLocalizer["Industrial"]</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <button type="submit" 
                                class="w-full bg-[#E8A020] hover:bg-[#ffb94c] text-[#151B26] font-bold py-4 rounded-xl transition-all duration-300 transform active:scale-95 shadow-[0_6px_20px_rgba(232,160,32,0.15)]">
                            @SharedLocalizer["SubmitRequest"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <!-- Trust Features Section -->
    <section class="bg-white py-10 md:py-12 border-t border-slate-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">local_shipping</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["FastDelivery"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["FastDeliveryDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">verified_user</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["WarrantyMatching"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["WarrantyMatchingDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">support_agent</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["TechnicalSupport"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["TechnicalSupportDesc"]</p>
                </div>
                <div class="flex flex-col items-center text-center gap-4 group p-6 rounded-2xl hover:bg-slate-50 transition-colors duration-300">
                    <div class="w-14 h-14 bg-[#E8A020]/10 rounded-2xl flex items-center justify-center text-[#E8A020] group-hover:bg-[#E8A020] group-hover:text-[#151B26] transition-all duration-300">
                        <span class="material-symbols-outlined text-2xl font-bold">payments</span>
                    </div>
                    <h4 class="font-bold text-slate-800">@SharedLocalizer["FlexiblePayments"]</h4>
                    <p class="text-xs text-slate-400 leading-relaxed">@SharedLocalizer["FlexiblePaymentsDesc"]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section: Market Prices rendered via deferred lightweight AJAX with a clean skeleton placeholder -->
    <section class="w-full py-10 md:py-16 px-4 sm:px-6 bg-surface-container-lowest border-t border-outline-variant relative z-10">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                <div>
                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-green-500/10 text-green-500 font-bold text-xs uppercase tracking-wider rounded-full mb-3">
                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                        @(SharedLocalizer["LiveAndUpdated"].ResourceNotFound ? "مباشر ومُحدّث" : SharedLocalizer["LiveAndUpdated"])
                    </span>
                    <h2 class="font-headline-lg text-on-surface font-black">@(SharedLocalizer["LocalMarketMaterialPrices"].ResourceNotFound ? "أسعار المواد في السوق المحلي" : SharedLocalizer["LocalMarketMaterialPrices"])</h2>
                </div>
                <p class="text-on-surface-variant max-w-md text-xs md:text-sm leading-relaxed">
                    @SharedLocalizer["MarketPricesDesc"]
                </p>
            </div>

            <div id="market-prices-container">
                <!-- Sleek, premium skeleton placeholders matching the exact card design -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter animate-pulse">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="bg-white border border-outline-variant p-6 shadow-hard flex items-center justify-between">
                            <div class="flex items-center gap-4 w-2/3">
                                <div class="w-12 h-12 bg-slate-100 rounded-lg shrink-0"></div>
                                <div class="flex-grow flex flex-col gap-2">
                                    <div class="h-4 bg-slate-100 rounded w-5/6"></div>
                                    <div class="h-3 bg-slate-100 rounded w-1/3"></div>
                                </div>
                            </div>
                            <div class="w-1/4 flex flex-col items-end gap-2">
                                <div class="h-5 bg-slate-100 rounded w-2/3"></div>
                                <div class="h-3 bg-slate-100 rounded w-1/2"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/js/services/market-prices-service.js" asp-append-version="true" defer></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Load market prices in background asynchronously using the centralized ApiClient
            setTimeout(function() {
                if (window.MarketPricesService && typeof window.MarketPricesService.fetchPricesHtml === 'function') {
                    window.MarketPricesService.fetchPricesHtml('@Url.Action("GetMarketPrices", "Home", new { area = "Shop" })')
                        .then(function(html) {
                            const container = document.getElementById('market-prices-container');
                            if (container && html) {
                                container.innerHTML = html;
                            }
                        })
                        .catch(function(err) {
                            if (err.name !== 'AbortError') {
                                console.warn('Deferred market prices fetch cancelled or failed: ', err);
                                const container = document.getElementById('market-prices-container');
                                if (container) {
                                    container.style.display = 'none';
                                }
                            }
                        });
                }
            }, 100);
        });
    </script>
}