@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Globalization
@{
    bool isRtl = CultureInfo.CurrentCulture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase);

    string searchPlaceholder = ViewData["SearchPlaceholder"] as string ?? (isRtl ? "بحث بالاسم، الوصف، أو الـ SKU..." : "Search by name, description, or SKU...");
    string searchValue = ViewData["SearchValue"] as string ?? "";
    string currentSortOrder = ViewData["SortOrder"] as string ?? "desc";

    string selectName = ViewData["SelectName"] as string ?? "";
    string selectLabel = ViewData["SelectLabel"] as string ?? (isRtl ? "جميع التصنيفات" : "All Categories");
    string selectValue = ViewData["SelectValue"] as string ?? "";
    var selectOptions = ViewData["SelectOptions"] as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();

    string actionName = ViewData["Action"] as string ?? "Index";
    string controllerName = ViewData["Controller"] as string ?? "";

    bool hasActiveFilter = !string.IsNullOrEmpty(searchValue) || !string.IsNullOrEmpty(selectValue) || (currentSortOrder != "desc" && !string.IsNullOrEmpty(currentSortOrder));

    bool hasSelect = !string.IsNullOrEmpty(selectName);

    string filterBtnText = isRtl ? "تصفية" : "Filter";
    string resetBtnText = isRtl ? "إعادة ضبط" : "Reset";
}

<!-- Adaptive Filter Component: Smart Layout for Multi-Filter vs Single-Filter Views -->
<div class="bg-slate-50 border-b border-slate-200 p-4 rounded-t-2xl" dir="@(isRtl ? "rtl" : "ltr")">
    <form method="get" action="@Url.Action(actionName, controllerName)" id="gridFilterForm" class="space-y-3">
        
        <input type="hidden" name="sortOrder" value="@currentSortOrder" id="gridSortOrderInput" />

        @if (hasSelect)
        {
            <!-- Multi-Filter View (e.g. Products / Orders): 3-Column Split Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-center">
                
                <!-- 1. Search Bar -->
                <div class="bg-white border border-slate-300 rounded-xl px-3 py-2 flex items-center gap-2.5 shadow-sm hover:border-slate-400 focus-within:border-[#E8A020] focus-within:ring-2 focus-within:ring-[#E8A020]/20 transition-all">
                    <div class="flex items-center justify-center shrink-0 text-slate-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>

                    <input type="text" 
                           name="search" 
                           value="@searchValue" 
                           placeholder="@searchPlaceholder" 
                           class="w-full bg-transparent border-0 p-0 text-slate-900 text-xs font-medium focus:ring-0 focus:outline-none placeholder:text-slate-400" />
                    
                    @if (!string.IsNullOrEmpty(searchValue))
                    {
                        <a href="@Url.Action(actionName, controllerName)" class="flex items-center justify-center shrink-0 text-slate-400 hover:text-red-500 transition-colors" title="@resetBtnText">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </a>
                    }
                </div>

                <!-- 2. Select DDL Dropdown -->
                <div class="bg-white border border-slate-300 rounded-xl px-3 py-2 flex items-center justify-between shadow-sm hover:border-slate-400 focus-within:border-[#E8A020] focus-within:ring-2 focus-within:ring-[#E8A020]/20 transition-all">
                    <div class="flex items-center justify-center shrink-0 text-slate-400 me-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                        </svg>
                    </div>

                    <select name="@selectName" 
                            onchange="this.form.submit()" 
                            class="w-full bg-transparent border-0 p-0 text-slate-800 text-xs font-bold appearance-none cursor-pointer focus:ring-0 focus:outline-none">
                        <option value="">@selectLabel</option>
                        @foreach (var opt in selectOptions)
                        {
                            bool isSelected = opt.Value == selectValue;
                            <option value="@opt.Value" selected="@isSelected">@opt.Text</option>
                        }
                    </select>

                    <div class="flex items-center justify-center shrink-0 text-slate-400 pointer-events-none ms-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </div>

                <!-- 3. Action Buttons -->
                <div class="flex items-center gap-2 justify-start">
                    <button type="submit" class="px-5 py-2 bg-[#E8A020] hover:bg-[#d89218] text-white font-extrabold text-xs rounded-xl shadow-sm hover:shadow active:scale-95 transition-all flex items-center justify-center gap-2 border border-[#E8A020]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                        </svg>
                        <span>@filterBtnText</span>
                    </button>

                    @if (hasActiveFilter)
                    {
                        <a href="@Url.Action(actionName, controllerName)" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold text-xs rounded-xl border border-slate-300 active:scale-95 transition-all flex items-center justify-center gap-1.5" title="@resetBtnText">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                            <span>@resetBtnText</span>
                        </a>
                    }
                </div>

            </div>
        }
        else
        {
            <!-- Single-Filter View (e.g. Categories): Clean Search Bar with Action Button Right Next To It -->
            <div class="flex flex-col sm:flex-row items-center gap-3">
                
                <!-- Expanded Search Bar -->
                <div class="flex-1 w-full bg-white border border-slate-300 rounded-xl px-3 py-2 flex items-center gap-2.5 shadow-sm hover:border-slate-400 focus-within:border-[#E8A020] focus-within:ring-2 focus-within:ring-[#E8A020]/20 transition-all">
                    <div class="flex items-center justify-center shrink-0 text-slate-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>

                    <input type="text" 
                           name="search" 
                           value="@searchValue" 
                           placeholder="@searchPlaceholder" 
                           class="w-full bg-transparent border-0 p-0 text-slate-900 text-xs font-medium focus:ring-0 focus:outline-none placeholder:text-slate-400" />
                    
                    @if (!string.IsNullOrEmpty(searchValue))
                    {
                        <a href="@Url.Action(actionName, controllerName)" class="flex items-center justify-center shrink-0 text-slate-400 hover:text-red-500 transition-colors" title="@resetBtnText">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </a>
                    }
                </div>

                <!-- Action Button Right Next To Search Bar -->
                <div class="flex items-center gap-2 shrink-0">
                    <button type="submit" class="px-5 py-2 bg-[#E8A020] hover:bg-[#d89218] text-white font-extrabold text-xs rounded-xl shadow-sm hover:shadow active:scale-95 transition-all flex items-center justify-center gap-2 border border-[#E8A020]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                        </svg>
                        <span>@filterBtnText</span>
                    </button>

                    @if (hasActiveFilter)
                    {
                        <a href="@Url.Action(actionName, controllerName)" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold text-xs rounded-xl border border-slate-300 active:scale-95 transition-all flex items-center justify-center gap-1.5" title="@resetBtnText">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                            <span>@resetBtnText</span>
                        </a>
                    }
                </div>

            </div>
        }

        <!-- Filter Status Tags -->
        @if (hasActiveFilter)
        {
            <div class="flex flex-wrap items-center gap-2 pt-1 text-xs">
                <span class="text-slate-400 font-medium">الفلاتر النشطة:</span>
                @if (!string.IsNullOrEmpty(searchValue))
                {
                    <span class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 text-amber-800 px-2.5 py-0.5 rounded-lg font-semibold">
                        بحث: "@searchValue"
                    </span>
                }
                @if (!string.IsNullOrEmpty(selectValue))
                {
                    var selectedText = selectOptions.FirstOrDefault(x => x.Value == selectValue)?.Text ?? selectValue;
                    <span class="inline-flex items-center gap-1 bg-blue-50 border border-blue-200 text-blue-800 px-2.5 py-0.5 rounded-lg font-semibold">
                        التصنيف: @selectedText
                    </span>
                }
            </div>
        }
    </form>
</div>
