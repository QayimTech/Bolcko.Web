@model (bool IsIconOnly, bool IsAdmin, string Theme, string Height)
@{
    bool isIconOnly = Model.IsIconOnly;
    bool isAdmin = Model.IsAdmin;
    string theme = Model.Theme ?? "light";
    string height = Model.Height ?? "h-10";

    string textFill = theme == "dark" ? "#FFFFFF" : "#0F172A";
    string subtitleFill = theme == "dark" ? "#8A95A8" : "#64748B";
}

<div class="flex items-center gap-3" dir="ltr">
    @if (isIconOnly)
    {
        <svg viewBox="0 0 76 70" class="@height aspect-square w-auto" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect x="15" y="12" width="46" height="46" rx="8" fill="#E8A020"/>
            <path d="M29.5 22.5h11c4.1 0 7.5 2.7 7.5 6.1 0 2.2-1.2 4.1-3.2 5.1 2.5 1 4.2 3.2 4.2 5.6 0 3.4-3.4 6.1-7.5 6.1h-11v-22.9z" fill="#FFFFFF"/>
            <rect x="34.5" y="27" width="5" height="5.5" rx="1" fill="#E8A020"/>
            <rect x="34.5" y="35.8" width="5" height="6.5" rx="1" fill="#E8A020"/>
        </svg>
    }
    else if (isAdmin)
    {
        <svg viewBox="0 0 420 85" class="@height w-auto" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect x="15" y="12" width="46" height="46" rx="8" fill="#E8A020"/>
            <path d="M29.5 22.5h11c4.1 0 7.5 2.7 7.5 6.1 0 2.2-1.2 4.1-3.2 5.1 2.5 1 4.2 3.2 4.2 5.6 0 3.4-3.4 6.1-7.5 6.1h-11v-22.9z" fill="#FFFFFF"/>
            <rect x="34.5" y="27" width="5" height="5.5" rx="1" fill="#E8A020"/>
            <rect x="34.5" y="35.8" width="5" height="6.5" rx="1" fill="#E8A020"/>
            @Html.Raw($"<text x=\"72\" y=\"47\" font-family=\"'Space Grotesk', sans-serif\" font-weight=\"800\" font-size=\"34\" fill=\"{textFill}\" letter-spacing=\"1\">BLOCKO</text>")
            @Html.Raw($"<text x=\"255\" y=\"47\" font-family=\"'Space Grotesk', sans-serif\" font-weight=\"800\" font-size=\"34\" fill=\"#E8A020\" letter-spacing=\"1\">ADMIN</text>")
            @Html.Raw($"<text x=\"18\" y=\"72\" font-family=\"'Space Grotesk', sans-serif\" font-weight=\"600\" font-size=\"7.5\" fill=\"{subtitleFill}\" letter-spacing=\"4\">DASHBOARD MANAGEMENT</text>")
        </svg>
    }
    else
    {
        <svg viewBox="0 0 300 85" class="@height w-auto" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect x="15" y="12" width="46" height="46" rx="8" fill="#E8A020"/>
            <path d="M29.5 22.5h11c4.1 0 7.5 2.7 7.5 6.1 0 2.2-1.2 4.1-3.2 5.1 2.5 1 4.2 3.2 4.2 5.6 0 3.4-3.4 6.1-7.5 6.1h-11v-22.9z" fill="#FFFFFF"/>
            <rect x="34.5" y="27" width="5" height="5.5" rx="1" fill="#E8A020"/>
            <rect x="34.5" y="35.8" width="5" height="6.5" rx="1" fill="#E8A020"/>
            @Html.Raw($"<text x=\"72\" y=\"47\" font-family=\"'Space Grotesk', sans-serif\" font-weight=\"800\" font-size=\"34\" fill=\"{textFill}\" letter-spacing=\"1\">BLOCKO</text>")
            @Html.Raw($"<text x=\"18\" y=\"72\" font-family=\"'Space Grotesk', sans-serif\" font-weight=\"600\" font-size=\"7.5\" fill=\"{subtitleFill}\" letter-spacing=\"4\">CONSTRUCTION SUPPLIES</text>")
        </svg>
    }
</div>
