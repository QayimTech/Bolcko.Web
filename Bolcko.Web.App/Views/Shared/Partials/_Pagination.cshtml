@using Bolcko.Domain.Common
@model IPagedList<object>

@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between border-t border-slate-200 px-6 py-4">
        <div class="text-sm text-slate-500">
            عرض @(((Model.PageIndex - 1) * Model.PageSize + 1)) - @Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount) من @Model.TotalCount
        </div>
        <div class="flex items-center gap-2">
            @if (Model.HasPreviousPage)
            {
                <a href="?page=@(Model.PageIndex - 1)&pageSize=@Model.PageSize" 
                   class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    السابق
                </a>
            }
            
            <div class="flex items-center gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageIndex - 2 || i == Model.PageIndex - 1 || i == Model.PageIndex || i == Model.PageIndex + 1 || i == Model.PageIndex + 2 || i == 1 || i == Model.TotalPages)
                    {
                        <a href="?page=@i&pageSize=@Model.PageSize" 
                           class="@(i == Model.PageIndex ? "bg-[#E8A020] text-[#1B2235]" : "bg-slate-100 text-slate-700 hover:bg-slate-200") px-3 py-2 text-sm font-medium rounded-lg transition-all">
                            @i
                        </a>
                    }
                    else if (i == Model.PageIndex - 3 || i == Model.PageIndex + 3)
                    {
                        <span class="text-slate-400 px-1">...</span>
                    }
                }
            </div>
            
            @if (Model.HasNextPage)
            {
                <a href="?page=@(Model.PageIndex + 1)&pageSize=@Model.PageSize" 
                   class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    التالي
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                </a>
            }
        </div>
    </div>
}
