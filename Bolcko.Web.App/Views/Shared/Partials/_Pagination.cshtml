@* 
    Parameters (passed via ViewBag or ViewData):
    - ViewBag.CurrentPage
    - ViewBag.TotalPages
    - ViewBag.TotalItems
    - ViewBag.PageSize
*@

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    bool hasPreviousPage = currentPage > 1;
    bool hasNextPage = currentPage < totalPages;
}

@if (totalPages > 1)
{
    <div class="flex items-center justify-between border-t border-slate-200 px-6 py-4">
        <div class="text-sm text-slate-500">
            عرض @(((currentPage - 1) * pageSize + 1)) - @Math.Min(currentPage * pageSize, totalItems) من @totalItems
        </div>
        <div class="flex items-center gap-2">
            @if (hasPreviousPage)
            {
                <a href="?page=@(currentPage - 1)&pageSize=@pageSize" 
                   class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    السابق
                </a>
            }
            
            <div class="flex items-center gap-1">
                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage - 2 || i == currentPage - 1 || i == currentPage || i == currentPage + 1 || i == currentPage + 2 || i == 1 || i == totalPages)
                    {
                        <a href="?page=@i&pageSize=@pageSize" 
                           class="@(i == currentPage ? "bg-[#E8A020] text-[#1B2235]" : "bg-slate-100 text-slate-700 hover:bg-slate-200") px-3 py-2 text-sm font-medium rounded-lg transition-all">
                            @i
                        </a>
                    }
                    else if (i == currentPage - 3 || i == currentPage + 3)
                    {
                        <span class="text-slate-400 px-1">...</span>
                    }
                }
            </div>
            
            @if (hasNextPage)
            {
                <a href="?page=@(currentPage + 1)&pageSize=@pageSize" 
                   class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    التالي
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                </a>
            }
        </div>
    </div>
}
