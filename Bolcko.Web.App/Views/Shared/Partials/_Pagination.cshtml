@using Bolcko.Domain.Common
@model IPagedList<object>

@{
    // Build base URL preserving existing querystring except page/pageSize
    var currentQuery = Context.Request.Query
        .Where(q => !q.Key.Equals("page", StringComparison.OrdinalIgnoreCase)
                 && !q.Key.Equals("pageSize", StringComparison.OrdinalIgnoreCase))
        .Select(q => $"{q.Key}={Uri.EscapeDataString(q.Value.ToString())}")
        .ToList();
    string baseQs = currentQuery.Count > 0 ? "&" + string.Join("&", currentQuery) : "";

    string PageUrl(int p) => $"?page={p}&pageSize={Model.PageSize}{baseQs}";
}

@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between border-t border-slate-200 px-6 py-4" dir="rtl">
        <div class="text-sm text-slate-500">
            عرض @(((Model.PageIndex - 1) * Model.PageSize + 1)) - @Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount) من أصل @Model.TotalCount
        </div>
        <div class="flex items-center gap-2">

            @* زر التالي (→ للأمام) *@
            @if (Model.HasNextPage)
            {
                <a href="@PageUrl(Model.PageIndex + 1)"
                   class="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    التالي
                    <span class="material-symbols-outlined text-base leading-none">arrow_back</span>
                </a>
            }

            <div class="flex items-center gap-1">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    bool isActive     = i == Model.PageIndex;
                    bool isNear       = Math.Abs(i - Model.PageIndex) <= 2;
                    bool isEndpoint   = i == 1 || i == Model.TotalPages;
                    bool isEllipsis   = Math.Abs(i - Model.PageIndex) == 3;

                    if (isActive || isNear || isEndpoint)
                    {
                        <a href="@PageUrl(i)"
                           class="@(isActive ? "bg-[#E8A020] text-[#1B2235] shadow-sm" : "bg-slate-100 text-slate-700 hover:bg-slate-200") px-3 py-2 text-sm font-medium rounded-lg transition-all min-w-[36px] text-center">
                            @i
                        </a>
                    }
                    else if (isEllipsis)
                    {
                        <span class="text-slate-400 px-1 select-none">...</span>
                    }
                }
            </div>

            @* زر السابق (← للخلف) *@
            @if (Model.HasPreviousPage)
            {
                <a href="@PageUrl(Model.PageIndex - 1)"
                   class="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 hover:bg-slate-200 rounded-lg transition-all">
                    <span class="material-symbols-outlined text-base leading-none">arrow_forward</span>
                    السابق
                </a>
            }

        </div>
    </div>
}
