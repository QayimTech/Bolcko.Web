@model List<Bolcko.Web.App.Controllers.SitemapUrl>
@{
    ViewData["Title"] = "خريطة الموقع";
    Layout = "_Layout";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h2 class="mb-0 h4">
                        <i class="fas fa-sitemap me-2"></i>
                        خريطة الموقع (Sitemap)
                    </h2>
                    <a href="/sitemap.xml" class="btn btn-light btn-sm" target="_blank">
                        <i class="fas fa-code me-1"></i>
                        عرض XML
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 50px;">#</th>
                                    <th>الرابط (URL)</th>
                                    <th style="width: 120px;">الأولوية</th>
                                    <th style="width: 120px;">التكرار</th>
                                    <th style="width: 150px;">آخر تعديل</th>
                                    <th style="width: 80px;">فتح</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    var counter = 1;
                                    foreach (var url in Model)
                                    {
                                        <tr>
                                            <td class="text-center text-muted">@counter</td>
                                            <td>
                                                <span class="text-truncate d-inline-block" style="max-width: 400px;" title="@url.Loc">
                                                    @url.Loc.Replace(baseUrl, "~")
                                                </span>
                                            </td>
                                            <td>
                                                @if (url.Priority == "1.0")
                                                {
                                                    <span class="badge bg-success">@url.Priority</span>
                                                }
                                                else if (url.Priority == "0.9" || url.Priority == "0.8")
                                                {
                                                    <span class="badge bg-info">@url.Priority</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@url.Priority</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    @url.ChangeFreq
                                                </span>
                                            </td>
                                            <td class="text-muted small">
                                                @url.LastMod
                                            </td>
                                            <td>
                                                <a href="@url.Loc" target="_blank" class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-external-link-alt"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        counter++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="fas fa-inbox fa-3x mb-3"></i>
                                            <p class="mb-0">لا توجد روابط لعرضها</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                إجمالي الروابط: <strong>@(Model?.Count ?? 0)</strong> رابط
                            </small>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <a href="/sitemap.xml" class="btn btn-success btn-sm" download>
                                <i class="fas fa-download me-1"></i>
                                تحميل XML
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- معلومات إضافية -->
            <div class="row mt-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-home fa-2x text-primary mb-3"></i>
                            <h5 class="card-title">الصفحات الثابتة</h5>
                            <p class="card-text text-muted small">
                                الصفحة الرئيسية، من نحن، تواصل معنا، سياسة الخصوصية
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-tags fa-2x text-success mb-3"></i>
                            <h5 class="card-title">الفئات والتصنيفات</h5>
                            <p class="card-text text-muted small">
                                جميع فئات المنتجات المضافة ديناميكياً من قاعدة البيانات
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-box fa-2x text-info mb-3"></i>
                            <h5 class="card-title">المنتجات</h5>
                            <p class="card-text text-muted small">
                                جميع المنتجات المتوفرة في المتجر مع روابطها الديناميكية
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }
        .badge {
            font-size: 0.75rem;
        }
    </style>
}
