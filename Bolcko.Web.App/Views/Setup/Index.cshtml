@model Bolcko.Web.App.Controllers.SetupViewModel
@{
    Layout = null;
    ViewData["Title"] = "إعداد النظام - Bolcko";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #0a0f1e;
            --surface:   #111827;
            --card:      #1a2235;
            --border:    rgba(99,179,237,0.15);
            --accent:    #3b82f6;
            --accent-h:  #60a5fa;
            --gold:      #f59e0b;
            --danger:    #ef4444;
            --success:   #10b981;
            --text:      #e2e8f0;
            --muted:     #94a3b8;
            --radius:    16px;
        }

        html, body {
            min-height: 100vh;
            font-family: 'Tajawal', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        /* ── animated background ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 50% at 20% 10%,  rgba(59,130,246,.12) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 80%, rgba(245,158,11,.07) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        /* grid lines */
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(99,179,237,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(99,179,237,.04) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

        /* ── layout ── */
        .page {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 480px;
            animation: fadeUp .6s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── logo area ── */
        .logo-wrap {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo-icon {
            width: 72px;
            height: 72px;
            border-radius: 20px;
            background: linear-gradient(135deg, var(--accent), #6366f1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1rem;
            box-shadow: 0 8px 32px rgba(59,130,246,.35);
            animation: pulse 3s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% { box-shadow: 0 8px 32px rgba(59,130,246,.35); }
            50%       { box-shadow: 0 8px 48px rgba(59,130,246,.6); }
        }

        .logo-title {
            font-size: 1.75rem;
            font-weight: 800;
            background: linear-gradient(90deg, var(--accent-h), var(--gold));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo-sub {
            color: var(--muted);
            font-size: .9rem;
            margin-top: .25rem;
        }

        /* ── card ── */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2.25rem 2rem;
            backdrop-filter: blur(12px);
            box-shadow: 0 24px 64px rgba(0,0,0,.4);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: .75rem;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

        .step-badge {
            background: linear-gradient(135deg, var(--accent), #6366f1);
            color: #fff;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        .card-title { font-size: 1.15rem; font-weight: 700; }
        .card-desc  { font-size: .85rem; color: var(--muted); margin-top: .15rem; }

        /* ── alert box ── */
        .alert-info {
            background: rgba(59,130,246,.1);
            border: 1px solid rgba(59,130,246,.3);
            border-radius: 10px;
            padding: .85rem 1rem;
            font-size: .85rem;
            color: #93c5fd;
            display: flex;
            gap: .6rem;
            align-items: flex-start;
            margin-bottom: 1.5rem;
            line-height: 1.6;
        }

        /* ── form ── */
        .form-group {
            margin-bottom: 1.25rem;
        }

        label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: var(--muted);
            margin-bottom: .5rem;
            letter-spacing: .02em;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            right: .9rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 1rem;
            pointer-events: none;
        }

        input[type="email"],
        input[type="password"],
        input[type="text"] {
            width: 100%;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: .75rem 2.5rem .75rem 1rem;
            color: var(--text);
            font-family: 'Tajawal', sans-serif;
            font-size: .95rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }

        input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(59,130,246,.15);
        }

        input::placeholder { color: #475569; }

        /* password toggle */
        .toggle-pw {
            position: absolute;
            left: .9rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            line-height: 1;
            transition: color .2s;
        }
        .toggle-pw:hover { color: var(--accent-h); }

        /* password strength bar */
        .strength-bar {
            height: 4px;
            border-radius: 2px;
            background: #1e293b;
            margin-top: .5rem;
            overflow: hidden;
        }
        .strength-fill {
            height: 100%;
            border-radius: 2px;
            width: 0%;
            transition: width .4s, background .4s;
        }
        .strength-label {
            font-size: .75rem;
            color: var(--muted);
            margin-top: .3rem;
            min-height: 1em;
        }

        /* validation messages */
        .field-validation-error,
        .validation-summary-errors li {
            color: var(--danger);
            font-size: .8rem;
            margin-top: .35rem;
            display: block;
        }
        .validation-summary-errors { list-style: none; padding: 0; }
        .validation-summary-errors ul { list-style: none; padding: 0; }

        .error-box {
            background: rgba(239,68,68,.1);
            border: 1px solid rgba(239,68,68,.3);
            border-radius: 10px;
            padding: .85rem 1rem;
            margin-bottom: 1.25rem;
            font-size: .85rem;
            color: #fca5a5;
        }

        /* ── submit button ── */
        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--accent), #6366f1);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: .85rem 1rem;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: transform .15s, box-shadow .15s, opacity .15s;
            box-shadow: 0 4px 20px rgba(59,130,246,.35);
            margin-top: .5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(59,130,246,.5);
        }

        .btn-submit:active { transform: translateY(0); }

        .btn-submit.loading { opacity: .7; pointer-events: none; }

        /* spinner */
        @@keyframes spin { to { transform: rotate(360deg); } }
        .spinner {
            width: 18px; height: 18px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
        }
        .btn-submit.loading .spinner { display: block; }
        .btn-submit.loading .btn-text { display: none; }

        /* ── footer note ── */
        .footer-note {
            text-align: center;
            margin-top: 1.5rem;
            font-size: .8rem;
            color: #475569;
            line-height: 1.7;
        }

        .footer-note .lock-icon { color: var(--success); }
    </style>
</head>
<body>
<div class="page">
  <div class="container">

    <!-- Logo -->
    <div class="logo-wrap">
      <div class="logo-icon">🏗️</div>
      <div class="logo-title">Bolcko</div>
      <div class="logo-sub">منصة المشاريع الإنشائية</div>
    </div>

    <!-- Card -->
    <div class="card">
      <div class="card-header">
        <div class="step-badge">1</div>
        <div>
          <div class="card-title">إعداد حساب المدير</div>
          <div class="card-desc">أنشئ حساب المدير الرئيسي للنظام</div>
        </div>
      </div>

      <div class="alert-info">
        <span>🔐</span>
        <span>هذه الصفحة تظهر مرة واحدة فقط عند أول تشغيل. بعد إنشاء حساب المدير لن يتمكن أحد من الوصول إليها.</span>
      </div>

      <!-- Validation Summary -->
      @if (!ViewData.ModelState.IsValid)
      {
        <div class="error-box">
          <div asp-validation-summary="ModelOnly"></div>
        </div>
      }

      <form method="post" action="/Setup" id="setupForm" novalidate>
        @Html.AntiForgeryToken()

        <!-- Email -->
        <div class="form-group">
          <label for="Email">📧 البريد الإلكتروني للمدير</label>
          <div class="input-wrap">
            <span class="input-icon">&#64;</span>
            <input type="email"
                   id="Email"
                   name="Email"
                   value="@Model?.Email"
                   placeholder="admin@yourcompany.com"
                   autocomplete="username"
                   required />
          </div>
          <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <!-- Password -->
        <div class="form-group">
          <label for="Password">🔑 كلمة المرور</label>
          <div class="input-wrap">
            <span class="input-icon">🔒</span>
            <input type="password"
                   id="Password"
                   name="Password"
                   placeholder="12 حرف على الأقل..."
                   autocomplete="new-password"
                   oninput="checkStrength(this.value)"
                   required />
            <button type="button" class="toggle-pw" onclick="togglePw('Password', this)" title="إظهار/إخفاء">👁</button>
          </div>
          <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
          <div class="strength-label" id="strengthLabel"></div>
          <span asp-validation-for="Password" class="field-validation-error"></span>
        </div>

        <!-- Confirm Password -->
        <div class="form-group">
          <label for="ConfirmPassword">🔑 تأكيد كلمة المرور</label>
          <div class="input-wrap">
            <span class="input-icon">🔒</span>
            <input type="password"
                   id="ConfirmPassword"
                   name="ConfirmPassword"
                   placeholder="أعد كتابة كلمة المرور..."
                   autocomplete="new-password"
                   required />
            <button type="button" class="toggle-pw" onclick="togglePw('ConfirmPassword', this)" title="إظهار/إخفاء">👁</button>
          </div>
          <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-submit" id="submitBtn">
          <div class="spinner"></div>
          <span class="btn-text">🚀 إنشاء حساب المدير وبدء النظام</span>
        </button>
      </form>
    </div>

    <!-- Footer -->
    <div class="footer-note">
      <span class="lock-icon">🛡</span>
      هذه الصفحة محمية — لا يمكن الوصول إليها بعد إنشاء المدير<br/>
      كلمة المرور مشفرة بـ ASP.NET Core Identity
    </div>

  </div>
</div>

<script>
  // ── Password visibility toggle ──
  function togglePw(id, btn) {
    const inp = document.getElementById(id);
    if (inp.type === 'password') { inp.type = 'text';     btn.textContent = '🙈'; }
    else                         { inp.type = 'password'; btn.textContent = '👁'; }
  }

  // ── Password strength meter ──
  function checkStrength(pw) {
    const fill  = document.getElementById('strengthFill');
    const label = document.getElementById('strengthLabel');
    let score = 0;
    if (pw.length >= 12) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[a-z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    const map = [
      { pct: '0%',   color: 'transparent',             text: '' },
      { pct: '20%',  color: '#ef4444',                 text: '⚠️ ضعيفة جداً' },
      { pct: '40%',  color: '#f97316',                 text: '🔸 ضعيفة' },
      { pct: '65%',  color: '#eab308',                 text: '🔶 متوسطة' },
      { pct: '85%',  color: '#3b82f6',                 text: '✅ جيدة' },
      { pct: '100%', color: '#10b981',                 text: '💪 قوية جداً' },
    ];
    fill.style.width      = map[score].pct;
    fill.style.background = map[score].color;
    label.textContent     = map[score].text;
  }

  // ── Loading state on submit ──
  document.getElementById('setupForm').addEventListener('submit', function (e) {
    // Basic client validation
    const pw  = document.getElementById('Password').value;
    const cpw = document.getElementById('ConfirmPassword').value;
    if (pw !== cpw) { e.preventDefault(); alert('كلمتا المرور غير متطابقتين'); return; }
    if (pw.length < 12) { e.preventDefault(); alert('كلمة المرور يجب أن تكون 12 حرف على الأقل'); return; }

    const btn = document.getElementById('submitBtn');
    btn.classList.add('loading');
  });
</script>
</body>
</html>
